  ['Community', 'Para builders locales y experimentos.', '0€', 'siempre', ['CLI completo y API Python', 'Modo local single-tenant', 'Verificación de ledger', 'Búsqueda híbrida', 'Código fuente Apache 2.0'], 'pip install cortex-persist', 'copy'],
  ['Pro', 'Para operadores de agentes serios.', '29€', '/mes', ['Sincronización cifrada multi-dispositivo', 'Cinco entornos tenant', 'Handoff y rastreo de ghosts', 'Soporte de implementación', 'Exportación de evidencia cloud'], 'Solicitar acceso Pro', 'pro'],
  ['Team', 'Para equipos de ingeniería bajo auditoría.', '99€', '/mes', ['Entornos tenant ilimitados', 'Flujos de consenso WBFT', 'Plantillas de reportes compliance', 'Fusión de conocimiento en grafo', 'Sesión de onboarding táctico'], 'Solicitar acceso Team', 'team'],
