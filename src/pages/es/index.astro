    <footer class="footer"><div><a class="brand notranslate" href="#hero" aria-label="CORTEX home" translate="no"><span class="brand-mark">C</span><span translate="no">CORTEX</span></a><p>Infraestructura de confianza para IA autónoma. Núcleo Apache 2.0.</p></div><nav aria-label="Navegación del pie de página"><a href="/org/">Confianza</a><a href="/site/">Docs</a><a href="/site/api/">API</a><a href="/site/security/">Seguridad</a><a href="/site/quickstart/">Quickstart</a><a href="/site/blog/">Blog</a><a href="/org/">Trust center</a></nav></footer>

    <div class="modal" id="checkout-modal" aria-hidden="true"><div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="checkout-title"><button class="modal-close" type="button" id="checkout-close" aria-label="Cerrar checkout">x</button><span class="section-kicker">Checkout seguro</span><h2 id="checkout-title">Solicitar acceso</h2><p id="checkout-copy">Los datos de la tarjeta son procesados por nuestro proveedor de pagos de forma segura. CORTEX no recopila datos de tarjeta sin procesar en esta página.</p><form id="checkout-form"><input type="hidden" name="plan" id="checkout-plan" value="pro" /><label for="checkout-email">Correo del trabajo</label><input id="checkout-email" name="email" type="email" inputmode="email" autocomplete="email" placeholder="tu@empresa.com" required /><button class="btn btn-primary" id="checkout-submit" type="submit">Continuar</button></form><p class="modal-footnote">Si el checkout online aún no está activado, el botón abrirá una solicitud formal pre-completada con el fundador.</p></div></div>

    <script is:inline>
      (() => {
        const nav = document.getElementById('nav');
        const modal = document.getElementById('checkout-modal');
        const close = document.getElementById('checkout-close');
        const form = document.getElementById('checkout-form');
        const planInput = document.getElementById('checkout-plan');
        const title = document.getElementById('checkout-title');
        const copy = document.getElementById('checkout-copy');
        const submit = document.getElementById('checkout-submit');
        const email = document.getElementById('checkout-email');
        const apiBaseMeta = document.querySelector('meta[name="cortex-api-base"]');
        const planCopy = {
          pro: { title: 'Solicitar acceso Pro', copy: 'Pro añade sincronización cifrada, cinco entornos tenant y soporte de implementación prioritario. El proveedor de pago maneja los detalles si el checkout alojado está activo.' },
          team: { title: 'Solicitar piloto Team', copy: 'Team añade entornos tenant ilimitados, flujos de consenso WBFT y plantillas de reportes compliance. El proveedor de pago maneja los detalles si el checkout alojado está activo.' }
        };
        const openModal = (plan) => { const selected = planCopy[plan] || planCopy.pro; planInput.value = plan; title.textContent = selected.title; copy.textContent = selected.copy; modal.classList.add('active'); modal.setAttribute('aria-hidden', 'false'); setTimeout(() => email.focus(), 50); };
        const closeModal = () => { modal.classList.remove('active'); modal.setAttribute('aria-hidden', 'true'); submit.disabled = false; submit.textContent = 'Continue'; };
        const resolvePublicOrigin = () => globalThis.location.protocol === 'file:' ? 'https://cortexpersist.com' : globalThis.location.origin;
        const resolveApiBase = () => globalThis.CORTEX_API_BASE_URL || apiBaseMeta?.content || resolvePublicOrigin();
        const checkoutEndpoint = () => new URL('/v1/billing/checkout', resolveApiBase()).toString();
        const copyInstall = async (button) => { const value = button.dataset.copy || 'pip install cortex-persist'; try { await navigator.clipboard.writeText(value); } catch (_) { const textarea = document.createElement('textarea'); textarea.value = value; textarea.setAttribute('readonly', ''); textarea.style.position = 'absolute'; textarea.style.left = '-9999px'; document.body.appendChild(textarea); textarea.select(); document.execCommand('copy'); textarea.remove(); } button.textContent = 'Copied: ' + value; setTimeout(() => { button.textContent = value; }, 1800); };
        document.querySelectorAll('.open-checkout').forEach((button) => button.addEventListener('click', () => openModal(button.dataset.plan)));
        document.querySelectorAll('.copy-install').forEach((button) => button.addEventListener('click', () => copyInstall(button)));
        close.addEventListener('click', closeModal);
        modal.addEventListener('click', (event) => { if (event.target === modal) closeModal(); });
        document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && modal.classList.contains('active')) closeModal(); });
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (!email.checkValidity()) { email.reportValidity(); return; }
          submit.disabled = true;
          submit.textContent = 'Opening secure checkout...';
          const plan = planInput.value;
          const publicOrigin = resolvePublicOrigin();
          const payload = { plan, customer_email: email.value, success_url: publicOrigin + '/success/', cancel_url: publicOrigin + '/cancel/', ui_mode: 'hosted' };
          try {
            const response = await fetch(checkoutEndpoint(), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (!response.ok) throw new Error('checkout unavailable');
            const data = await response.json();
            if (data.url) { globalThis.location.href = data.url; return; }
            throw new Error('checkout URL missing');
          } catch (_) {
            const subject = encodeURIComponent('CORTEX ' + plan.toUpperCase() + ' access request');
            const body = encodeURIComponent('Plan: ' + plan + '\nEmail: ' + email.value + '\n\nI want access to CORTEX ' + plan + '.');
            globalThis.location.href = 'mailto:borja@cortexpersist.com?subject=' + subject + '&body=' + body;
            closeModal();
          }
        });
        const onScroll = () => nav.classList.toggle('scrolled', globalThis.scrollY > 16);
        onScroll();
        globalThis.addEventListener('scroll', onScroll, { passive: true });

        const useCases = {
          crypto: {
            kicker: 'Paquete de Evidencia Fiscal',
            title: 'Forense blockchain y NFT para revisión de impuestos.',
            copy: 'Reconstruye wallets, exchanges, swaps, ventas NFT, royalties, comisiones y gaps de custodia en un dossier técnico trazable para un asesor fiscal.',
            tags: ['grafo wallet', 'hash tx', 'cost basis', 'PDF + CSV'],
            score: 96,
            checks: ['Deben reconciliarse múltiples fuentes.', 'Las decisiones deben explicarse meses después.', 'Un tercero revisará la evidencia.'],
            input: 'Wallets + CSVs exchanges + Mercados NFT',
            process: 'Clasificar, hashear, marcar gaps, sellar evidencia',
            output: 'PDF listo para asesor, CSV, manifest'
          },
          agent: {
            kicker: 'Pasaporte de memoria de agente',
            title: 'Un agente que recuerda sin fabricar su pasado.',
            copy: 'CORTEX separa la memoria útil de los hechos probados: preferencias, decisiones, tareas, transferencias y contexto de proyecto con fronteras de tenant.',
            tags: ['preferencias', 'handoff', 'tenant scope', 'ledger'],
            score: 91,
            checks: ['El agente opera durante semanas o meses.', 'Algunas decisiones no pueden perderse.', 'El contexto debe transferirse entre herramientas.'],
            input: 'Chats, decisiones de proyecto, tareas, eventos',
            process: 'Proteger, acotar, persistir, recuperar, verificar',
            output: 'Pasaporte de memoria portable para el agente'
          },
          research: {
            kicker: 'Cristalización profunda de investigación',
            title: 'Investigación que no muere en una transcripción.',
            copy: 'Convierte auditorías, benchmarks, análisis de repositorios e investigación competitiva en cristales de conocimiento con fuente, fecha y trazabilidad.',
            tags: ['origen', 'hallazgos', 'cristales', 'exportables'],
            score: 88,
            checks: ['Fuentes y conclusiones deben permanecer separadas.', 'El reporte será reutilizado más adelante.', 'Es crucial separar evidencia de hipótesis.'],
            input: 'Fuentes, repositorios, notas, prompts de auditoría',
            process: 'Adquirir, analizar, clasificar, cristalizar',
            output: 'Paquete de investigación basado en evidencia reutilizable'
          },
          incident: {
            kicker: 'Reconstrucción de Incidentes',
            title: 'Reconstruye lo que el sistema sabía cuando falló.',
            copy: 'Para bugs, incidentes de seguridad o decisiones automatizadas en disputa, CORTEX ayuda a reconstruir la memoria, las líneas temporales, las validaciones y el estado persistido.',
            tags: ['timeline', 'guards', 'log de auditoría', 'postmortem'],
            score: 93,
            checks: ['Una decisión automática está en disputa.', 'Necesitas una línea temporal verificable.', 'La respuesta debe sobrevivir a una auditoría.'],
            input: 'Eventos, escrituras en memoria, fallos de guard, entradas ledger',
            process: 'Replicar, verificar cadena, identificar divergencia',
            output: 'Línea temporal postmortem con anclajes de prueba'
          }
        };

        const usecaseRoot = document.querySelector('[data-usecase-console]');
        if (usecaseRoot) {
          const usecaseEls = {
            tabs: usecaseRoot.querySelectorAll('.usecase-tab'),
            main: usecaseRoot.querySelector('.usecase-main'),
            proof: usecaseRoot.querySelector('.usecase-proof'),
            flow: usecaseRoot.querySelector('.usecase-flow'),
            kicker: document.getElementById('usecase-kicker'),
            title: document.getElementById('usecase-title'),
            copy: document.getElementById('usecase-copy'),
            tags: document.getElementById('usecase-tags'),
            score: document.getElementById('usecase-score'),
            meter: document.getElementById('usecase-meter'),
            checks: document.getElementById('usecase-checks'),
            input: document.getElementById('usecase-input'),
            process: document.getElementById('usecase-process'),
            output: document.getElementById('usecase-output')
          };

          const renderUseCase = (key) => {
            const item = useCases[key] || useCases.crypto;
            usecaseEls.tabs.forEach((tab) => {
              const active = tab.dataset.usecase === key;
              tab.classList.toggle('active', active);
              tab.setAttribute('aria-selected', String(active));
            });
            [usecaseEls.main, usecaseEls.proof, usecaseEls.flow].forEach((el) => {
              el.classList.remove('is-swapping');
              void el.offsetWidth;
              el.classList.add('is-swapping');
            });
            usecaseEls.kicker.textContent = item.kicker;
            usecaseEls.title.textContent = item.title;
            usecaseEls.copy.textContent = item.copy;
            usecaseEls.tags.innerHTML = item.tags.map((tag) => `<em>${tag}</em>`).join('');
            usecaseEls.score.textContent = item.score;
            usecaseEls.meter.style.width = `${item.score}%`;
            usecaseEls.checks.innerHTML = item.checks.map((check) => `<li>${check}</li>`).join('');
            usecaseEls.input.textContent = item.input;
            usecaseEls.process.textContent = item.process;
            usecaseEls.output.textContent = item.output;
          };

          usecaseEls.tabs.forEach((tab) => {
            tab.addEventListener('click', () => renderUseCase(tab.dataset.usecase));
          });
        }
      })();
    </script>
  </body>
</html>
