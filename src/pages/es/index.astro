      <section id="pricing">
        <div class="section-heading"><span class="section-kicker">Precios</span><h2>Empieza localmente. Añade soporte gestionado cuando lo necesites.</h2><p>El núcleo open-source es gratuito. Los niveles de pago son para equipos que quieren sincronización alojada, soporte de implementación o evidencia de cumplimiento gestionada.</p></div>
        <div class="pricing-grid">
          {plans.map(([name, desc, price, suffix, items, cta, action], index) => <article class:list={['plan', index === 1 && 'highlighted', action === 'enterprise' && 'enterprise']}>
            {index === 1 && <div class="plan-badge">Acceso anticipado</div>}
            <div class="plan-head"><h3>{name}</h3><p>{desc}</p></div>
            <div class="price">{price} <span>{suffix}</span></div>
            <ul>{items.map((item) => <li>{item}</li>)}</ul>
            {action === 'copy' && <button class="btn btn-secondary copy-install" type="button" data-copy="pip install cortex-persist">{cta}</button>}
            {action === 'pro' && <button class="btn btn-primary open-checkout" type="button" data-plan="pro">{cta}</button>}
            {action === 'team' && <button class="btn btn-secondary open-checkout" type="button" data-plan="team">{cta}</button>}
            {action === 'enterprise' && <a class="btn btn-secondary" href="mailto:borja@cortexpersist.com?subject=Implementación%20Enterprise%20CORTEX">{cta}</a>}
          </article>)}
