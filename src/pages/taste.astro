---
// @C5-REAL
// ASTRO PAGE: /taste
// Fuses Industrial Noir 2026 aesthetics with the complete GOLD ALBUMS ledger.

import SiteLayout from '../layouts/SiteLayout.astro';
import { Music, Search, Disc, Clock, Calendar, ExternalLink, SlidersHorizontal, Youtube } from 'lucide-react';
import { CortexFriction } from '../lib/CortexFriction';

// Import our C5-REAL data
import albumsData from '../lib/playlist_albums.json';
import analysesData from '../lib/album_analyses_cache.json';
import exergyScores from '../lib/exergy_scores.json';

// C5-REAL: Telemetry Ping
CortexFriction.ping('taste.astro', 'RENDER');

// Helper to extract Spotify Album ID for embedding
function getEmbedUrl(url: string) {
  if (!url) return null;
  const match = url.match(/album\/([a-zA-Z0-9]+)/);
  return match ? `https://open.spotify.com/embed/album/${match[1]}?utm_source=generator&theme=0` : null;
}

// Helper to extract YouTube Video ID for embedding
function getYoutubeEmbedUrl(url: string) {
  if (!url) return null;
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
  return match ? `https://www.youtube.com/embed/${match[1]}` : null;
}

// Map and merge data
const albums = albumsData.map((album, index) => {
  const key = album.album_url || `unknown_album_${index}`;
  const searchKey = `${album.album_name} - ${album.artist}`;
  const exergyScore = (exergyScores as Record<string, number>)[searchKey] || 0.0;
  return {
    ...album,
    id: key,
    index: index + 1,
    exergyScore,
    analysis: analysesData[key as keyof typeof analysesData] || "Sonic analysis not available in local Ledger.",
    embedUrl: getEmbedUrl(album.album_url || ''),
    liveVideoUrl: album.live_video_url || null,
    youtubeEmbedUrl: getYoutubeEmbedUrl(album.live_video_url || '')
  };
});

const totalTracks = albums.reduce((acc, a) => acc + (a.tracks ? a.tracks.length : 0), 0);
const totalDurationSec = albums.reduce((acc, a) => acc + (a.tracks ? a.tracks.reduce((tAcc, t) => tAcc + (t.duration_sec || 0), 0) : 0), 0);
const totalHours = Math.floor(totalDurationSec / 3600);
const totalMinutes = Math.floor((totalDurationSec % 3600) / 60);
const durationStr = `${totalHours}h ${totalMinutes}m`;

const years = albums.map(a => parseInt(a.year || '')).filter(y => !isNaN(y));
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const yearsRangeStr = `${minYear} - ${maxYear}`;
---

<SiteLayout 
  title="GOLD ALBUMS · Sovereign Curation Ledger"
  description="The sonic vault and concentration repository for deep work behind Cortex Persist. 151 manually curated blocks."
  canonical="https://cortexpersist.com/taste"
>
  <main class="taste-container">
    
    <!-- Navigation Back Link -->
    <div class="nav-back-container">
      <a href="/" class="nav-back-link">
        ← BACK TO SUBSTRATE
      </a>
    </div>

    <!-- Hero Header -->
    <section class="taste-hero-section">
      <div class="taste-hero-banner">
        <div class="taste-hero-overlay"></div>
        <img 
          src="/assets/gold_albums_banner.png" 
          alt="Gold Albums Substack Banner" 
          class="taste-hero-img"
        />
        <div class="taste-hero-content">
          <div>
            <div class="taste-badge-wrapper">
              <span class="pulse-dot">
                <span class="pulse-ping"></span>
                <span class="pulse-solid"></span>
              </span>
              <span class="badge-text">
                The Official Cortex Soundtrack
              </span>
            </div>
            <h1 class="taste-hero-title">
              GOLD ALBUMS
            </h1>
            <p class="taste-hero-desc">
              The sonic bunker where we build <strong>Cortex Persist</strong>. 100% manual curation. Complete albums designed to sustain deep work states with zero algorithmic interruptions.
            </p>
          </div>
          
          <div class="taste-hero-meta">
            <span>Curator:</span>
            <span class="curator-value">Bakala de Troya</span>
          </div>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="taste-stats-grid">
        <div class="taste-stat-card">
          <div class="taste-stat-header">
            <Disc class="taste-stat-icon" />
            <span class="taste-stat-label">Albums</span>
          </div>
          <span class="taste-stat-value">{albums.length}</span>
        </div>
        
        <div class="taste-stat-card">
          <div class="taste-stat-header">
            <Music class="taste-stat-icon" />
            <span class="taste-stat-label">Tracks</span>
          </div>
          <span class="taste-stat-value">{totalTracks}</span>
        </div>

        <div class="taste-stat-card">
          <div class="taste-stat-header">
            <Clock class="taste-stat-icon" />
            <span class="taste-stat-label">Duration</span>
          </div>
          <span class="taste-stat-value">{durationStr}</span>
        </div>

        <div class="taste-stat-card">
          <div class="taste-stat-header">
            <Calendar class="taste-stat-icon" />
            <span class="taste-stat-label">Years Covered</span>
          </div>
          <span class="taste-stat-value">{yearsRangeStr}</span>
        </div>
      </div>
    </section>

    <!-- Manifesto / Block Modulation Split Layout -->
    <section class="taste-split-layout">
      <div class="taste-section-intro">
        <div class="taste-section-eyebrow">
          <span>0x00</span>
          <span class="taste-section-line"></span>
          <span>Noise vs. Signal</span>
        </div>
        <h2 class="taste-section-heading">
          Deep Work: <span>Zero Algorithms</span>
        </h2>
        <div class="taste-section-text">
          <p>
            Why does an AI infrastructure company have a music page? Because building complex code (like <span class="taste-bold-highlight">Cortex Persist</span>) requires absolute isolation. You don't write software while skipping through AI-generated playlists that break your focus.
          </p>
          <p>
            <span class="taste-bold-highlight">GOLD ALBUMS</span> is our internal concentration repository. A sonic vault built block-by-block, adding each album manually over the years. It contains {totalTracks} tracks curated with human precision. No auto-recommendations. No <em>skips</em>. Only full albums that respect the original creator's narrative.
          </p>
          <p>
            We open this library to the public. If you are a developer, founder, or simply need to escape Spotify's entropy for deep work, this is your sonic bunker. Close the door and start building.
          </p>
        </div>
      </div>

      <div class="taste-config-block">
        <div class="taste-section-eyebrow" style="margin-bottom: 1rem;">
          <span>0x01</span>
          <span class="taste-section-line"></span>
          <span>System Parameters</span>
        </div>
        <pre class="taste-config-pre"><code>Ledger: GOLD ALBUMS
Operator: Bakala de Troya
Scale: {totalTracks} Tracks (C5-REAL)
Active Blocks: {albums.length} LPs/EPs
Total Duration: {durationStr}
Curation: 100% Manual
Mission: Deep Work Focus</code></pre>
      </div>
    </section>

    <!-- Frequencies Section -->
    <section class="taste-split-layout" style="border-top: none; padding-top: 0;">
      <div class="taste-section-intro">
        <div class="taste-section-eyebrow">
          <span>Frequencies</span>
          <span class="taste-section-line"></span>
          <span>Block Modulation</span>
        </div>
        <p class="taste-section-text" style="font-size: 0.8rem;">
          Curation demands friction. By forcing the operator to process uninterrupted blocks of 40 to 60 minutes, the sonic design deploys its neurological modulation:
        </p>
        <div class="table-wrapper">
          <table class="frequencies-table">
            <thead>
              <tr>
                <th>Block</th>
                <th>Dominant Styles & Textures</th>
                <th>Technical Role</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="freq-block-num">01 - 25</td>
                <td>Cinematic Synthpop, Warm Electronic, Avant-Garde House</td>
                <td class="freq-desc">Beta wave modulation. Focus alignment.</td>
              </tr>
              <tr>
                <td class="freq-block-num">26 - 50</td>
                <td>Avant-Prog, Breaks, Spanish Indie Folk, Experimental Rap</td>
                <td class="freq-desc">Causal friction injection. Complex problems.</td>
              </tr>
              <tr>
                <td class="freq-block-num">51 - 100</td>
                <td>Melodic Techno, Dark Ambient, Glitch-Hop</td>
                <td class="freq-desc">Absolute isolation. High-density focus.</td>
              </tr>
              <tr>
                <td class="freq-block-num">101 - 151</td>
                <td>Synthwave, Post-Punk, Dark Ambient, Sci-Fi Soundtracks</td>
                <td class="freq-desc">Episodic memory consolidation.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="avatar-card">
        <div class="avatar-header">
          <span>AVATAR: 'BORJARL'</span>
          <span class="avatar-badge">Active</span>
        </div>
        <ul class="avatar-list">
          <li class="avatar-item">
            <span class="avatar-item-title">[Metallic Skin & Golden Mohawk]</span>
            <span class="avatar-item-desc">The fusion between the immutable rigor of the machine and the constant disruption of open source.</span>
          </li>
          <li class="avatar-item">
            <span class="avatar-item-title">[Tailoring & Patch Cords]</span>
            <span class="avatar-item-desc">Each cable represents a neural connection in the AST (Abstract Syntax Tree) of curation. Systems engineering applied to acoustics.</span>
          </li>
        </ul>
      </div>
    </section>

    <!-- Search and Controls Registry -->
    <div class="search-controls-container">
      <div class="search-header-row">
        <div class="taste-section-eyebrow" style="margin-bottom: 0.5rem;">
          <span>0x03</span>
          <span class="taste-section-line"></span>
          <span>Immutable Blocks Registry</span>
        </div>
        <h2 class="taste-section-heading">Subagent Audit</h2>
      </div>

      <div class="search-bar-row">
        <div class="search-input-wrapper">
          <Search class="search-icon" />
          <input 
            type="text" 
            id="search-input" 
            placeholder="Filter by artist, album, or year..." 
            class="search-input"
          />
        </div>
        
        <div class="action-buttons-group">
          <button id="sort-exergy-btn" class="filter-btn" data-active="false">
            <SlidersHorizontal class="filter-btn-icon" /> SORT: DEFAULT
          </button>
          <button id="view-grid-btn" class="filter-btn active">GRID</button>
          <button id="view-list-btn" class="filter-btn">LIST</button>
        </div>
      </div>
      
      <div id="results-count" class="results-telemetry">
        Showing {albums.length} of {albums.length} blocks
      </div>
    </div>

    <!-- Album Cards Container -->
    <section style="margin-bottom: 6rem;">
      <div id="albums-container" class="albums-grid">
        {albums.map((a) => (
          <div 
            class="taste-album-card"
            data-artist={a.artist.toLowerCase()}
            data-title={a.album_name.toLowerCase()}
            data-year={a.year ? a.year.toString() : ''}
            data-exergy={a.exergyScore}
            data-index={a.index}
          >
            <div class="card-top">
              <div class="card-badge-row">
                <span class="card-block-num">BLOCK #{a.index.toString().padStart(3, '0')}</span>
                <div class="card-badges">
                  {a.exergyScore > 9.0 && (
                    <span class="badge-high-exergy">HIGH EXERGY</span>
                  )}
                  <span class="badge-exergy">Ex: {a.exergyScore.toFixed(2)}</span>
                  {a.year && (
                    <span class="badge-year">{a.year}</span>
                  )}
                </div>
              </div>

              <h3 class="card-album-name">{a.album_name}</h3>
              <p class="card-artist">{a.artist}</p>
              <p class="card-analysis">"{a.analysis}"</p>
            </div>

            <div class="card-bottom">
              {a.embedUrl && (
                <div class="embed-wrapper hidden">
                  <iframe 
                    class="lazy-spotify-iframe" 
                    data-src={a.embedUrl}
                    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
                    loading="lazy"
                  ></iframe>
                </div>
              )}

              {a.youtubeEmbedUrl && (
                <div class="video-wrapper hidden">
                  <iframe 
                    class="lazy-youtube-iframe" 
                    data-src={a.youtubeEmbedUrl}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              )}
              
              <div class="card-actions">
                <div class="card-play-actions">
                  <button class="play-btn">[PLAY]</button>
                  {a.youtubeEmbedUrl && (
                    <button class="watch-btn" style="margin-left: 0.8rem; display: inline-flex; align-items: center; gap: 0.25rem;">
                      <Youtube class="watch-btn-icon" style={{width: "0.85rem", height: "0.85rem", color: "#ff0000"}} /> [WATCH CONCERT]
                    </button>
                  )}
                </div>
                {a.album_url && (
                  <a 
                    href={a.album_url} 
                    target="_blank" 
                    class="spotify-link"
                  >
                    Open Spotify <ExternalLink class="link-icon" />
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

  </main>
</SiteLayout>

<style>
  /* Scoped styles for the Gold Albums taste page */
  .taste-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
    position: relative;
    z-index: 10;
  }
  
  .nav-back-container {
    margin-bottom: 2.5rem;
  }
  
  .nav-back-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  
  .nav-back-link:hover {
    color: var(--accent-soft);
  }
  
  /* Hero section styling */
  .taste-hero-section {
    margin-bottom: 3.5rem;
  }
  
  .taste-hero-banner {
    position: relative;
    height: 280px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--line);
    overflow: hidden;
    margin-bottom: 2rem;
    box-shadow: 0 0 35px rgba(43, 59, 229, 0.15);
  }
  
  @media (min-width: 768px) {
    .taste-hero-banner {
      height: 360px;
    }
  }
  
  .taste-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--bg-0) 10%, rgba(10, 10, 10, 0.4) 60%, transparent 100%);
    z-index: 10;
  }
  
  .taste-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) contrast(1.15);
  }
  
  .taste-hero-content {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    right: 2rem;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  
  @media (min-width: 768px) {
    .taste-hero-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }
  
  .taste-badge-wrapper {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(43, 59, 229, 0.3);
    background: rgba(43, 59, 229, 0.1);
    backdrop-filter: blur(12px);
    margin-bottom: 0.5rem;
    width: fit-content;
  }
  
  .pulse-dot {
    position: relative;
    display: flex;
    width: 6px;
    height: 6px;
  }
  
  .pulse-ping {
    position: absolute;
    display: inline-flex;
    height: 100%;
    width: 100%;
    border-radius: 9999px;
    background-color: var(--accent-soft);
    opacity: 0.75;
    animation: ping 1.2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  
  .pulse-solid {
    position: relative;
    display: inline-flex;
    border-radius: 9999px;
    height: 6px;
    width: 6px;
    background-color: var(--accent-soft);
  }
  
  .badge-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.64rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }
  
  .taste-hero-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }
  
  @media (min-width: 768px) {
    .taste-hero-title {
      font-size: 3.8rem;
    }
  }
  
  .taste-hero-desc {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.6;
    max-width: 580px;
    margin: 0.2rem 0 0;
  }
  
  .taste-hero-meta {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  
  .curator-value {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-transform: uppercase;
  }
  
  /* Stats grid */
  .taste-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3.5rem;
  }
  
  @media (min-width: 768px) {
    .taste-stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .taste-stat-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
    box-shadow: var(--shadow);
  }
  
  .taste-stat-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent-soft);
  }
  
  .taste-stat-icon {
    width: 0.9rem;
    height: 0.9rem;
  }
  
  .taste-stat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  
  .taste-stat-value {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
  }
  
  /* Sections container */
  .taste-split-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3rem;
    margin-bottom: 4rem;
  }
  
  @media (min-width: 1024px) {
    .taste-split-layout {
      grid-template-columns: 2fr 1fr;
    }
  }
  
  .taste-section-intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .taste-section-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-soft);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  
  .taste-section-line {
    height: 1px;
    width: 24px;
    background: rgba(110, 124, 255, 0.3);
  }
  
  .taste-section-heading {
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }
  
  .taste-section-heading span {
    color: var(--success);
  }
  
  .taste-section-text {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.7;
    margin: 0;
    font-weight: 300;
  }
  
  .taste-section-text p {
    margin: 0 0 1rem 0;
  }
  
  .taste-section-text p:last-child {
    margin-bottom: 0;
  }
  
  .taste-bold-highlight {
    color: #fff;
    font-weight: 500;
  }
  
  .taste-italic-highlight {
    color: #fff;
    font-style: italic;
  }
  
  /* System configuration block */
  .taste-config-block {
    background: var(--panel-strong);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  
  .taste-config-block::after {
    content: '';
    position: absolute;
    top: -4rem;
    right: -4rem;
    width: 8rem;
    height: 8rem;
    background: rgba(43, 59, 229, 0.08);
    border-radius: 999px;
    filter: blur(24px);
  }
  
  .taste-config-pre {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: 1.1rem;
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.7;
    color: var(--success);
    overflow-x: auto;
  }
  
  /* Table block styles */
  .table-wrapper {
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.01);
    margin-top: 1rem;
  }
  
  .frequencies-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.76rem;
    text-align: left;
  }
  
  .frequencies-table th {
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.8rem 1rem;
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }
  
  .frequencies-table td {
    padding: 0.9rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.8);
  }
  
  .frequencies-table tr:hover td {
    background: rgba(255, 255, 255, 0.015);
  }
  
  .freq-block-num {
    font-weight: 700;
    color: var(--accent-soft);
  }
  
  .freq-desc {
    color: var(--muted);
  }
  
  /* Avatar side panel */
  .avatar-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  
  .avatar-header {
    display: flex;
    justify-content: space-between;
