  .play-btn, .watch-btn {
    background: transparent;
    border: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--accent-soft);
    cursor: pointer;
    padding: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all 0.2s ease;
  }
  
  .play-btn:hover, .watch-btn:hover {
    color: #fff;
  }
  
  .spotify-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s ease;
  }
  
  .spotify-link:hover {
    color: #fff;
  }
  
  .link-icon {
    width: 0.65rem;
    height: 0.65rem;
  }
  
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
</style>

<script>
  // Client-side search, view toggle, and sorting scripting
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const cards = document.querySelectorAll('.taste-album-card') as NodeListOf<HTMLDivElement>;
  const container = document.getElementById('albums-container') as HTMLDivElement;
  const resultsCount = document.getElementById('results-count') as HTMLDivElement;
  
  const viewGridBtn = document.getElementById('view-grid-btn') as HTMLButtonElement;
  const viewListBtn = document.getElementById('view-list-btn') as HTMLButtonElement;
  const sortExergyBtn = document.getElementById('sort-exergy-btn') as HTMLButtonElement;

  // Sorting Logic
  if (sortExergyBtn && container) {
    sortExergyBtn.addEventListener('click', () => {
      const isActive = sortExergyBtn.getAttribute('data-active') === 'true';
      const cardArray = Array.from(cards);
      
      if (!isActive) {
        // Sort by Exergy descending
        cardArray.sort((a, b) => {
          const exA = parseFloat(a.getAttribute('data-exergy') || '0');
          const exB = parseFloat(b.getAttribute('data-exergy') || '0');
          return exB - exA;
        });
        sortExergyBtn.innerHTML = `<span class="inline-block w-1.5 h-1.5 rounded-full bg-[#ff0055] mr-1.5 animate-ping"></span> SORT: EXERGY`;
        sortExergyBtn.setAttribute('data-active', 'true');
        sortExergyBtn.className = "filter-btn active";
      } else {
        // Sort back to index ascending (original order)
        cardArray.sort((a, b) => {
          const idxA = parseInt(a.getAttribute('data-index') || '0');
          const idxB = parseInt(b.getAttribute('data-index') || '0');
          return idxA - idxB;
        });
        sortExergyBtn.innerHTML = `SORT: DEFAULT`;
        sortExergyBtn.setAttribute('data-active', 'false');
        sortExergyBtn.className = "filter-btn";
      }
      
      // Append cards in sorted order
      cardArray.forEach(card => container.appendChild(card));
    });
  }

  // Filter Logic
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value.toLowerCase().trim();
      let visibleCount = 0;
      
      cards.forEach(card => {
        const artist = card.dataset.artist || '';
        const title = card.dataset.title || '';
        const year = card.dataset.year || '';
        
        if (artist.includes(val) || title.includes(val) || year.includes(val)) {
          card.style.display = 'flex';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      
      if (resultsCount) {
        resultsCount.textContent = `Showing ${visibleCount} of ${cards.length} blocks`;
      }
    });
  }

  // View Toggles
  if (viewGridBtn && viewListBtn && container) {
    viewGridBtn.addEventListener('click', () => {
      container.classList.remove('list-view');
      viewGridBtn.classList.add('active');
      viewListBtn.classList.remove('active');
    });

    viewListBtn.addEventListener('click', () => {
      container.classList.add('list-view');
      viewListBtn.classList.add('active');
      viewGridBtn.classList.remove('active');
    });
  }

  // Play/Embed Toggle Logic
  cards.forEach(card => {
    const playBtn = card.querySelector('.play-btn') as HTMLButtonElement;
    const embedWrapper = card.querySelector('.embed-wrapper') as HTMLDivElement;
    const iframe = card.querySelector('.lazy-spotify-iframe') as HTMLIFrameElement;

    const watchBtn = card.querySelector('.watch-btn') as HTMLButtonElement;
    const videoWrapper = card.querySelector('.video-wrapper') as HTMLDivElement;
    const youtubeIframe = card.querySelector('.lazy-youtube-iframe') as HTMLIFrameElement;
    
    if (playBtn && embedWrapper && iframe) {
      playBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = embedWrapper.classList.contains('hidden');
        
        if (isHidden) {
          // Lazy load the iframe source
          const src = iframe.dataset.src;
          if (src && !iframe.src) {
            iframe.src = src;
          }
          embedWrapper.classList.remove('hidden');
          playBtn.textContent = "[HIDE PLAYER]";

          // Hide video player if open
          if (videoWrapper && !videoWrapper.classList.contains('hidden')) {
            videoWrapper.classList.add('hidden');
            if (watchBtn) watchBtn.textContent = "[WATCH CONCERT]";
          }
        } else {
          embedWrapper.classList.add('hidden');
          playBtn.textContent = "[PLAY]";
        }
      });
    }

    if (watchBtn && videoWrapper && youtubeIframe) {
      watchBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = videoWrapper.classList.contains('hidden');
        
        if (isHidden) {
          // Lazy load the YouTube iframe source
          const src = youtubeIframe.dataset.src;
          if (src && !youtubeIframe.src) {
            youtubeIframe.src = src;
          }
          videoWrapper.classList.remove('hidden');
          watchBtn.textContent = "[HIDE CONCERT]";

          // Hide Spotify player if open
          if (embedWrapper && !embedWrapper.classList.contains('hidden')) {
            embedWrapper.classList.add('hidden');
            if (playBtn) playBtn.textContent = "[PLAY]";
          }
        } else {
          videoWrapper.classList.add('hidden');
          watchBtn.textContent = "[WATCH CONCERT]";
        }
      });
    }
  });
</script>
