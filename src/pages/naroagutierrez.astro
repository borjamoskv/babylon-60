const exhibitions = [
	{ date: 'Sep 2025', title: 'Verhoeven x12', venue: 'Próxima Presentación', status: 'upcoming' },
	{ date: 'May 2025', title: 'DiviNos VaiVenes', venue: 'Politena Espacio de Arte, Bilbao', status: 'past' },
	{ date: 'Jul 2024', title: 'Siarte y El Bosque de Oma', venue: 'Siarte Ediciones', status: 'past' },
	{ date: 'Jan 2023', title: 'Emakumeen arteaN', venue: 'Harilka Elkartea (Colectivo Feminista)', status: 'past' },
	{ date: 'Mar 2022', title: 'Repóker de Reinas', venue: 'Siarte Leku', status: 'past' },
	{ date: 'Oct 2020', title: 'Iconos Pop', venue: 'Clara Campoamor, Barakaldo', status: 'past' },
	{ date: 'Jul 2015', title: 'Espejos del Alma', venue: 'Ilustre Colegio de Abogados de Bizkaia', status: 'past' },
	{ date: 'Sep 2012', title: 'Fitting Room', venue: 'Hotel Meliá Bilbao (difundido en EITB)', status: 'past' },
	{ date: '2002/12', title: 'Espejos del Alma', venue: 'Museo de Bellas Artes de Bilbao', status: 'past' }
];

const artworks = [
	{
		id: 'amy-rocks',
		title: 'Amy Rocks',
		series: 'Rocks',
		year: '2023',
		medium: 'Acrílico y mica mineral sobre pizarra natural',
		commons: 'Naroa_Gutierrez_Gil_-_Amy_Rocks_(2023).webp',
		svgType: 'slate-amy'
	},
	{
		id: 'marilyn-rocks',
		title: 'Marilyn Rocks (I)',
		series: 'Rocks',
		year: '2023',
		medium: 'Acrílico y mica mineral sobre pizarra natural',
		commons: 'Naroa_Gutierrez_Gil_-_Marilyn_Rocks_(I)_(2023).webp',
		svgType: 'slate-marilyn'
	},
	{
		id: 'mr-fahrenheit',
		title: 'Mr. Fahrenheit',
		series: 'Tributos',
		year: '2021',
		medium: 'Técnica mixta y tinta sobre madera',
		commons: 'Naroa_Gutierrez_Gil_-_Mr._Fahrenheit_(2021).webp',
		svgType: 'portrait-freddie'
	},
	{
		id: 'espejos-del-alma',
		title: 'Espejos del Alma',
		series: 'Espejos',
		year: '2023',
		medium: 'Acrílico y collage sobre lienzo',
		commons: 'Naroa_Gutierrez_Gil_-_Espejos_del_Alma_(2023).webp',
		svgType: 'mirror'
	},
	{
		id: 'amor-en-conserva',
		title: 'Amor en Conserva',
		series: 'Enlatas',
		year: '2022',
		medium: 'Acrílico y técnica mixta sobre lienzo',
		commons: 'Naroa_Gutierrez_Gil_-_Amor_en_Conserva_(2022).webp',
		svgType: 'can'
	},
	{
		id: 'lagrimas-de-oro',
		title: 'Lágrimas de Oro',
		series: 'Golden',
		year: '2021',
		medium: 'Acrílico y pan de oro sobre madera',
		commons: 'Naroa_Gutierrez_Gil_-_Lagrimas_de_Oro_(2021).webp',
		svgType: 'gold-tears'
	},
	{
		id: 'peter-rowan',
		title: 'Peter Rowan',
		series: 'Retratos',
		year: '2023',
		medium: 'Carboncillo y acrílico sobre papel',
		commons: 'Naroa_Gutierrez_Gil_-_Peter_Rowan_(2023).webp',
		svgType: 'portrait-peter'
	}
];

const pressLinks = [
	{ date: '10/01/2009', media: 'El País', context: 'Expodistrito Bilbao - Espejos del Alma', url: 'https://elpais.com/diario/2009/01/10/paisvasco/1231620008_850215.html' },
	{ date: '09/09/2014', media: 'La Vanguardia', context: 'Paisajes Retratados - Barakart', url: 'https://www.lavanguardia.com/local/pais-vasco/20140909/54414829898/las-salas-municipales-de-barakaldo-retoman-su-programacion-expositiva-en-septiembre-con-ocho.html' },
	{ date: '25/03/2022', media: 'Siarte.com', context: 'Repóker de Reinas - Siarte Leku', url: 'https://siarte.com/2022-03-25-siarte-exposicion-pintura-collage-arte-naroa-gutierrez.php' },
	{ date: '20/07/2015', media: 'DEIA', context: 'Espejos del alma - Colegio de Abogados', url: 'https://www.deia.eus/cultura/2015/07/20/agenda-5113256.html' },
	{ date: '29/09/2012', media: 'EITB Kultura', context: 'Fitting Room 2012 - Meliá Bilbao', url: 'https://www.eitb.eus/es/television/detalle/956660/zinemaldia-los-cortos-kimuak-2012-zinemira--eitb-kultura/' }
];
---

<SiteLayout
	title="Wiki de Naroa Gutiérrez Gil | Nodo de Arte Institucional"
	description="Ficha biográfica institucional, catálogo selecto de obras y cronología verificada de exposiciones de la artista plástica bilbaína Naroa Gutiérrez Gil."
	canonical="https://cortexpersist.com/naroagutierrez"
	lang="es"
>
	<main class="landing-shell wiki-layout">
		<!-- Header de navegación superior -->
		<header class="masthead">
			<a class="brand" href="/" aria-label="CORTEX Persist home">
				<span class="brand-mark">CP</span>
				<span class="brand-copy">
					<strong>CORTEX Persist</strong>
					<span>Verifiable memory for AI agents</span>
				</span>
			</a>

			<nav class="site-nav" aria-label="Primary">
				<a class="nav-link" href="#perfil">Perfil</a>
				<a class="nav-link" href="#obras">Obras</a>
				<a class="nav-link" href="#exposiciones">Exposiciones</a>
				<a class="nav-link" href="#prensa">Prensa</a>
				<a class="nav-link" href="#institucional">Datos</a>
			</nav>

			<div class="masthead-actions">
				<a class="button-tertiary" href="/dashboard" aria-label="Acceder al Panel de Control del Espacio Gemelo">
					Twin Panel
				</a>
				<a class="button-tertiary" href="/vsa">
					VSA Shell
				</a>
				<a class="button-primary" href="https://www.wikidata.org/wiki/Q137970281" target="_blank" rel="noreferrer">
					Wikidata Node
				</a>
			</div>
		</header>

		<!-- Hero de la Ficha Biográfica -->
		<section class="wiki-hero surface" id="perfil">
			<div class="hero-header">
				<div class="title-block">
					<p class="eyebrow glow-green">Ficha Biográfica / Wiki Node</p>
					<h1>Naroa Gutiérrez Gil</h1>
					<p class="subtitle">Artista Plástica, Artivista y Artesana Emocional</p>
				</div>
				<div class="wikidata-badge">
					<span class="badge-label">Wikidata ID</span>
					<a href="https://www.wikidata.org/wiki/Q137970281" target="_blank" rel="noreferrer" class="badge-value">Q137970281</a>
				</div>
			</div>

			<div class="wiki-intro-grid">
				<div class="bio-text">
					<p>
						<strong>Naroa Gutiérrez Gil</strong> (Bilbao, España) es una artista plástica multidisciplinar y artivista conocida por sus retratos expresivos en técnica mixta y sus series conceptuales que exploran la figura humana, la introspección y la memoria emocional. Su práctica artística se distingue por la superposición tricolor y texturas minerales complejas sobre soportes no convencionales como la pizarra natural y la madera.
					</p>
					<p>
						A lo largo de su trayectoria, Gutiérrez Gil ha desarrollado un lenguaje visual enfocado en el <strong>"error como método"</strong> y la tensión entre la precisión hiperrealista y la imperfección orgánica digital. Sus obras actúan como "espejos del alma" que invitan a la contemplación y a la re-creación personal a través de la pintura.
					</p>
					<div class="meta-pills">
						<span class="chip font-mono">Bilbao, Euskadi</span>
						<span class="chip font-mono">Hiperrealismo Pop</span>
						<span class="chip font-mono">Técnica Mixta / Pizarra</span>
						<span class="chip font-mono">Harilka Elkartea</span>
					</div>

					<div class="sonic-link-card">
						<div class="sonic-label">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
							Conexión sonora
						</div>
						<p class="sonic-title">La mujer que soñaba con ser ruido blanco</p>
						<p class="sonic-meta">Bakala de Troya — Lore Electrónico: Borja Moskv Multiverso · Track 6</p>
						<div class="sonic-actions">
							<a href="https://soundcloud.com/borja-moskv/la-mujer-que-sonaba-con-convertirse-en-ruido" target="_blank" rel="noreferrer" class="sonic-btn sc">
								<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M1.175 12.225c-.088 0-.164.069-.175.155l-.012.094.012.095c.011.086.087.155.175.155.088 0 .164-.069.175-.155l.013-.095-.013-.094c-.011-.086-.087-.155-.175-.155zm1.394-.3c-.1 0-.186.073-.198.172l-.011.084.011.085c.012.1.098.173.198.173.1 0 .187-.073.199-.173l.012-.085-.012-.084c-.012-.099-.099-.172-.199-.172zm1.412-.187c-.112 0-.206.082-.219.192l-.011.08.011.08c.013.11.107.193.219.193.112 0 .206-.083.219-.193l.012-.08-.012-.08c-.013-.11-.107-.192-.219-.192zm11.557-5.192C14.519 3.013 11.591 1 8.175 1 4.536 1 1.581 3.834 1.406 7.413L1.4 7.5l.006.088C1.581 11.166 4.536 14 8.175 14h7.363C17.449 14 19 12.449 19 10.537c0-1.819-1.394-3.306-3.188-3.461-.037-.001-.073-.003-.109-.003-.057 0-.113.003-.169.009-.047-2.007-1.674-3.637-3.706-3.637-.469 0-.916.087-1.327.244z"/></svg>
								SoundCloud
							</a>
							<a href="https://borjamoskv.bandcamp.com/track/la-mujer-que-so-aba-con-ser-ru-do-blanco" target="_blank" rel="noreferrer" class="sonic-btn bc">
								<svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
								Bandcamp
							</a>
						</div>
					</div>
				</div>
				<aside class="bio-quick-facts surface-sunken">
					<div class="surface-head">
						<span class="surface-label">Detalles del Perfil</span>
						<span class="surface-state">Verificado</span>
					</div>
					<div class="quick-facts-list">
						<div class="fact-row">
							<span class="label">Nacimiento</span>
							<span class="val">Bilbao, Bizkaia</span>
						</div>
						<div class="fact-row">
							<span class="label">Especialidad</span>
							<span class="val">Retrato, Joyería de Autor, Pintura</span>
						</div>
						<div class="fact-row">
							<span class="label">Movimiento</span>
							<span class="val">Artivismo, Expresionismo Pop, Neo-Kintsugi</span>
						</div>
						<div class="fact-row">
							<span class="label">Soporte Clave</span>
							<span class="val">Pizarra, Lienzo, Madera de deriva</span>
						</div>
						<div class="fact-row">
							<span class="label">Afiliación</span>
							<span class="val">Harilka Elkartea, Azoka en Lataska</span>
						</div>
					</div>
				</aside>
			</div>
		</section>

		<!-- Sección de Catálogo de Obras Selectas -->
		<section class="section-frame surface" id="obras">
			<div class="section-heading">
				<p class="section-kicker glow-blue">Catálogo selecto</p>
				<h2>Obras Destacadas</h2>
				<p>
					Selección curada de obras maestras que ilustran la evolución de sus técnicas mixtas, texturas minerales de mica y soporte conceptual de retratos.
				</p>
			</div>

			<div id="twin-banner-mount"></div>

			<div class="artworks-grid">
				{artworks.map((work) => (
					<article class="artwork-card-premium surface-sunken">
						<div class="artwork-preview">
							<!-- Procedural SVG representational blueprint for the artwork -->
							{work.svgType === 'slate-amy' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<path d="M 50 80 L 350 50 L 370 240 L 30 260 Z" fill="#1b1c22" stroke="#2b3be5" stroke-width="1.5" opacity="0.85"/>
									<path d="M 60 90 L 340 60 L 350 230 L 45 245 Z" fill="#14151a" stroke="#00ff41" stroke-width="1" opacity="0.7"/>
									<circle cx="150" cy="140" r="45" fill="none" stroke="#2b3be5" stroke-dasharray="4 6" stroke-width="2"/>
									<circle cx="250" cy="160" r="35" fill="none" stroke="#00ff41" stroke-dasharray="3 3" stroke-width="1.5"/>
									<path d="M 120 150 Q 200 100 280 170" fill="none" stroke="#cc0000" stroke-width="3" stroke-linecap="round"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">SLATE SUBSTRATE // MICA OVERLAY</text>
								</svg>
							)}
							{work.svgType === 'slate-marilyn' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<path d="M 60 60 L 340 70 L 320 250 L 80 230 Z" fill="#1e1f26" stroke="#2b3be5" stroke-width="1.5" opacity="0.85"/>
									<path d="M 70 70 L 330 80 L 310 240 L 90 220 Z" fill="#121318" stroke="#00ff41" stroke-width="1" opacity="0.6"/>
									<rect x="140" y="110" width="120" height="80" fill="none" stroke="#2b3be5" stroke-width="1" stroke-dasharray="5 5"/>
									<path d="M 170 180 Q 200 130 230 180" fill="none" stroke="#cc0000" stroke-width="2.5"/>
									<circle cx="200" cy="140" r="25" fill="none" stroke="#00ff41" stroke-width="1.5"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">PIZARRA // DUO-TONE TEXTURE</text>
								</svg>
							)}
							{work.svgType === 'portrait-freddie' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<path d="M 100 50 L 300 50 L 300 250 L 100 250 Z" fill="#14141c" stroke="#2b3be5" stroke-width="1"/>
									<circle cx="200" cy="110" r="50" fill="none" stroke="#00ff41" stroke-width="2"/>
									<path d="M 170 170 H 230" stroke="#cc0000" stroke-width="4"/>
									<path d="M 200 110 L 200 200" stroke="#2b3be5" stroke-dasharray="2 4" stroke-width="1"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">WOOD PANEL // DYNAMIC TRIBUTE</text>
								</svg>
							)}
							{work.svgType === 'mirror' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<ellipse cx="200" cy="150" rx="90" ry="70" fill="#101322" stroke="#2b3be5" stroke-width="2"/>
									<ellipse cx="200" cy="150" rx="80" ry="60" fill="none" stroke="#00ff41" stroke-dasharray="10 4 2 4" stroke-width="1"/>
									<path d="M 130 150 Q 200 220 270 150" fill="none" stroke="#cc0000" stroke-width="3" stroke-linecap="round"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">CANVAS // REFLECTION ENGINE</text>
								</svg>
							)}
							{work.svgType === 'can' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<rect x="130" y="70" width="140" height="160" rx="15" fill="#161822" stroke="#2b3be5" stroke-width="2"/>
									<ellipse cx="200" cy="70" rx="70" ry="12" fill="#202436" stroke="#00ff41" stroke-width="1"/>
									<path d="M 150 140 H 250" stroke="#cc0000" stroke-width="2.5"/>
									<path d="M 150 160 H 250" stroke="#00ff41" stroke-width="1.5" stroke-dasharray="3 3"/>
									<text x="145" y="125" fill="#edf5ff" font-family="'Orbitron', sans-serif" font-size="12" letter-spacing="1">AMOR</text>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">ENLATAS SERIES // POP METAPHOR</text>
								</svg>
							)}
							{work.svgType === 'gold-tears' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<polygon points="200,60 270,230 130,230" fill="#1c1810" stroke="#d8b56a" stroke-width="2"/>
									<path d="M 200 60 V 230" stroke="#00ff41" stroke-width="1" stroke-dasharray="5 5"/>
									<circle cx="200" cy="130" r="10" fill="#cc0000"/>
									<path d="M 200 130 Q 180 180 185 220" fill="none" stroke="#d8b56a" stroke-width="3" stroke-linecap="round"/>
									<path d="M 200 130 Q 220 190 215 220" fill="none" stroke="#d8b56a" stroke-width="3" stroke-linecap="round"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">GOLDEN SERIES // METALLIC ACCENT</text>
								</svg>
							)}
							{work.svgType === 'portrait-peter' && (
								<svg viewBox="0 0 400 300" class="art-svg" aria-label={`Representación abstracta de ${work.title}`}>
									<rect width="100%" height="100%" fill="#080808"/>
									<path d="M 120 70 Q 200 30 280 70 T 320 220 Q 200 270 80 220 Z" fill="#13141a" stroke="#2b3be5" stroke-width="1" opacity="0.8"/>
									<path d="M 160 140 C 160 110, 240 110, 240 140" fill="none" stroke="#00ff41" stroke-width="2"/>
									<circle cx="200" cy="150" r="6" fill="#cc0000"/>
									<path d="M 150 180 C 180 210, 220 210, 250 180" fill="none" stroke="#edf5ff" stroke-width="1.5" stroke-dasharray="2 2"/>
									<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">RETRATOS // HIGHCONTRAST CHARCOAL</text>
								</svg>
							)}
						</div>
						<div class="artwork-info">
							<div class="info-header">
								<span class="artwork-tag-series">{work.series}</span>
								<span class="artwork-tag-year">{work.year}</span>
							</div>
							<h3>{work.title}</h3>
							<p class="artwork-medium">{work.medium}</p>
							<div class="artwork-actions">
								<span class="commons-tag">Commons: {work.id}</span>
								<a href={`https://commons.wikimedia.org/wiki/File:${work.commons}`} target="_blank" rel="noreferrer" class="button-tertiary compact">
									Wiki Asset
								</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- Sección de Cronología de Exposiciones -->
		<section class="section-frame surface" id="exposiciones">
			<div class="section-heading">
				<p class="section-kicker glow-green">Historial</p>
				<h2>Cronología de Exposiciones</h2>
				<p>
					Registro verificado de exposiciones en museos, espacios colectivos e instituciones desde el año 2002.
				</p>
			</div>

			<div class="timeline-container">
				<div class="timeline-line"></div>
				<div class="timeline-list">
					{exhibitions.map((ex) => (
						<div class:list={['timeline-item', ex.status === 'upcoming' && 'timeline-upcoming']}>
							<div class="timeline-time font-mono">
								{ex.date}
								{ex.status === 'upcoming' && <span class="badge-upcoming">PRÓXIMA</span>}
							</div>
							<div class="timeline-badge-node"></div>
							<div class="timeline-content surface-sunken">
								<h3>{ex.title}</h3>
								<p class="venue">{ex.venue}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Sección de Prensa y Colectivos -->
		<div class="wiki-dual-section">
			<!-- Verified Press Index -->
			<section class="section-frame surface" id="prensa">
				<div class="section-heading">
					<p class="section-kicker glow-blue">Hemeroteca</p>
					<h2>Prensa e Impacto Editorial</h2>
					<p>
						Indexación de artículos y referencias críticas en prensa de primer nivel que sustentan el registro institucional de notabilidad.
					</p>
				</div>

				<div class="press-table-container">
					<table class="press-table">
						<thead>
							<tr>
								<th>Fecha</th>
								<th>Medio</th>
								<th>Contexto / Enlace</th>
							</tr>
						</thead>
						<tbody>
							{pressLinks.map((press) => (
								<tr>
									<td class="font-mono text-muted">{press.date}</td>
									<td><strong>{press.media}</strong></td>
									<td>
										<a href={press.url} target="_blank" rel="noreferrer" class="press-link">
											{press.context}
											<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
										</a>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<!-- Artivism and Collectives Details -->
			<section class="section-frame surface" id="colectivos">
				<div class="section-heading">
					<p class="section-kicker glow-green">Artivismo</p>
					<h2>Redes y Espacio Público</h2>
					<p>
						Integración en redes sororales, colectivos transformadores de Bizkaia y muestras públicas en la costa vasca.
					</p>
				</div>

				<div class="collectives-grid">
					<article class="collective-card surface-sunken">
						<h3>Harilka Elkartea (Bilbao)</h3>
						<p>
