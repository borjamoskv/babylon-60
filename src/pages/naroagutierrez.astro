						bannerMount.innerHTML = `
							<div class="twin-alert surface-sunken font-mono" style="border: 1px solid var(--accent-green); padding: 0.8rem 1.2rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; background: rgba(0, 255, 65, 0.04); font-size: 0.8rem; flex-wrap: wrap; gap: 0.8rem;">
