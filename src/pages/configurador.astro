---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
	title="CORTEX Persist | Swarm Architect & Configurator"
	description="Interactive product configurator and dynamic topology designer for Cortex-Persist. Compute pricing, audit paths, and cryptographically sign exergy agreements."
	canonical="https://cortexpersist.com/configurador"
	bodyClass="configurador-body"
>
	<main class="landing-shell configurador-container">
		<header class="config-header animate-fade-in">
			<a class="back-link" href="/" aria-label="Back to landing">
				&larr; Return to landing
			</a>
			<div class="header-main">
				<span class="eyebrow">Exergy Optimizer v10.5</span>
				<h1>Swarm Architect &amp; Configurator</h1>
				<p class="subtitle">
					Deconstruct, configure, and provision your agent memory topology. Map latencies, simulate Byzantine faults, and emit signed exergy agreements directly to the ledger.
				</p>
			</div>
		</header>

		<div class="config-grid">
			<!-- Form Control Side -->
			<section class="surface config-controls animate-slide-up">
				<div class="section-head">
					<div class="control-brand">
						<span class="surface-label">Configuration Engine</span>
						<span class="sensor-state">Active</span>
					</div>
					<span class="status-indicator" id="system-status">STANDBY</span>
				</div>

				<!-- Step 1: Deployment Tier -->
				<fieldset class="config-section">
					<legend class="surface-label">1. Deployment Infrastructure Tier</legend>
					<div class="options-vertical">
						<div class="option-wrapper">
							<input type="radio" name="tier" id="tier-self" value="self" checked class="hidden-input" />
							<label class="option-card-v2" for="tier-self">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Self-Hosted (BYOC)</span>
									<span class="option-desc">Sovereign local nodes. Bring Your Own Compute. Community audited.</span>
								</div>
								<span class="option-price">$0/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="tier" id="tier-pro" value="pro" class="hidden-input" />
							<label class="option-card-v2" for="tier-pro">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Pro Cloud</span>
									<span class="option-desc">Shared edge compute database with telemetry output streams.</span>
								</div>
								<span class="option-price">$29/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="tier" id="tier-legion" value="legion" class="hidden-input" />
							<label class="option-card-v2" for="tier-legion">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Legion Swarm</span>
									<span class="option-desc">Dedicated edge cluster. Handles lock-free routing for 1k concurrent agents.</span>
								</div>
								<span class="option-price">$99/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="tier" id="tier-sovereign" value="sovereign" class="hidden-input" />
							<label class="option-card-v2" for="tier-sovereign">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Sovereign Enterprise</span>
									<span class="option-desc">Isolated multi-tenant VPC, 15-node BFT consensus, hardware HSM keys.</span>
								</div>
								<span class="option-price">$999/mo</span>
							</label>
						</div>
					</div>
				</fieldset>

				<!-- Step 2: Storage & Vector Backend -->
				<fieldset class="config-section">
					<legend class="surface-label">2. Storage Topography &amp; Vector Sink</legend>
					<div class="options-vertical">
						<div class="option-wrapper">
							<input type="radio" name="storage" id="storage-sqlite" value="sqlite" checked class="hidden-input" />
							<label class="option-card-v2" for="storage-sqlite">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">SQLite + sqlite-vec (Local)</span>
									<span class="option-desc">Zero-dependency vector search. In-memory speed, full disk locality.</span>
								</div>
								<span class="option-price">+$0</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="storage" id="storage-turbopuffer" value="turbopuffer" class="hidden-input" />
							<label class="option-card-v2" for="storage-turbopuffer">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Turbopuffer L2 Cloud Sink</span>
									<span class="option-desc">L1 local cache with automated, compressed L2 cold storage compaction.</span>
								</div>
								<span class="option-price">+$20/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="storage" id="storage-alloydb" value="alloydb" class="hidden-input" />
							<label class="option-card-v2" for="storage-alloydb">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">AlloyDB pgvector Cluster</span>
									<span class="option-desc">Distributed serverless cluster with infinite index scaling.</span>
								</div>
								<span class="option-price">+$150/mo</span>
							</label>
						</div>
					</div>
				</fieldset>

				<!-- Step 3: Agent Scale Slider + Direct input -->
				<div class="config-section">
					<span class="surface-label">3. Concurrent Agent Scale</span>
					<div class="slider-container-v2">
						<div class="slider-header">
							<span class="slider-label">Provisioned Scale</span>
							<div class="slider-input-group">
								<input type="number" id="agent-number-input" min="1" max="10000" value="10" class="agent-number-box" />
								<span class="agent-suffix">Agents</span>
							</div>
						</div>
						<input type="range" id="agent-slider" min="1" max="10000" value="10" class="cortex-slider" />
						<div class="slider-ticks">
							<span>1</span>
							<span>1k</span>
							<span>5k</span>
							<span>10k</span>
						</div>
						<div class="scale-yield-alert" id="scale-alert">
							Scale matches tier allocation boundaries. No overage charges apply.
						</div>
					</div>
				</div>

				<!-- Step 4: SLA & Consensus -->
				<fieldset class="config-section">
					<legend class="surface-label">4. Consensus &amp; SLA Boundary</legend>
					<div class="options-vertical">
						<div class="option-wrapper">
							<input type="radio" name="sla" id="sla-best" value="best_effort" checked class="hidden-input" />
							<label class="option-card-v2" for="sla-best">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">Best Effort Execution</span>
									<span class="option-desc">Standard thread pool dispatch. Non-guaranteed failover.</span>
								</div>
								<span class="option-price">+$0</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="sla" id="sla-uptime" value="uptime" class="hidden-input" />
							<label class="option-card-v2" for="sla-uptime">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">99.9% Swarm Availability</span>
									<span class="option-desc">L1 Redis cache integration and replicated event listeners.</span>
								</div>
								<span class="option-price">+$49/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="radio" name="sla" id="sla-bft" value="bft" class="hidden-input" />
							<label class="option-card-v2" for="sla-bft">
								<span class="custom-radio"></span>
								<div class="option-details">
									<span class="option-title">99.99% BFT Consensus Guarantee</span>
									<span class="option-desc">Active hedged race execution (CortexLLMRouter) and Byzantine fault limits.</span>
								</div>
								<span class="option-price">+$299/mo</span>
							</label>
						</div>
					</div>
				</fieldset>

				<!-- Step 5: Compliance Modules -->
				<fieldset class="config-section">
					<legend class="surface-label">5. Cryptographic Compliance &amp; Security</legend>
					<div class="options-vertical">
						<div class="option-wrapper">
							<input type="checkbox" id="comp-eu" value="eu_ai" class="hidden-input" />
							<label class="option-card-v2 checkbox-card" for="comp-eu">
								<span class="custom-checkbox"></span>
								<div class="option-details">
									<span class="option-title">EU AI Act (Article 12) Audit Trail</span>
									<span class="option-desc">Automated, signed verification trails. Verifiable facts lineage.</span>
								</div>
								<span class="option-price">+$39/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="checkbox" id="comp-soc" value="soc2" class="hidden-input" />
							<label class="option-card-v2 checkbox-card" for="comp-soc">
								<span class="custom-checkbox"></span>
								<div class="option-details">
									<span class="option-title">SOC 2 continuous monitoring</span>
									<span class="option-desc">Automated system health reporting and immutable export tools.</span>
								</div>
								<span class="option-price">+$99/mo</span>
							</label>
						</div>

						<div class="option-wrapper">
							<input type="checkbox" id="comp-zk" value="zk_keys" class="hidden-input" />
							<label class="option-card-v2 checkbox-card" for="comp-zk">
								<span class="custom-checkbox"></span>
								<div class="option-details">
									<span class="option-title">Zero-Knowledge Hardware Key Encryption</span>
									<span class="option-desc">Hardware HSM integration. All memories encrypted at rest.</span>
								</div>
								<span class="option-price">+$199/mo</span>
							</label>
						</div>
					</div>
				</fieldset>
			</section>

			<!-- Visualization & Summary Side -->
			<section class="config-summary animate-slide-up" style="animation-delay: 100ms;">
				<!-- Topology Blueprint with SVG Flow -->
				<article class="surface config-topology">
					<div class="surface-head">
						<span class="surface-label">Active Topology Blueprint</span>
						<span class="surface-state" id="topo-state">Sovereign Local</span>
					</div>
					
					<div class="blueprint-canvas-container">
						<!-- SVG Flow lines -->
						<svg class="topo-connections-svg" xmlns="http://www.w3.org/2000/svg">
							<defs>
								<linearGradient id="flow-grad" x1="0%" y1="0%" x2="0%" y2="100%">
									<stop offset="0%" stop-color="var(--accent-soft)" />
									<stop offset="100%" stop-color="var(--green)" />
								</linearGradient>
							</defs>
							
							<!-- Main path: Agents -> Core -->
							<path id="path-agent-to-core" class="topo-path active" d="M 140 55 L 140 100" />
							
							<!-- Core -> Storage (Left branch) -->
							<path id="path-core-to-storage" class="topo-path active" d="M 140 142 L 75 142 L 75 200" />
							
							<!-- Core -> Compliance (Right branch) -->
							<path id="path-core-to-compliance" class="topo-path" d="M 140 142 L 205 142 L 205 200" />
							
							<!-- Core -> HSM (Center branch) -->
							<path id="path-core-to-hsm" class="topo-path" d="M 140 142 L 140 280" />
						</svg>

						<div class="topo-nodes-wrapper">
							<!-- Node 1: Swarm input -->
							<div class="topo-node central-agent" id="node-agent">
								<span class="node-label">MOSKV-1 Swarm</span>
								<span class="node-sub" id="agent-display-count">10 Agents</span>
							</div>

							<!-- Node 2: Core persistent engine -->
							<div class="topo-node engine-core" id="node-core">
								<span class="node-label">CORTEX Persist L1</span>
								<span class="node-sub">Taint &amp; Verification</span>
							</div>

							<!-- Node row for targets -->
							<div class="topo-flex-row">
								<div class="topo-node store-sink" id="node-storage">
									<span class="node-label">Local SQLite-Vec</span>
									<span class="node-sub">Locality: 100%</span>
								</div>

								<div class="topo-node compliance-node opaque-hidden" id="node-compliance">
									<span class="node-label">Audit Exporter</span>
									<span class="node-sub">EU AI / SOC 2 Logs</span>
								</div>
							</div>

							<!-- HSM node -->
							<div class="topo-node security-node opaque-hidden" id="node-hsm">
								<span class="node-label">Hardware HSM Gateway</span>
								<span class="node-sub">Zero-Knowledge active</span>
							</div>
						</div>
					</div>
				</article>

				<!-- Performance / Yield Panel -->
				<article class="surface config-metrics">
					<div class="surface-head">
						<span class="surface-label">Thermodynamic Metrics</span>
						<span class="surface-state">Calculated</span>
					</div>
					<div class="metrics-row">
						<div class="metric-card">
							<span class="metric-label">Latency (TTFT)</span>
							<strong id="metric-latency" class="glow-value">75 ms</strong>
						</div>
						<div class="metric-card">
							<span class="metric-label">Fault Tolerance</span>
							<strong id="metric-bft" class="glow-value">f = 0</strong>
						</div>
						<div class="metric-card">
							<span class="metric-label">Exergy Yield</span>
							<strong id="metric-exergy" class="glow-value">98.2%</strong>
						</div>
					</div>
				</article>

				<!-- Cost Calculation Panel -->
				<article class="surface-sunken config-pricing">
					<div class="pricing-header">
						<span class="surface-label">CORTEX Exergy Agreement</span>
						<div class="price-display">
							<span class="currency">$</span>
							<span class="amount font-orbitron" id="total-price-val">0</span>
							<span class="period">/mo</span>
						</div>
					</div>

					<div class="pricing-breakdown">
						<div class="breakdown-item">
							<span id="label-tier">Self-Hosted Tier</span>
							<span id="val-tier">$0/mo</span>
						</div>
						<div class="breakdown-item">
							<span id="label-storage">Local Storage</span>
							<span id="val-storage">$0/mo</span>
						</div>
						<div class="breakdown-item">
							<span id="label-agents">Agent Scale</span>
							<span id="val-agents">$0/mo</span>
						</div>
						<div class="breakdown-item">
							<span id="label-sla">Best Effort SLA</span>
							<span id="val-sla">$0/mo</span>
						</div>
						<div class="breakdown-item hidden" id="breakdown-comp">
							<span>Compliance Modules</span>
							<span id="val-comp">$0/mo</span>
						</div>
					</div>

					<!-- Interactive console for signing sequence -->
					<div class="console-logger hidden" id="ledger-console">
						<div class="console-lines" id="console-output"></div>
					</div>

					<button class="button-primary sign-button" id="sign-ledger-btn">
						<span class="button-icon">&#x2716;</span>
						Cripto-Firme de Contrato (Emitir a Ledger)
					</button>
				</article>
			</section>
		</div>
	</main>
</SiteLayout>

<style is:global>
	/* Configurator animations */
	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}
	@keyframes slideUp {
		from { opacity: 0; transform: translateY(12px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@keyframes dash {
		to {
			stroke-dashoffset: -40;
		}
	}
	@keyframes pulseGlow {
		0%, 100% { box-shadow: 0 0 10px rgba(43, 59, 229, 0.15); }
		50% { box-shadow: 0 0 25px rgba(43, 59, 229, 0.35); }
	}

	.animate-fade-in {
		animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	.animate-slide-up {
		animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		opacity: 0;
	}

	.configurador-body {
		background-attachment: fixed;
	}

	.configurador-container {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		min-height: calc(100vh - 4rem);
		padding-bottom: 4rem;
		padding-top: 2rem;
	}

	.config-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.back-link {
		color: var(--accent-soft);
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.85rem;
		font-weight: 500;
		transition: color 150ms ease;
		width: max-content;
	}

	.back-link:hover {
		color: var(--text);
	}

	.header-main {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.header-main h1 {
		font-family: 'Orbitron', sans-serif;
		font-size: 2.2rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		margin: 0;
		text-transform: uppercase;
	}

	.subtitle {
		color: var(--muted);
		font-size: 1.1rem;
		line-height: 1.5;
		margin: 0;
		max-width: 700px;
	}

	.config-grid {
		display: grid;
		gap: 1.8rem;
		grid-template-columns: 1.25fr 1fr;
	}

	@media (max-width: 1024px) {
		.config-grid {
			grid-template-columns: 1fr;
		}
	}

	.config-controls {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 2.2rem;
	}

	.section-head {
		align-items: center;
		border-bottom: 1px solid var(--line);
		display: flex;
		justify-content: space-between;
		padding-bottom: 1.2rem;
	}

	.control-brand {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.sensor-state {
		color: var(--success);
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.65rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.status-indicator {
		background: rgba(43, 59, 229, 0.12);
		border: 1px solid var(--line);
		border-radius: 4px;
		color: var(--accent-soft);
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.78rem;
		font-weight: 600;
		padding: 0.3rem 0.65rem;
		transition: all 0.3s ease;
	}

	.config-section {
		border: none;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		margin: 0;
		padding: 0;
	}

	.options-vertical {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	/* Hidden native inputs for fully custom styling */
	.hidden-input {
		opacity: 0;
		position: absolute;
		z-index: -1;
	}

	.option-card-v2 {
		align-items: center;
		background: rgba(15, 15, 18, 0.4);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		cursor: pointer;
		display: flex;
		gap: 1.2rem;
		padding: 1.2rem;
		position: relative;
		transition:
			background 200ms cubic-bezier(0.16, 1, 0.3, 1),
			border-color 200ms cubic-bezier(0.16, 1, 0.3, 1),
			transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
		user-select: none;
	}

	.option-card-v2:hover {
		background: rgba(255, 255, 255, 0.02);
		border-color: var(--line-strong);
		transform: translateY(-1px);
	}

	/* Active states based on checkbox/radio sibling selections */
	.hidden-input:checked + .option-card-v2 {
		background: rgba(43, 59, 229, 0.05);
		border-color: var(--accent-soft);
		box-shadow: 0 0 15px rgba(43, 59, 229, 0.1);
	}

	/* Custom radio button design */
	.custom-radio {
		border: 1px solid var(--line);
		border-radius: 999px;
		height: 1.15rem;
		position: relative;
		transition: all 180ms ease;
		width: 1.15rem;
	}

	.custom-radio::after {
		background: var(--accent-soft);
		border-radius: 999px;
		content: '';
		height: 0.55rem;
		left: 50%;
		opacity: 0;
		position: absolute;
		top: 50%;
		transform: translate(-50%, -50%) scale(0.65);
		transition: all 180ms cubic-bezier(0.16, 1, 0.3, 1);
		width: 0.55rem;
	}

	.hidden-input:checked + .option-card-v2 .custom-radio {
		border-color: var(--accent-soft);
		box-shadow: 0 0 8px rgba(43, 59, 229, 0.4);
	}

	.hidden-input:checked + .option-card-v2 .custom-radio::after {
		opacity: 1;
		transform: translate(-50%, -50%) scale(1);
	}

	/* Custom Checkbox design */
	.custom-checkbox {
		border: 1px solid var(--line);
		border-radius: var(--radius-md);
		height: 1.15rem;
		position: relative;
		transition: all 180ms ease;
		width: 1.15rem;
	}

	.custom-checkbox::after {
		border-bottom: 2px solid var(--success);
		border-right: 2px solid var(--success);
		content: '';
		height: 0.55rem;
		left: 32%;
		opacity: 0;
		position: absolute;
		top: 15%;
		transform: rotate(45deg) scale(0.65);
		transition: all 180ms cubic-bezier(0.16, 1, 0.3, 1);
		width: 0.3rem;
	}

	.hidden-input:checked + .option-card-v2 .custom-checkbox {
		border-color: var(--success);
		box-shadow: 0 0 8px rgba(0, 229, 163, 0.3);
	}

	.hidden-input:checked + .option-card-v2 .custom-checkbox::after {
		opacity: 1;
		transform: rotate(45deg) scale(1);
	}

	.option-details {
		display: flex;
		flex-direction: column;
		flex-grow: 1;
		gap: 0.25rem;
	}

	.option-title {
		color: var(--text);
		font-size: 0.98rem;
		font-weight: 700;
	}

	.option-desc {
		color: var(--muted);
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.option-price {
		color: var(--text);
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.92rem;
		font-weight: 600;
	}

	.hidden-input:checked + .option-card-v2.checkbox-card {
		background: rgba(0, 229, 163, 0.03);
		border-color: var(--green);
	}

	/* Slider Design v2 */
	.slider-container-v2 {
		background: rgba(15, 15, 18, 0.4);
