<script>
	// Configurator script for UI and pricing updates
	document.addEventListener('DOMContentLoaded', () => {
		const agentSlider = document.getElementById('agent-slider') as HTMLInputElement;
		const agentInput = document.getElementById('agent-number-input') as HTMLInputElement;
		const scaleAlert = document.getElementById('scale-alert');
		const agentDisplayCount = document.getElementById('agent-display-count');
		
		// Metrics
		const metricLatency = document.getElementById('metric-latency');
		const metricBft = document.getElementById('metric-bft');
		const metricExergy = document.getElementById('metric-exergy');
		
		// Pricing Targets
		const totalPriceVal = document.getElementById('total-price-val');
		const labelTier = document.getElementById('label-tier');
		const valTier = document.getElementById('val-tier');
		const labelStorage = document.getElementById('label-storage');
		const valStorage = document.getElementById('val-storage');
		const labelAgents = document.getElementById('label-agents');
		const valAgents = document.getElementById('val-agents');
		const labelSla = document.getElementById('label-sla');
		const valSla = document.getElementById('val-sla');
		const breakdownComp = document.getElementById('breakdown-comp');
		const valComp = document.getElementById('val-comp');

		// Blueprint nodes
		const nodeStorage = document.getElementById('node-storage');
		const nodeCompliance = document.getElementById('node-compliance');
		const nodeHsm = document.getElementById('node-hsm');
		const topoState = document.getElementById('topo-state');

		// Blueprint SVG Paths
		const pathCompliance = document.getElementById('path-core-to-compliance');
		const pathHsm = document.getElementById('path-core-to-hsm');
		const pathStorage = document.getElementById('path-core-to-storage');

		// Interactive signature console
		const signBtn = document.getElementById('sign-ledger-btn');
		const systemStatus = document.getElementById('system-status');
		const consoleLogger = document.getElementById('ledger-console');
		const consoleOutput = document.getElementById('console-output');

		function calculate() {
			// Radios
			const tierEl = document.querySelector('input[name="tier"]:checked') as HTMLInputElement;
			const tier = tierEl ? tierEl.value : 'self';
			
			const storageEl = document.querySelector('input[name="storage"]:checked') as HTMLInputElement;
			const storage = storageEl ? storageEl.value : 'sqlite';
			
			const slaEl = document.querySelector('input[name="sla"]:checked') as HTMLInputElement;
			const sla = slaEl ? slaEl.value : 'best_effort';

			// Checkboxes
			const compEu = (document.getElementById('comp-eu') as HTMLInputElement).checked;
			const compSoc = (document.getElementById('comp-soc') as HTMLInputElement).checked;
			const compZk = (document.getElementById('comp-zk') as HTMLInputElement).checked;

			// Synced inputs validation
			let agents = parseInt(agentInput.value);
			if (isNaN(agents) || agents < 1) agents = 1;
			if (agents > 10000) agents = 10000;

			// Base Pricing
			let tierCost = 0;
			let tierLabel = 'Self-Hosted Tier';
			let tierBaseAgents = 10;
			let costPerAgent = 0.10;

			if (tier === 'pro') {
				tierCost = 29;
				tierLabel = 'Pro Cloud Tier';
				tierBaseAgents = 100;
				costPerAgent = 0.08;
			} else if (tier === 'legion') {
				tierCost = 99;
				tierLabel = 'Legion Swarm Tier';
				tierBaseAgents = 1000;
				costPerAgent = 0.05;
			} else if (tier === 'sovereign') {
				tierCost = 999;
				tierLabel = 'Sovereign Ent. Tier';
				tierBaseAgents = 10000;
				costPerAgent = 0.02;
			}

			// Storage Pricing
			let storageCost = 0;
			let storageLabel = 'Local SQLite-Vec';
			if (storage === 'turbopuffer') {
				storageCost = 20;
				storageLabel = 'Turbopuffer L2 Cloud';
			} else if (storage === 'alloydb') {
				storageCost = 150;
				storageLabel = 'AlloyDB pgvector';
			}

			// SLA Pricing
			let slaCost = 0;
			let slaLabel = 'Best Effort SLA';
			if (sla === 'uptime') {
				slaCost = 49;
				slaLabel = '99.9% Swarm SLA';
			} else if (sla === 'bft') {
				slaCost = 299;
				slaLabel = '99.99% BFT SLA';
			}

			// Compliance Pricing
			let compCost = 0;
			if (compEu) compCost += 39;
			if (compSoc) compCost += 99;
			if (compZk) compCost += 199;

			// Agent cost
			let agentCost = 0;
			if (agents > tierBaseAgents) {
				agentCost = Math.round((agents - tierBaseAgents) * costPerAgent);
				if (scaleAlert) {
					scaleAlert.textContent = `Overage detected: +$${costPerAgent.toFixed(2)}/agent exceeding base of ${tierBaseAgents.toLocaleString()}.`;
					scaleAlert.classList.add('overage');
				}
			} else {
				if (scaleAlert) {
					scaleAlert.textContent = `Scale matches tier allocation boundaries. (Base limit: ${tierBaseAgents.toLocaleString()} agents)`;
					scaleAlert.classList.remove('overage');
				}
			}

			const total = tierCost + storageCost + agentCost + slaCost + compCost;

			// Output values
			if (totalPriceVal) totalPriceVal.textContent = total.toLocaleString();
			if (agentDisplayCount) {
				agentDisplayCount.textContent = `${agents.toLocaleString()} Agent${agents > 1 ? 's' : ''}`;
			}

			// Output breakdown
			if (labelTier) labelTier.textContent = tierLabel;
			if (valTier) valTier.textContent = `$${tierCost}/mo`;
			if (labelStorage) labelStorage.textContent = storageLabel;
			if (valStorage) valStorage.textContent = `+$${storageCost}/mo`;
			if (labelAgents) labelAgents.textContent = `Agent Scale (${agents.toLocaleString()} agents)`;
			if (valAgents) valAgents.textContent = `+$${agentCost}/mo`;
			if (labelSla) labelSla.textContent = slaLabel;
			if (valSla) valSla.textContent = `+$${slaCost}/mo`;

			if (compEu || compSoc || compZk) {
				if (breakdownComp) breakdownComp.classList.remove('hidden');
				if (valComp) valComp.textContent = `+$${compCost}/mo`;
			} else {
				if (breakdownComp) breakdownComp.classList.add('hidden');
			}

			// Topology Node Updates
			if (nodeStorage) {
				const labelNode = nodeStorage.querySelector('.node-label');
				const subNode = nodeStorage.querySelector('.node-sub');
				if (storage === 'sqlite') {
					if (labelNode) labelNode.textContent = 'Local SQLite-Vec';
					if (subNode) subNode.textContent = 'Locality: 100%';
				} else if (storage === 'turbopuffer') {
					if (labelNode) labelNode.textContent = 'Turbopuffer L2 Sink';
					if (subNode) subNode.textContent = 'Locality: Hybrid Cloud';
				} else if (storage === 'alloydb') {
					if (labelNode) labelNode.textContent = 'Distributed AlloyDB';
					if (subNode) subNode.textContent = 'Locality: pgvector Cloud';
				}
			}

			// Node visibility and SVG flow activation
			if (nodeCompliance && pathCompliance) {
				if (compEu || compSoc) {
					nodeCompliance.classList.remove('opaque-hidden');
					pathCompliance.classList.add('active');
				} else {
					nodeCompliance.classList.add('opaque-hidden');
					pathCompliance.classList.remove('active');
				}
			}

			if (nodeHsm && pathHsm && hsmArrow) {
				if (compZk) {
					nodeHsm.classList.remove('opaque-hidden');
					pathHsm.classList.add('active');
				} else {
					nodeHsm.classList.add('opaque-hidden');
					pathHsm.classList.remove('active');
				}
			}

			if (pathStorage) {
				if (storage !== 'sqlite') {
					// Different flow for remote storage
					pathStorage.style.stroke = 'var(--accent-soft)';
				} else {
					pathStorage.style.stroke = '';
				}
			}

			if (topoState) {
				if (tier === 'self' && storage === 'sqlite') {
					topoState.textContent = 'Sovereign Local';
				} else if (tier === 'sovereign' || storage === 'alloydb' || sla === 'bft') {
					topoState.textContent = 'Distributed BFT';
				} else {
					topoState.textContent = 'Hybrid Edge';
				}
			}

			// Performance calculations
			if (metricLatency) {
				let latency = 85;
				if (tier === 'legion' || tier === 'sovereign') latency = 25;
				if (storage === 'sqlite') latency -= 10;
				if (sla === 'bft') latency = 12; // active race routing
				metricLatency.textContent = `${latency} ms`;
			}

			if (metricBft) {
				if (sla === 'bft' || tier === 'sovereign') {
					metricBft.textContent = 'f = 4 (n=15)';
				} else if (sla === 'uptime') {
					metricBft.textContent = 'f = 1 (n=4)';
				} else {
					metricBft.textContent = 'f = 0 (n=1)';
				}
			}

			if (metricExergy) {
				let exergy = 98.2;
				if (compZk) exergy += 0.5;
				if (compEu) exergy += 0.8;
				if (storage === 'alloydb') exergy -= 1.2;
				metricExergy.textContent = `${exergy.toFixed(1)}%`;
			}
		}

		// Double sync for range and number input
		agentSlider.addEventListener('input', () => {
			agentInput.value = agentSlider.value;
			calculate();
		});

		agentInput.addEventListener('change', () => {
			agentSlider.value = agentInput.value;
			calculate();
		});

		// Monitor input changes
		const inputs = document.querySelectorAll('input[type="radio"], input[type="checkbox"]');
		inputs.forEach(input => {
			input.addEventListener('change', calculate);
		});

		// Console Logging Signing Flow simulation
		if (signBtn) {
			signBtn.addEventListener('click', () => {
				signBtn.setAttribute('disabled', 'true');
				signBtn.textContent = 'Compilando acuerdo exergético...';
				if (systemStatus) {
					systemStatus.textContent = 'PROVISIONING';
					systemStatus.style.background = 'rgba(229, 43, 85, 0.12)';
					systemStatus.style.color = 'var(--warning)';
					systemStatus.style.borderColor = 'rgba(229, 43, 85, 0.3)';
				}

				if (consoleLogger && consoleOutput) {
					consoleLogger.classList.remove('hidden');
					consoleOutput.innerHTML = '';

					const lines = [
						{ text: '[KERNEL] Solicitando firmas para acuerdo exergético...', type: 'info' },
						{ text: '[CRYPTO] Iniciando cifrado de contrato Ed25519...', type: 'info' },
						{ text: '[CRYPTO] Firma del Demiurgo autorizada: ID = borjamoskv', type: 'success' },
						{ text: '[KERNEL] Inyectando CORTEX-TAINT en bloque de entrada...', type: 'info' },
						{ text: '[LEDGER] Calculando Hash criptográfico del bloque...', type: 'info' },
						{ text: '[LEDGER] Bloque validado. Hash: c5df762ab88a11394fcd0317e0827b5e48df16c', type: 'success' },
						{ text: '[SYSTEM] Estructura aprovisionada en Cloudflare Edge.', type: 'success' },
						{ text: '[SYSTEM] Ecosistema: C5-REAL (Working Tree Clean)', type: 'success' }
					];

					let i = 0;
					function printLine() {
						if (i < lines.length) {
							const p = document.createElement('p');
							p.className = `console-line ${lines[i].type}`;
							p.textContent = lines[i].text;
							consoleOutput?.appendChild(p);
							consoleLogger?.scrollTo(0, consoleLogger.scrollHeight);
							i++;
							setTimeout(printLine, 400);
						} else {
							signBtn.textContent = 'Acuerdo firmado e inyectado';
							signBtn.style.background = 'linear-gradient(135deg, var(--green), var(--green))';
							signBtn.style.color = '#0a0a0a';
							if (systemStatus) {
								systemStatus.textContent = 'COMMITTED';
								systemStatus.style.background = 'rgba(0, 229, 163, 0.15)';
								systemStatus.style.color = 'var(--success)';
								systemStatus.style.borderColor = 'rgba(0, 229, 163, 0.3)';
							}
						}
					}
					printLine();
				}
			});
		}

		// Run calculation on load
		calculate();
	});
</script>
