---
import SpectrogramAudioLab from '../components/SpectrogramAudioLab.astro';
import Layout from '../layouts/Layout.astro';

const marketingOrigin = import.meta.env.PUBLIC_MARKETING_ORIGIN || '';
const homeHref = marketingOrigin || '/';
---

<Layout
  title="DJ Automata — Immersive Ambient Engine by CORTEX"
  description="An immersive spectral route: paint, diffuse, and keep DJ Automata broadcasting ambient avant-garde audio live in the browser."
>
  <header class="spectral-page-header">
    <div class="spectral-page-header__inner w">
      <a class="spectral-page-header__brand" href={homeHref}>
        <span>CP</span>
        <strong>DJ Automata</strong>
      </a>
      <nav class="spectral-page-header__nav" aria-label="Spectral lab navigation">
        <a href={homeHref}>Home</a>
        <a href="#how-it-works">How it works</a>
        <a href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="spectral-hero w">
      <div class="spectral-hero__copy rv">
        <div class="eyebrow">DJ Automata / Spectral Broadcast</div>
        <div class="spectral-hero__stamp">NAROA VOID ACCESS / LIVE AMBIENT GATE</div>
        <h1>Turn the site into a live ambient transmission.</h1>
        <div class="spectral-hero__actions">
          <a class="btn btn--p" href="#spectral-lab">Enter DJ Automata</a>
          <a class="btn btn--g" href={homeHref}>Back to product site</a>
        </div>
      </div>

      <aside class="spectral-hero__rail rv">
        <article>
          <span>Visual field</span>
        </article>
        <article>
          <span>Diffusion pass</span>
        </article>
        <article>
          <span>Live engine</span>
        </article>
      </aside>
    </section>

    <div id="spectral-lab">
      <SpectrogramAudioLab />
    </div>
  </main>

  <style>
    .spectral-page-header {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(225, 255, 171, 0.18);
      background:
        linear-gradient(180deg, rgba(7, 10, 18, 0.94), rgba(5, 12, 9, 0.9)),
        rgba(5, 12, 9, 0.9);
    }

    .spectral-page-header__inner {
      min-height: 74px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
    }

    .spectral-page-header__brand {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      color: var(--text);
      letter-spacing: -0.03em;
    }

    .spectral-page-header__brand span {
      width: 40px;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(197, 255, 111, 0.24), rgba(132, 246, 197, 0.18));
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-family: var(--mono);
      color: #efffbf;
    }

    .spectral-page-header__nav {
      display: flex;
      gap: 18px;
      color: color-mix(in srgb, var(--text) 84%, var(--muted));
      font-size: 0.95rem;
    }

    .spectral-page-header__nav a:hover {
      color: var(--text);
    }

    .spectral-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.8fr);
      gap: 22px;
      padding-top: 42px;
      align-items: start;
    }

    .spectral-hero__copy,
    .spectral-hero__rail {
      border: 1px solid rgba(225, 255, 171, 0.18);
      border-radius: 30px;
      background:
        radial-gradient(circle at top left, rgba(75, 243, 255, 0.09), transparent 18rem),
        radial-gradient(circle at top right, rgba(255, 91, 134, 0.1), transparent 18rem),
        linear-gradient(180deg, rgba(132, 246, 197, 0.05), rgba(255, 255, 255, 0)),
        rgba(8, 16, 12, 0.94);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42),
        0 0 42px rgba(95, 242, 255, 0.08);
      backdrop-filter: blur(16px);
      position: relative;
      overflow: hidden;
    }

    .spectral-hero__copy::before,
    .spectral-hero__rail::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.02) 42%, rgba(255, 255, 255, 0.12) 50%, transparent 58%),
        repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 3px);
      mix-blend-mode: screen;
      opacity: 0.34;
      pointer-events: none;
      animation: spectralSweep 12s linear infinite;
    }

    .spectral-hero__copy {
      padding: 34px;
    }

    .spectral-hero__copy h1 {
      margin-top: 18px;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
      text-transform: uppercase;
      background: linear-gradient(180deg, #ffffff 0%, #d5ff8b 34%, #5ff2ff 68%, #ff89b0 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow:
        0 0 28px rgba(95, 242, 255, 0.12),
        0 0 24px rgba(255, 137, 176, 0.12);
    }

    .spectral-hero__stamp {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 16px;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(95, 242, 255, 0.28);
      background: rgba(5, 12, 10, 0.84);
      color: #eefcff;
      font-family: var(--mono);
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 0 18px rgba(95, 242, 255, 0.1);
    }

    .spectral-hero__copy p {
      max-width: 62ch;
      margin-top: 18px;
      color: var(--muted);
      font-size: 1.05rem;
      display: none;
    }

    .spectral-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .spectral-hero__rail {
      display: grid;
      gap: 14px;
      padding: 22px;
    }

    .spectral-hero__rail article {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid rgba(225, 255, 171, 0.14);
      background: rgba(7, 14, 11, 0.88);
    }

    .spectral-hero__rail span {
      display: block;
      color: #efffbf;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .spectral-hero__rail p {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.94rem;
      display: none;
    }

    @keyframes spectralSweep {
      0% {
        transform: translateX(-100%);
      }

      100% {
        transform: translateX(100%);
      }
    }

    @media (max-width: 920px) {
      .spectral-page-header__inner,
      .spectral-hero {
        grid-template-columns: 1fr;
        flex-direction: column;
      }

      .spectral-page-header__nav {
        flex-wrap: wrap;
      }
    }

    @media (max-width: 720px) {
      .spectral-page-header__inner {
        padding-top: 14px;
        padding-bottom: 14px;
      }

      .spectral-page-header__brand {
        font-size: 0.95rem;
      }

      .spectral-hero__copy,
      .spectral-hero__rail {
        border-radius: 24px;
      }

      .spectral-hero__copy {
        padding: 24px;
      }
    }
  </style>
</Layout>
