---
import '../../styles/saas-landing.css';

const metrics = [
  ['<5ms', 'local retrieval path'],
  ['1,162+', 'test functions tracked'],
  ['55+', 'documented API endpoints'],
  ['90+', 'operator CLI commands'],
];

const workflow = [
  ['01', 'Propose', 'An agent proposes a fact, decision, observation, or runtime state change.'],
  ['02', 'Validate', 'Guards enforce schema, taint, tenant scope, secret redaction, and deterministic admission rules.'],
  ['03', 'Persist', 'Accepted state is written transactionally with ledger continuity and explicit failure semantics.'],
  ['04', 'Verify', 'Teams can inspect, replay, export, and verify the chain when incidents or audits happen.'],
];

const features = [
  ['01', 'Immutable ledger', 'Facts are appended to a SHA-256 hash chain, with verification commands for continuity checks.'],
  ['02', 'Tenant boundaries', 'Public read and write paths are designed around explicit tenant scope to avoid cross-customer memory bleed.'],
  ['03', 'Guarded admission', 'Validation failures stay failures. Unverified generative output does not become durable fact by accident.'],
  ['04', 'Hybrid retrieval', 'Semantic and full-text recall can work together while preserving provenance and verification state.'],
  ['05', 'WBFT consensus', 'Multiple agents can vote on facts with weighted Byzantine fault-tolerant agreement semantics.'],
  ['06', 'Local-first runtime', 'Start with SQLite on your machine. Add cloud, sync, or enterprise deployment only when the risk model allows it.'],
];

const apiCards = [
  ['Memory Core', 'Store, recall, edit, deprecate, and ghost facts', 'Durable facts carry type, project, tenant, timestamps, provenance, and trust metadata.', ['POST /v1/facts', 'cortex store']],
  ['Hybrid Search', 'Semantic + lexical retrieval', 'Use vector search, FTS5, graph-aware recall, temporal filters, and ranked context assembly for agents.', ['POST /v1/search', 'GET /v1/search']],
  ['Trust Ledger', 'Verify hash continuity and checkpoints', 'Ledger verification, Merkle roots, snapshots, and exportable evidence turn memory into an auditable state chain.', ['cortex trust-ledger verify', 'cortex export']],
  ['WBFT Consensus', 'Multi-agent voting and reputation', 'Agents can vote on facts with quorum, weighted reputation, disputed states, and consensus audit trails.', ['cortex vote_v2', 'consensus helpers']],
  ['Projects + Timeline', 'Point-in-time reconstruction', 'Export project memory, navigate temporal state, reconstruct incidents, and produce auditor-friendly context packs.', ['GET /v1/projects/{project}/export', 'cortex timeline']],
  ['Auth + Tenancy', 'RBAC, API keys, tenant scope', 'Roles, permissions, API keys, rate limits, and explicit tenant boundaries protect public read/write surfaces.', ['Authorization: Bearer ctx_...', 'tenant_id scoped reads']],
  ['Daemon + Observability', 'Health, metrics, watchdogs', 'Expose health checks, Prometheus metrics, observatory state, daemon status, and operational signals.', ['GET /health', 'GET /metrics', 'GET /v1/daemon/status']],
  ['Billing + Integrations', 'Stripe, Langbase, MCP, SDKs', 'Use server-side billing routes, async clients, MCP tools, language integrations, and hosted API surfaces where needed.', ['POST /v1/stripe/checkout', 'POST /v1/langbase/search']],
];

const agenticaCards = [
  ['01', 'Agent lifecycle', 'Register agents, monitor liveness, restart supervised tasks, and keep working memory attached to agent identity.', ['POST /v1/agents', 'GET /v1/agents']],
  ['02', 'Swarm orchestration', 'Coordinate parallel agents, isolated worktrees, mission queues, budget controls, and high-risk verification gates.', ['GET /v1/swarm/status', 'POST /v1/missions']],
  ['03', 'Mejoralo engine', 'Scan, record improvement sessions, inspect history, and run ship gates before autonomous changes become release candidates.', ['POST /v1/mejoralo/scan', 'POST /v1/mejoralo/ship-gate']],
  ['04', 'Conflict resolution', 'Use weighted votes, Byzantine consensus, elder-council style escalation, and audit trails for disputed agent decisions.', ['consensus_score', 'vote ledger']],
];

const researchFlow = [
  ['01', 'Discover', 'Knowledge Radar scans curated targets, unresolved ghosts, semantic gaps, and operational signals.'],
  ['02', 'Acquire', 'Scraper-Ω and bounded file/API tools collect source material without mixing raw evidence with verified facts.'],
  ['03', 'Analyze', 'Oracle, Mejoralo, swarm formations, and static-analysis gates produce dense reports and failure signatures.'],
  ['04', 'Crystallize', 'NightShift and ledgered memory convert high-confidence findings into reusable, timestamped knowledge.'],
];

const plans = [
  ['Community', 'For local builders and internal prototypes.', '$0', 'forever', ['Full CLI and Python API', 'Single-tenant local mode', 'Ledger verification', 'Hybrid search', 'Apache 2.0 source'], 'pip install cortex-persist', 'copy'],
  ['Pro', 'For solo operators running serious agents.', '$29', '/month', ['Encrypted multi-device sync', 'Five tenant workspaces', 'Ghost tracking and handoff', 'Priority implementation support', 'Hosted evidence exports'], 'Request Pro access', 'pro'],
  ['Team', 'For engineering teams with audit pressure.', '$99', '/month', ['Unlimited tenant workspaces', 'WBFT consensus workflows', 'Compliance report templates', 'Graph knowledge fusion', 'Team onboarding session'], 'Request Team access', 'team'],
  ['Enterprise', 'For regulated deployments and private infrastructure.', 'Custom', '', ['On-premise architecture review', 'Custom guard and tenant policy', 'Audit evidence pack', 'Security review support', 'Dedicated implementation lane'], 'Talk to founder', 'enterprise'],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CORTEX | Auditable Memory for AI Agents</title>
    <meta name="description" content="CORTEX adds tamper-evident memory, tenant-scoped audit trails, agent orchestration, research intelligence, and EU AI Act logging evidence to autonomous AI systems." />
    <meta property="og:title" content="CORTEX | Auditable Memory for AI Agents" />
    <meta property="og:description" content="Tamper-evident logs, deterministic admission, agéntica, and local-first memory for autonomous AI systems." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cortexpersist.com/saas_landing/" />
    <meta name="theme-color" content="#080a08" />
    <meta name="cortex-api-base" content="" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="background-grid" aria-hidden="true"></div>
    <div class="orb orb-a" aria-hidden="true"></div>
    <div class="orb orb-b" aria-hidden="true"></div>

    <div class="notice">
      <span>EU AI Act Article 12 logging obligations start August 2, 2026.</span>
      <a href="#compliance">Map the evidence gap</a>
    </div>

    <header class="nav" id="nav">
      <a class="brand" href="#hero" aria-label="CORTEX home"><span class="brand-mark">C</span><span>CORTEX</span></a>
      <nav class="nav-links" aria-label="Primary navigation">
        <a href="#compliance">EU AI Act</a>
        <a href="#features">Features</a>
        <a href="#api-surface">API</a>
        <a href="#agentica">Agéntica</a>
        <a href="#research">Research</a>
        <a href="#pricing">Pricing</a>
        <a href="/guides/quickstart/">Docs</a>
      </nav>
      <a class="nav-cta" href="#pricing">Install free</a>
    </header>

    <main>
      <section class="hero" id="hero">
        <div class="hero-copy">
          <div class="eyebrow">Local-first trust substrate for autonomous AI</div>
          <h1>Auditable memory for agents that cannot afford guesswork.</h1>
          <p class="hero-sub">CORTEX records AI decisions as tenant-scoped, tamper-evident facts. It gives engineering, security, and compliance teams a verifiable trail without turning agent memory into another hosted SaaS dependency.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#pricing">Start with the CLI</a>
            <a class="btn btn-secondary" href="/architecture/">Audit the architecture</a>
          </div>
          <div class="hero-proof" aria-label="CORTEX proof points"><span>Apache 2.0</span><span>SQLite local mode</span><span>Hash-chained ledger</span></div>
        </div>
        <aside class="evidence-console" aria-label="CORTEX command line example">
          <div class="console-topbar"><span></span><span></span><span></span><strong>decision-ledger</strong></div>
          <div class="console-body">
            <p><span class="prompt">$</span> cortex store --type decision "Use OAuth2 PKCE for auth"</p>
            <p class="ok">stored fact #42 | tenant=acme | taint=validated</p>
            <p class="hash">sha256:a3f8c2...d91b -> prev:7e2b01...4fc3</p>
            <p><span class="prompt">$</span> cortex trust-ledger verify</p>
            <p class="ok">ledger intact | merkle checkpoint sealed | report ready</p>
          </div>
        </aside>
      </section>

      <section class="metrics" aria-label="CORTEX metrics">
        {metrics.map(([value, label]) => <div class="metric-card"><strong>{value}</strong><span>{label}</span></div>)}
      </section>

      <section class="logo-strip" aria-label="Integrations">
        <p>Designed to sit underneath the tools teams already use</p>
        <div><span>Claude Code</span><span>Cursor</span><span>LangChain</span><span>CrewAI</span><span>AutoGen</span><span>Custom agents</span></div>
      </section>

      <section class="split compliance" id="compliance">
        <div>
          <span class="section-kicker">Regulatory pressure</span>
          <h2>Article 12 needs evidence, not screenshots.</h2>
          <p>High-risk AI systems in the EU need automatic logging, traceability, and integrity controls. CORTEX is not legal advice and does not make a system compliant by itself. It gives your team the technical record needed to prove what an agent knew, decided, and wrote.</p>
          <div class="risk-box"><span>Potential exposure</span><strong>up to EUR 30M or 6% of worldwide annual turnover</strong><small>For qualifying EU AI Act violations, depending on classification and facts.</small></div>
        </div>
        <div class="checklist" aria-label="EU AI Act logging evidence map">
          <article><strong>Automatic logging</strong><p>Every admitted fact receives timestamp, type, tenant scope, provenance, and ledger continuity metadata.</p></article>
          <article><strong>Tamper evidence</strong><p>Hash chains and Merkle checkpoints make record mutation detectable instead of silently accepted.</p></article>
          <article><strong>Decision lineage</strong><p>Facts, votes, guards, and verification state can be traced back to the operation that created them.</p></article>
          <article><strong>Human and agent oversight</strong><p>WBFT voting and disputed-state handling keep single-agent memory writes from becoming unreviewed truth.</p></article>
        </div>
      </section>

      <section id="workflow">
        <div class="section-heading"><span class="section-kicker">Operating model</span><h2>From agent output to evidence chain.</h2><p>CORTEX does not replace your model, framework, or vector store. It adds the deterministic trust boundary between raw output and persisted memory.</p></div>
        <div class="workflow-grid">{workflow.map(([num, title, text]) => <article><span>{num}</span><h3>{title}</h3><p>{text}</p></article>)}</div>
      </section>

      <section id="features">
        <div class="section-heading"><span class="section-kicker">Core capabilities</span><h2>Memory infrastructure with a trust contract.</h2><p>Most memory products optimize recall. CORTEX optimizes whether a recalled fact should be trusted.</p></div>
        <div class="features-grid">{features.map(([num, title, text]) => <article class="feature-card"><div class="feature-icon">{num}</div><h3>{title}</h3><p>{text}</p></article>)}</div>
      </section>

      <section class="api-surface" id="api-surface">
        <div class="section-heading"><span class="section-kicker">Full API surface</span><h2>CORTEX is not just a landing page. It is an operator API.</h2><p>The backend exposes a broad FastAPI, CLI, SDK, MCP, and daemon surface.</p></div>
        <div class="api-stats"><div><strong>55+</strong><span>documented API endpoints</span></div><div><strong>90+</strong><span>operator CLI commands</span></div><div><strong>13</strong><span>daemon monitors</span></div><div><strong>4</strong><span>API, CLI, SDK, MCP</span></div></div>
        <div class="api-grid">
          {apiCards.map(([kicker, title, text, codes]) => <article class="api-card"><span>{kicker}</span><h3>{title}</h3><p>{text}</p>{codes.map((code) => <code>{code}</code>)}</article>)}
        </div>
        <div class="api-note"><strong>Positioning:</strong> The open-source core is the trust engine. Paid tiers package managed API hosting, tenant policy, evidence exports, onboarding, and production support around this full surface.</div>
      </section>

      <section class="agentica-section" id="agentica">
        <div class="section-heading"><span class="section-kicker">Agéntica layer</span><h2>A control plane for societies of agents.</h2><p>CORTEX includes an agéntica stack: registered agents, heartbeat supervision, swarm missions, consensus resolution, handoff state, and self-improvement loops.</p></div>
        <div class="agentica-hero">
          <div class="agentica-map" aria-label="Agéntica control plane map"><div class="agent-node prime">Supervisor</div><div class="agent-ring"><span>MemoryAgent</span><span>SecurityAgent</span><span>VerificationAgent</span><span>HandoffAgent</span><span>NightshiftAgent</span><span>OmegaPrime</span></div></div>
          <div class="agentica-copy"><h3>From single-agent memory to coordinated agency.</h3><p>Agents can register, emit heartbeats, receive messages, persist working memory, vote on facts, and escalate conflicts. Swarms can run isolated worktrees, budget execution, verify risky changes, and record mission results back into the ledger.</p><div class="agentica-pills"><span>Agent registry</span><span>Message bus</span><span>Heartbeat supervision</span><span>Swarm missions</span><span>WBFT arbitration</span><span>Handoff state</span></div></div>
        </div>
        <div class="agentica-grid">{agenticaCards.map(([num, title, text, codes]) => <article><span>{num}</span><h3>{title}</h3><p>{text}</p>{codes.map((code) => <code>{code}</code>)}</article>)}</div>
      </section>

      <section class="research-section" id="research">
        <div class="section-heading"><span class="section-kicker">Investigación intelligence</span><h2>Deep research that becomes durable knowledge.</h2><p>CORTEX can run research as an evidence pipeline: discover gaps, extract sources, generate audits, synthesize findings, and persist only traceable claims.</p></div>
        <div class="research-flow">{researchFlow.map(([num, title, text]) => <article><span>{num}</span><h3>{title}</h3><p>{text}</p></article>)}</div>
        <div class="research-grid">
          <article class="research-card wide"><span>Deep Research</span><h3>Competitive analysis, architecture audits, security research, and scientific synthesis.</h3><p>The product should sell the intelligence workflow, not hide it in docs.</p><div class="research-tags"><em>Competitive analysis</em><em>Architecture review</em><em>Security audit</em><em>Source synthesis</em></div></article>
          <article class="research-card"><span>Oracle audits</span><h3>Fast B2B audit reports</h3><p>Run targeted audits against companies, repos, APIs, or architecture surfaces and store the report back into CORTEX.</p><code>POST /v1/oracle/audit</code></article>
          <article class="research-card"><span>Observatory</span><h3>One endpoint, full picture</h3><p>Aggregate system status, daemon data, trust posture, and evolution/swarm signals into a single operator view.</p><code>GET /v1/observatory</code></article>
          <article class="research-card"><span>Knowledge Radar</span><h3>Find what the system does not know</h3><p>Detect unresolved ghosts, semantic gaps, and queued targets so the system can prioritize research automatically.</p><code>knowledge_gap</code></article>
          <article class="research-card"><span>NightShift</span><h3>Autonomous knowledge generation</h3><p>Background cycles discover targets, build plans, forge knowledge crystals, and persist cycle reports.</p><code>nightshift_cycle</code></article>
        </div>
      </section>

      <section id="pricing">
        <div class="section-heading"><span class="section-kicker">Pricing</span><h2>Start locally. Add managed help when needed.</h2><p>The open-source core is free. Paid tiers are for teams that want hosted sync, implementation support, or managed compliance evidence.</p></div>
        <div class="pricing-grid">
          {plans.map(([name, desc, price, suffix, items, cta, action], index) => <article class:list={['plan', index === 1 && 'highlighted', action === 'enterprise' && 'enterprise']}>
            {index === 1 && <div class="plan-badge">Early access</div>}
            <div class="plan-head"><h3>{name}</h3><p>{desc}</p></div>
            <div class="price">{price} <span>{suffix}</span></div>
            <ul>{items.map((item) => <li>{item}</li>)}</ul>
            {action === 'copy' && <button class="btn btn-secondary copy-install" type="button" data-copy="pip install cortex-persist">{cta}</button>}
            {action === 'pro' && <button class="btn btn-primary open-checkout" type="button" data-plan="pro">{cta}</button>}
            {action === 'team' && <button class="btn btn-secondary open-checkout" type="button" data-plan="team">{cta}</button>}
            {action === 'enterprise' && <a class="btn btn-secondary" href="mailto:borja@cortexpersist.com?subject=CORTEX%20Enterprise%20deployment">{cta}</a>}
          </article>)}
        </div>
      </section>

      <section class="deployment-section" id="deployment">
        <div class="section-heading"><span class="section-kicker">Vercel API + Cloudflare edge</span><h2>Serve the landing at the edge. Keep billing behind the API.</h2><p>The static page can live on Cloudflare Pages while `/v1/*` is proxied to the Vercel FastAPI entrypoint.</p></div>
        <div class="deployment-grid"><article><span>01</span><h3>Cloudflare Pages</h3><p>Serves the Astro build, security headers, and the edge proxy worker.</p></article><article><span>02</span><h3>Vercel FastAPI</h3><p>Exposes `api/index.py`, mounts `/v1/stripe/checkout`, and talks to Stripe with server-only variables.</p></article><article><span>03</span><h3>Stripe Checkout</h3><p>Hosted checkout collects payment details directly. The landing only sends plan and email.</p></article></div>
      </section>

      <section class="final-cta" id="start"><span class="section-kicker">Thirty seconds to first proof</span><h2>Do not let agent memory become unverifiable production state.</h2><p>Install locally, store one decision, and verify the ledger before you trust the next agent handoff.</p><div class="hero-actions"><a class="btn btn-primary" href="#pricing">Install CORTEX</a><a class="btn btn-secondary" href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noopener noreferrer">View source on GitHub</a></div></section>
    </main>

    <footer class="footer"><div><a class="brand" href="#hero" aria-label="CORTEX home"><span class="brand-mark">C</span><span>CORTEX</span></a><p>Trust infrastructure for autonomous AI. Apache 2.0 core.</p></div><nav aria-label="Footer navigation"><a href="/guides/quickstart/">Docs</a><a href="/reference/">Reference</a><a href="/security/">Security</a><a href="https://borjamoskv.com" target="_blank" rel="noopener noreferrer">borjamoskv.com</a></nav></footer>

    <div class="modal" id="checkout-modal" aria-hidden="true"><div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="checkout-title"><button class="modal-close" type="button" id="checkout-close" aria-label="Close checkout">x</button><span class="section-kicker">Secure checkout</span><h2 id="checkout-title">Request access</h2><p id="checkout-copy">Card details are handled by Stripe checkout. CORTEX does not collect raw card data on this page.</p><form id="checkout-form"><input type="hidden" name="plan" id="checkout-plan" value="pro" /><label for="checkout-email">Work email</label><input id="checkout-email" name="email" type="email" inputmode="email" autocomplete="email" placeholder="you@company.com" required /><button class="btn btn-primary" id="checkout-submit" type="submit">Continue</button></form><p class="modal-footnote">If hosted checkout is not active yet, the button opens a pre-filled founder request instead.</p></div></div>

    <script is:inline>
      (() => {
        const nav = document.getElementById('nav');
        const modal = document.getElementById('checkout-modal');
        const close = document.getElementById('checkout-close');
        const form = document.getElementById('checkout-form');
        const planInput = document.getElementById('checkout-plan');
        const title = document.getElementById('checkout-title');
        const copy = document.getElementById('checkout-copy');
        const submit = document.getElementById('checkout-submit');
        const email = document.getElementById('checkout-email');
        const apiBaseMeta = document.querySelector('meta[name="cortex-api-base"]');
        const planCopy = {
          pro: { title: 'Request Pro early access', copy: 'Pro adds encrypted sync, five tenant workspaces, and priority implementation support. Stripe handles payment details if hosted checkout is enabled.' },
          team: { title: 'Request a Team pilot', copy: 'Team adds unlimited tenant workspaces, consensus workflows, and compliance report templates. Stripe handles payment details if hosted checkout is enabled.' }
        };
        const openModal = (plan) => { const selected = planCopy[plan] || planCopy.pro; planInput.value = plan; title.textContent = selected.title; copy.textContent = selected.copy; modal.classList.add('active'); modal.setAttribute('aria-hidden', 'false'); setTimeout(() => email.focus(), 50); };
        const closeModal = () => { modal.classList.remove('active'); modal.setAttribute('aria-hidden', 'true'); submit.disabled = false; submit.textContent = 'Continue'; };
        const resolvePublicOrigin = () => globalThis.location.protocol === 'file:' ? 'https://cortexpersist.com' : globalThis.location.origin;
        const resolveApiBase = () => globalThis.CORTEX_API_BASE_URL || apiBaseMeta?.content || resolvePublicOrigin();
        const checkoutEndpoint = () => new URL('/v1/stripe/checkout', resolveApiBase()).toString();
        const copyInstall = async (button) => { const value = button.dataset.copy || 'pip install cortex-persist'; try { await navigator.clipboard.writeText(value); } catch (_) { const textarea = document.createElement('textarea'); textarea.value = value; textarea.setAttribute('readonly', ''); textarea.style.position = 'absolute'; textarea.style.left = '-9999px'; document.body.appendChild(textarea); textarea.select(); document.execCommand('copy'); textarea.remove(); } button.textContent = 'Copied: ' + value; setTimeout(() => { button.textContent = value; }, 1800); };
        document.querySelectorAll('.open-checkout').forEach((button) => button.addEventListener('click', () => openModal(button.dataset.plan)));
        document.querySelectorAll('.copy-install').forEach((button) => button.addEventListener('click', () => copyInstall(button)));
        close.addEventListener('click', closeModal);
        modal.addEventListener('click', (event) => { if (event.target === modal) closeModal(); });
        document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && modal.classList.contains('active')) closeModal(); });
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (!email.checkValidity()) { email.reportValidity(); return; }
          submit.disabled = true;
          submit.textContent = 'Opening secure checkout...';
          const plan = planInput.value;
          const publicOrigin = resolvePublicOrigin();
          const payload = { plan, customer_email: email.value, success_url: publicOrigin + '/success/', cancel_url: publicOrigin + '/cancel/', ui_mode: 'hosted' };
          try {
            const response = await fetch(checkoutEndpoint(), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (!response.ok) throw new Error('checkout unavailable');
            const data = await response.json();
            if (data.url) { globalThis.location.href = data.url; return; }
            throw new Error('checkout URL missing');
          } catch (_) {
            const subject = encodeURIComponent('CORTEX ' + plan.toUpperCase() + ' access request');
            const body = encodeURIComponent('Plan: ' + plan + '\nEmail: ' + email.value + '\n\nI want access to CORTEX ' + plan + '.');
            globalThis.location.href = 'mailto:borja@cortexpersist.com?subject=' + subject + '&body=' + body;
            closeModal();
          }
        });
        const onScroll = () => nav.classList.toggle('scrolled', globalThis.scrollY > 16);
        onScroll();
        globalThis.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
  </body>
</html>
