---
import SiteLayout from '../layouts/SiteLayout.astro';

const defaultArtworks = [
	{
		id: 'amy-rocks',
		title: 'Amy Rocks',
		series: 'Rocks',
		year: '2023',
		medium: 'Acrílico y mica mineral sobre pizarra natural',
		commons: 'Naroa_Gutierrez_Gil_-_Amy_Rocks_(2023).webp',
		svgType: 'slate-amy'
	},
	{
		id: 'marilyn-rocks',
		title: 'Marilyn Rocks (I)',
		series: 'Rocks',
		year: '2023',
		medium: 'Acrílico y mica mineral sobre pizarra natural',
		commons: 'Naroa_Gutierrez_Gil_-_Marilyn_Rocks_(I)_(2023).webp',
		svgType: 'slate-marilyn'
	},
	{
		id: 'mr-fahrenheit',
		title: 'Mr. Fahrenheit',
		series: 'Tributos',
		year: '2021',
		medium: 'Técnica mixta y tinta sobre madera',
		commons: 'Naroa_Gutierrez_Gil_-_Mr._Fahrenheit_(2021).webp',
		svgType: 'portrait-freddie'
	},
	{
		id: 'espejos-del-alma',
		title: 'Espejos del Alma',
		series: 'Espejos',
		year: '2023',
		medium: 'Acrílico y collage sobre lienzo',
		commons: 'Naroa_Gutierrez_Gil_-_Espejos_del_Alma_(2023).webp',
		svgType: 'mirror'
	},
	{
		id: 'amor-en-conserva',
		title: 'Amor en Conserva',
		series: 'Enlatas',
		year: '2022',
		medium: 'Acrílico y técnica mixta sobre lienzo',
		commons: 'Naroa_Gutierrez_Gil_-_Amor_en_Conserva_(2022).webp',
		svgType: 'can'
	},
	{
		id: 'lagrimas-de-oro',
		title: 'Lágrimas de Oro',
		series: 'Golden',
		year: '2021',
		medium: 'Acrílico y pan de oro sobre madera',
		commons: 'Naroa_Gutierrez_Gil_-_Lagrimas_de_Oro_(2021).webp',
		svgType: 'gold-tears'
	},
	{
		id: 'peter-rowan',
		title: 'Peter Rowan',
		series: 'Retratos',
		year: '2023',
		medium: 'Carboncillo y acrílico sobre papel',
		commons: 'Naroa_Gutierrez_Gil_-_Peter_Rowan_(2023).webp',
		svgType: 'portrait-peter'
	}
];
---

<SiteLayout
	title="Twin Dashboard | Naroa Gutiérrez Gil"
	description="Panel exclusivo para Naroa Gutiérrez Gil. Gestión, personalización y previsualización de catálogo."
	lang="es"
>
	<main class="dashboard-shell">
		<!-- Authentication Guard Overlay -->
		<div id="auth-overlay" class="auth-overlay">
			<div class="auth-card surface">
				<div class="auth-header">
					<span class="auth-logo">N</span>
					<h2>CORTEX Private Node Auth</h2>
					<p class="auth-meta">Ingrese su clave para sincronizar el espacio gemelo.</p>
				</div>
				<div class="auth-form">
					<input type="password" id="cortex-key" class="auth-input" placeholder="Clave privada de Naroa" autocomplete="current-password" />
					<button id="auth-submit-btn" class="button-primary w-full">Desbloquear Nodo</button>
					<p id="auth-error-msg" class="auth-error" aria-live="polite"></p>
				</div>
			</div>
		</div>

		<!-- Dashboard Shell Grid -->
		<div id="dashboard-content" class="dashboard-container" style="display: none;">
			<!-- Header -->
			<header class="db-header surface">
				<div class="header-left">
					<span class="pulse-node"></span>
					<div>
						<h1>Naroa Gutiérrez Gil</h1>
						<p class="db-meta">// MODO ESPACIO GEMELO ACTIVO</p>
					</div>
				</div>
				<div class="header-actions">
					<button id="btn-export-code" class="button-secondary compact font-mono">Exportar PR</button>
					<button id="btn-reset-catalog" class="button-tertiary compact font-mono">Reajustar</button>
					<a href="/naroagutierrez" class="button-primary compact font-mono">Ver Ficha Pública</a>
				</div>
			</header>

			<div class="db-main">
				<!-- Sidebar / List of artworks -->
				<aside class="db-sidebar surface">
					<div class="sidebar-head">
						<h3>Catálogo de Obras</h3>
						<button id="btn-add-artwork" class="button-primary compact font-mono">+ Añadir</button>
					</div>
					<div id="artworks-list-container" class="artworks-list">
						<!-- Dynamically populated rows -->
					</div>
				</aside>

				<!-- Main Editor Canvas -->
				<section class="db-canvas surface">
					<div id="no-selection-msg" class="empty-state">
						<svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
							<circle cx="9" cy="9" r="2"/>
							<path d="M21 15l-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
						</svg>
						<p>Seleccione una obra para editar su ficha o cree una nueva.</p>
					</div>

					<div id="editor-form-container" class="editor-layout" style="display: none;">
						<!-- Editor form -->
						<div class="editor-fields">
							<div class="field-group">
								<label for="edit-title">Título de la Obra</label>
								<input type="text" id="edit-title" class="form-input" />
							</div>

							<div class="field-row">
								<div class="field-group">
									<label for="edit-series">Serie / Colección</label>
									<input type="text" id="edit-series" class="form-input" />
								</div>
								<div class="field-group">
									<label for="edit-year">Año de Creación</label>
									<input type="text" id="edit-year" class="form-input" />
								</div>
							</div>

							<div class="field-group">
								<label for="edit-medium">Técnica y Soporte</label>
								<input type="text" id="edit-medium" class="form-input" />
							</div>

							<div class="field-group">
								<label for="edit-commons">Wikimedia Commons (Fichero)</label>
								<input type="text" id="edit-commons" class="form-input" placeholder="Nombre_del_fichero.webp" />
							</div>

							<div class="field-group">
								<label for="edit-svg-type">Fórmula Representacional (SVG)</label>
								<select id="edit-svg-type" class="form-input">
									<option value="slate-amy">Pizarra - Amy Rocks</option>
									<option value="slate-marilyn">Pizarra - Marilyn Rocks</option>
									<option value="portrait-freddie">Tributo - Freddie</option>
									<option value="mirror">Espejo - Espejos del Alma</option>
									<option value="can">Enlata - Amor en Conserva</option>
									<option value="gold-tears">Lágrima - Lágrimas de Oro</option>
									<option value="portrait-peter">Carboncillo - Peter Rowan</option>
								</select>
							</div>

							<div class="editor-actions">
								<button id="btn-save-artwork" class="button-primary">Guardar Obra</button>
								<button id="btn-delete-artwork" class="button-danger">Borrar Obra</button>
							</div>
						</div>

						<!-- Editor live preview -->
						<div class="editor-preview">
							<div class="preview-card-wrapper">
								<h4 class="preview-label">// PREVISUALIZACIÓN EN TIEMPO REAL</h4>
								<article class="artwork-card-premium preview-card surface-sunken">
									<div id="preview-svg-container" class="artwork-preview">
										<!-- Dynamic SVG -->
									</div>
									<div class="artwork-info">
										<div class="info-header">
											<span id="preview-series" class="artwork-tag-series">ROCKS</span>
											<span id="preview-year" class="artwork-tag-year">2023</span>
										</div>
										<h3 id="preview-title">Amy Rocks</h3>
										<p id="preview-medium" class="artwork-medium">Acrílico y mica mineral sobre pizarra natural</p>
										<div class="artwork-actions">
											<span id="preview-id" class="commons-tag">Commons: amy-rocks</span>
											<span class="button-tertiary compact">Wiki Asset</span>
										</div>
									</div>
								</article>
							</div>
						</div>
					</div>
				</section>
			</div>
		</div>

		<!-- Export PR Modal -->
		<div id="modal-export" class="modal-overlay" style="display: none;">
			<div class="modal-card surface">
				<div class="modal-header">
					<h3>Código para Persistencia Git (PR)</h3>
					<button id="btn-close-modal" class="modal-close">&times;</button>
				</div>
				<p class="modal-desc">
					Copie este array JSON de configuración y envíelo a Borja o insértelo directamente en el repositorio en <code>src/pages/naroagutierrez.astro</code> para actualizar de forma permanente la web pública.
				</p>
				<textarea id="export-textarea" readonly class="modal-textarea"></textarea>
				<div class="modal-actions">
					<button id="btn-copy-code" class="button-primary">Copiar al Portapapeles</button>
					<button id="btn-dismiss-modal" class="button-secondary">Cerrar</button>
				</div>
			</div>
		</div>
	</main>
</SiteLayout>

<script define:vars={{ defaultArtworks }}>
	// ╔══════════════════════════════════════════╗
	// ║           CLIENT-SIDE CONTROLLER         ║
	// ╚══════════════════════════════════════════/
	(function() {
		// Custom local storage key
		const KEY_ARTWORKS = 'naroa_artworks_custom';
		const KEY_SESSION = 'naroa_session_active';

		// App state
		let artworks = [];
		let selectedId = null;

		// SVGs Mapping
		const SVG_TEMPLATES = {
			'slate-amy': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<path d="M 50 80 L 350 50 L 370 240 L 30 260 Z" fill="#1b1c22" stroke="#2b3be5" stroke-width="1.5" opacity="0.85"/>
					<path d="M 60 90 L 340 60 L 350 230 L 45 245 Z" fill="#14151a" stroke="#00ff41" stroke-width="1" opacity="0.7"/>
					<circle cx="150" cy="140" r="45" fill="none" stroke="#2b3be5" stroke-dasharray="4 6" stroke-width="2"/>
					<circle cx="250" cy="160" r="35" fill="none" stroke="#00ff41" stroke-dasharray="3 3" stroke-width="1.5"/>
					<path d="M 120 150 Q 200 100 280 170" fill="none" stroke="#cc0000" stroke-width="3" stroke-linecap="round"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">SLATE SUBSTRATE // MICA OVERLAY</text>
				</svg>
			`,
			'slate-marilyn': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<path d="M 60 60 L 340 70 L 320 250 L 80 230 Z" fill="#1e1f26" stroke="#2b3be5" stroke-width="1.5" opacity="0.85"/>
					<path d="M 70 70 L 330 80 L 310 240 L 90 220 Z" fill="#121318" stroke="#00ff41" stroke-width="1" opacity="0.6"/>
					<rect x="140" y="110" width="120" height="80" fill="none" stroke="#2b3be5" stroke-width="1" stroke-dasharray="5 5"/>
					<path d="M 170 180 Q 200 130 230 180" fill="none" stroke="#cc0000" stroke-width="2.5"/>
					<circle cx="200" cy="140" r="25" fill="none" stroke="#00ff41" stroke-width="1.5"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">PIZARRA // DUO-TONE TEXTURE</text>
				</svg>
			`,
			'portrait-freddie': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<path d="M 100 50 L 300 50 L 300 250 L 100 250 Z" fill="#14141c" stroke="#2b3be5" stroke-width="1"/>
					<circle cx="200" cy="110" r="50" fill="none" stroke="#00ff41" stroke-width="2"/>
					<path d="M 170 170 H 230" stroke="#cc0000" stroke-width="4"/>
					<path d="M 200 110 L 200 200" stroke="#2b3be5" stroke-dasharray="2 4" stroke-width="1"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">WOOD PANEL // DYNAMIC TRIBUTE</text>
				</svg>
			`,
			'mirror': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<ellipse cx="200" cy="150" rx="90" ry="70" fill="#101322" stroke="#2b3be5" stroke-width="2"/>
					<ellipse cx="200" cy="150" rx="80" ry="60" fill="none" stroke="#00ff41" stroke-dasharray="10 4 2 4" stroke-width="1"/>
					<path d="M 130 150 Q 200 220 270 150" fill="none" stroke="#cc0000" stroke-width="3" stroke-linecap="round"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">CANVAS // REFLECTION ENGINE</text>
				</svg>
			`,
			'can': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<rect x="130" y="70" width="140" height="160" rx="15" fill="#161822" stroke="#2b3be5" stroke-width="2"/>
					<ellipse cx="200" cy="70" rx="70" ry="12" fill="#202436" stroke="#00ff41" stroke-width="1"/>
					<path d="M 150 140 H 250" stroke="#cc0000" stroke-width="2.5"/>
					<path d="M 150 160 H 250" stroke="#00ff41" stroke-width="1.5" stroke-dasharray="3 3"/>
					<text x="145" y="125" fill="#edf5ff" font-family="'Orbitron', sans-serif" font-size="12" letter-spacing="1">AMOR</text>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">ENLATAS SERIES // POP METAPHOR</text>
				</svg>
			`,
			'gold-tears': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<polygon points="200,60 270,230 130,230" fill="#1c1810" stroke="#d8b56a" stroke-width="2"/>
					<path d="M 200 60 V 230" stroke="#00ff41" stroke-width="1" stroke-dasharray="5 5"/>
					<circle cx="200" cy="130" r="10" fill="#cc0000"/>
					<path d="M 200 130 Q 180 180 185 220" fill="none" stroke="#d8b56a" stroke-width="3" stroke-linecap="round"/>
					<path d="M 200 130 Q 220 190 215 220" fill="none" stroke="#d8b56a" stroke-width="3" stroke-linecap="round"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">GOLDEN SERIES // METALLIC ACCENT</text>
				</svg>
			`,
			'portrait-peter': (title) => `
				<svg viewBox="0 0 400 300" class="art-svg" aria-label="Abstract representation of ${title}">
					<rect width="100%" height="100%" fill="#080808"/>
					<path d="M 120 70 Q 200 30 280 70 T 320 220 Q 200 270 80 220 Z" fill="#13141a" stroke="#2b3be5" stroke-width="1" opacity="0.8"/>
					<path d="M 160 140 C 160 110, 240 110, 240 140" fill="none" stroke="#00ff41" stroke-width="2"/>
					<circle cx="200" cy="150" r="6" fill="#cc0000"/>
					<path d="M 150 180 C 180 210, 220 210, 250 180" fill="none" stroke="#edf5ff" stroke-width="1.5" stroke-dasharray="2 2"/>
					<text x="20" y="285" fill="#a6b3d2" font-family="monospace" font-size="10">RETRATOS // HIGHCONTRAST CHARCOAL</text>
				</svg>
			`
		};

		// Helper to render SVG blueprint
		function getSvgMarkup(type, title) {
			const renderer = SVG_TEMPLATES[type] || SVG_TEMPLATES['slate-amy'];
			return renderer(title);
		}

		// Initialize session & dashboard state
		function init() {
			if (localStorage.getItem(KEY_SESSION) === 'true') {
				showDashboard();
			} else {
				showAuth();
			}
		}

		function showAuth() {
			document.getElementById('auth-overlay').style.display = 'flex';
			document.getElementById('dashboard-content').style.display = 'none';
			document.getElementById('cortex-key').focus();
		}

		function showDashboard() {
			document.getElementById('auth-overlay').style.display = 'none';
			document.getElementById('dashboard-content').style.display = 'flex';

			// Load artworks from localStorage or initialize with defaults
			const stored = localStorage.getItem(KEY_ARTWORKS);
			if (stored) {
				try {
					artworks = JSON.parse(stored);
				} catch (e) {
					artworks = [...defaultArtworks];
				}
			} else {
				artworks = [...defaultArtworks];
				saveToStorage();
			}

			renderArtworksList();
		}

		function saveToStorage() {
			localStorage.setItem(KEY_ARTWORKS, JSON.stringify(artworks));
		}

		// Rendering Sidebar
		function renderArtworksList() {
			const container = document.getElementById('artworks-list-container');
			if (!container) return;

			container.innerHTML = '';
			artworks.forEach((work) => {
				const item = document.createElement('div');
				item.className = `list-item ${selectedId === work.id ? 'active' : ''}`;
				item.dataset.id = work.id;
				item.innerHTML = `
					<div class="item-meta">
						<span class="item-series">${work.series}</span>
						<span class="item-year">${work.year}</span>
					</div>
					<h4 class="item-title">${work.title}</h4>
				`;
				item.addEventListener('click', () => selectArtwork(work.id));
				container.appendChild(item);
			});
		}

		// Select & Edit Artwork
		function selectArtwork(id) {
			selectedId = id;
			renderArtworksList();

			const work = artworks.find(w => w.id === id);
			if (!work) return;

			document.getElementById('no-selection-msg').style.display = 'none';
			document.getElementById('editor-form-container').style.display = 'grid';

			// Populate inputs
			document.getElementById('edit-title').value = work.title;
			document.getElementById('edit-series').value = work.series;
			document.getElementById('edit-year').value = work.year;
			document.getElementById('edit-medium').value = work.medium;
			document.getElementById('edit-commons').value = work.commons;
			document.getElementById('edit-svg-type').value = work.svgType;

			updateLivePreview();
		}

		// Update Preview
		function updateLivePreview() {
			const title = document.getElementById('edit-title').value;
			const series = document.getElementById('edit-series').value;
			const year = document.getElementById('edit-year').value;
			const medium = document.getElementById('edit-medium').value;
			const commons = document.getElementById('edit-commons').value;
			const svgType = document.getElementById('edit-svg-type').value;

			document.getElementById('preview-title').textContent = title || 'Untitled';
			document.getElementById('preview-series').textContent = series.toUpperCase() || 'SERIES';
			document.getElementById('preview-year').textContent = year || 'YYYY';
			document.getElementById('preview-medium').textContent = medium || 'Medium details';
			document.getElementById('preview-id').textContent = `Commons: ${commons || 'unknown'}`;
			document.getElementById('preview-svg-container').innerHTML = getSvgMarkup(svgType, title);
		}

		// Save handler
		function saveSelectedArtwork() {
			if (!selectedId) return;
			const idx = artworks.findIndex(w => w.id === selectedId);
			if (idx === -1) return;

			artworks[idx] = {
				id: selectedId,
				title: document.getElementById('edit-title').value,
				series: document.getElementById('edit-series').value,
				year: document.getElementById('edit-year').value,
				medium: document.getElementById('edit-medium').value,
				commons: document.getElementById('edit-commons').value,
				svgType: document.getElementById('edit-svg-type').value
			};

			saveToStorage();
			renderArtworksList();
			
			// Show short feedback toast/color pulse on button
			const saveBtn = document.getElementById('btn-save-artwork');
			const originalText = saveBtn.textContent;
			saveBtn.textContent = '¡Guardado!';
			saveBtn.style.borderColor = '#00ff41';
			saveBtn.style.color = '#00ff41';
			setTimeout(() => {
				saveBtn.textContent = originalText;
				saveBtn.style.borderColor = '';
				saveBtn.style.color = '';
			}, 1500);
		}

		// Add Artwork
		function addNewArtwork() {
			const newId = 'obra-' + Date.now();
			const newWork = {
				id: newId,
				title: 'Nueva Obra',
				series: 'General',
				year: new Date().getFullYear().toString(),
				medium: 'Técnica mixta',
				commons: 'fichero.webp',
				svgType: 'slate-amy'
			};

			artworks.push(newWork);
			saveToStorage();
			selectArtwork(newId);
		}

		// Delete Artwork
		function deleteSelectedArtwork() {
			if (!selectedId) return;
			if (!confirm('¿Está seguro de que desea eliminar esta obra de su catálogo gemelo local?')) return;

			artworks = artworks.filter(w => w.id !== selectedId);
			saveToStorage();
			selectedId = null;

			document.getElementById('editor-form-container').style.display = 'none';
			document.getElementById('no-selection-msg').style.display = 'flex';
			renderArtworksList();
		}

		// Set up event listeners
		document.getElementById('auth-submit-btn').addEventListener('click', handleAuth);
		document.getElementById('cortex-key').addEventListener('keypress', (e) => {
			if (e.key === 'Enter') handleAuth();
		});

		function handleAuth() {
			const key = document.getElementById('cortex-key').value.trim();
			if (key === 'naro' || key === 'naroa2026') {
				localStorage.setItem(KEY_SESSION, 'true');
				showDashboard();
			} else {
				const errorMsg = document.getElementById('auth-error-msg');
				errorMsg.textContent = 'Clave incorrecta. Acceso al nodo denegado.';
				setTimeout(() => { errorMsg.textContent = ''; }, 3000);
			}
		}

		// Form listeners for live update
		const formInputs = ['edit-title', 'edit-series', 'edit-year', 'edit-medium', 'edit-commons', 'edit-svg-type'];
		formInputs.forEach(id => {
			document.getElementById(id).addEventListener('input', updateLivePreview);
		});

		document.getElementById('btn-save-artwork').addEventListener('click', saveSelectedArtwork);
		document.getElementById('btn-add-artwork').addEventListener('click', addNewArtwork);
		document.getElementById('btn-delete-artwork').addEventListener('click', deleteSelectedArtwork);

		// Global Buttons
		document.getElementById('btn-reset-catalog').addEventListener('click', () => {
			if (confirm('¿Restaurar todo el catálogo a los datos originales integrados de la web? Se perderán sus ediciones locales.')) {
				localStorage.removeItem(KEY_ARTWORKS);
				showDashboard();
				selectedId = null;
				document.getElementById('editor-form-container').style.display = 'none';
				document.getElementById('no-selection-msg').style.display = 'flex';
			}
		});

		// Export PR Modal logic
		document.getElementById('btn-export-code').addEventListener('click', () => {
			const code = 'const artworks = ' + JSON.stringify(artworks, null, '\t') + ';';
			document.getElementById('export-textarea').value = code;
			document.getElementById('modal-export').style.display = 'flex';
		});

		const closeModal = () => {
			document.getElementById('modal-export').style.display = 'none';
		};

		document.getElementById('btn-close-modal').addEventListener('click', closeModal);
		document.getElementById('btn-dismiss-modal').addEventListener('click', closeModal);

		document.getElementById('btn-copy-code').addEventListener('click', () => {
			const textarea = document.getElementById('export-textarea');
			textarea.select();
			document.execCommand('copy');
			const copyBtn = document.getElementById('btn-copy-code');
			copyBtn.textContent = '¡Copiado!';
			setTimeout(() => { copyBtn.textContent = 'Copiar al Portapapeles'; }, 1500);
		});

		// Start on load
		init();
	})();
</script>

