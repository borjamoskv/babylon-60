---
import { existsSync } from 'node:fs';
import { readFile } from 'node:fs/promises';

import RevideoKnowledgeConsole from '../components/RevideoKnowledgeConsole.astro';
import { buildBucketStats, normalizePageCatalog } from '../lib/revideoKnowledge.js';
import Layout from '../layouts/Layout.astro';

const marketingOrigin = import.meta.env.PUBLIC_MARKETING_ORIGIN || '';
const homeHref = marketingOrigin || '/';
const artifactRoot = new URL('../../tmp/revideo_ingest_20260407_resume_v3/', import.meta.url);
const manifestUrl = new URL('ingest_manifest.json', artifactRoot);
const pageCatalogUrl = new URL('page_catalog.json', artifactRoot);
const scrapeResultsUrl = new URL('scrape_results.json', artifactRoot);

async function readJson(url) {
  if (!existsSync(url)) {
    return null;
  }

  return JSON.parse(await readFile(url, 'utf-8'));
}

const manifest = await readJson(manifestUrl);
const pageCatalog = await readJson(pageCatalogUrl);
const scrapeResults = await readJson(scrapeResultsUrl);
const pages = pageCatalog ? normalizePageCatalog(pageCatalog, scrapeResults || []) : [];
const bucketStats = buildBucketStats(pages);
---

<Layout
  title="Revideo Atlas — Local Cognitive Surface by CORTEX"
  description="A local searchable route over the ingested Revideo documentation corpus, chunked, bucketed, and indexed inside CORTEX."
>
  <header class="revideo-page-header">
    <div class="revideo-page-header__inner w">
      <a class="revideo-page-header__brand" href={homeHref}>
        <span>RV</span>
        <strong>Revideo Atlas</strong>
      </a>
      <nav class="revideo-page-header__nav" aria-label="Revideo atlas navigation">
        <a href={homeHref}>Home</a>
        <a href="#atlas">Atlas</a>
        <a href="/spectral-audio">DJ Automata</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="revideo-hero w">
      <div class="revideo-hero__copy rv">
        <div class="eyebrow">Revideo / Cognitive Ingest</div>
        <div class="revideo-hero__stamp">LOCAL CORPUS / STATIC SEARCH / VECTOR MEMORY</div>
        <h1>Turn the Revideo docs into a navigable local atlas.</h1>
        <p>
          The corpus has already been ingested offline. This route gives the app a usable front-end for that memory:
          bucket stats, longest surfaces, and fast page-level search without leaving the site.
        </p>
        <div class="revideo-hero__actions">
          <a class="btn btn--p" href="#atlas">Open atlas</a>
          <a class="btn btn--g" href="https://docs.re.video/" target="_blank" rel="noreferrer">Source docs</a>
        </div>
      </div>

      <aside class="revideo-hero__rail rv">
        <article>
          <span>Ingest</span>
          <strong>{manifest?.total_urls ?? pages.length}</strong>
          <p>Pages captured into the isolated Revideo memory surface.</p>
        </article>
        <article>
          <span>Bundles</span>
          <strong>{manifest?.bundle_count ?? 0}</strong>
          <p>Chunked artifacts ready for recall and navigation.</p>
        </article>
        <article>
          <span>Route</span>
          <strong>App-native</strong>
          <p>Search and inspect the corpus directly from the marketing surface.</p>
        </article>
      </aside>
    </section>

    <section id="atlas" class="revideo-atlas w">
      <RevideoKnowledgeConsole manifest={manifest} pages={pages} bucketStats={bucketStats} />
    </section>
  </main>

  <style>
    .revideo-page-header {
      position: sticky;
      top: 0;
      z-index: 20;
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(136, 231, 255, 0.18);
      background:
        linear-gradient(180deg, rgba(9, 12, 19, 0.94), rgba(8, 10, 14, 0.9)),
        rgba(8, 10, 14, 0.9);
    }

    .revideo-page-header__inner {
      min-height: 74px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
    }

    .revideo-page-header__brand {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      color: var(--text);
      letter-spacing: -0.03em;
    }

    .revideo-page-header__brand span {
      width: 40px;
      height: 40px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(255, 209, 150, 0.24), rgba(95, 242, 255, 0.18));
      border: 1px solid rgba(255, 255, 255, 0.08);
      font-family: var(--mono);
      color: #fff1d9;
    }

    .revideo-page-header__nav {
      display: flex;
      gap: 18px;
      color: color-mix(in srgb, var(--text) 84%, #8aa8b2);
      font-size: 0.95rem;
    }

    .revideo-page-header__nav a:hover {
      color: var(--text);
    }

    .revideo-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(290px, 0.8fr);
      gap: 22px;
      padding-top: 42px;
      align-items: start;
    }

    .revideo-hero__copy,
    .revideo-hero__rail {
      border: 1px solid rgba(136, 231, 255, 0.18);
      border-radius: 30px;
      background:
        radial-gradient(circle at top left, rgba(255, 209, 150, 0.14), transparent 17rem),
        radial-gradient(circle at top right, rgba(95, 242, 255, 0.12), transparent 18rem),
        rgba(8, 12, 18, 0.94);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.04),
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42);
      overflow: hidden;
      position: relative;
    }

    .revideo-hero__copy {
      padding: 34px;
    }

    .revideo-hero__copy h1 {
      margin-top: 18px;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
      text-transform: uppercase;
      background: linear-gradient(180deg, #ffffff 0%, #85ffec 36%, #ffd196 78%, #ffffff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .revideo-hero__copy p {
      max-width: 60ch;
      margin-top: 18px;
      color: color-mix(in srgb, var(--text) 84%, #88aab4);
      font-size: 1.04rem;
    }

    .revideo-hero__stamp {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 16px;
      padding: 8px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255, 209, 150, 0.24);
      background: rgba(8, 11, 14, 0.82);
      color: #fff1d9;
      font-family: var(--mono);
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .revideo-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .revideo-hero__rail {
      display: grid;
      gap: 14px;
      padding: 22px;
    }

    .revideo-hero__rail article {
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid rgba(255, 209, 150, 0.14);
      background: rgba(7, 11, 15, 0.88);
    }

    .revideo-hero__rail span {
      display: block;
      color: #ffd196;
      font-family: var(--mono);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .revideo-hero__rail strong {
      display: block;
      margin-top: 10px;
      font-size: 1.45rem;
      letter-spacing: -0.04em;
    }

    .revideo-hero__rail p {
      margin-top: 8px;
      color: color-mix(in srgb, var(--text) 78%, #8299a1);
      font-size: 0.94rem;
    }

    .revideo-atlas {
      padding-top: 24px;
      padding-bottom: 56px;
    }

    @media (max-width: 980px) {
      .revideo-hero {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .revideo-page-header__inner {
        flex-direction: column;
        justify-content: center;
        padding: 12px 24px;
      }

      .revideo-page-header__nav {
        flex-wrap: wrap;
        justify-content: center;
      }

      .revideo-hero__copy,
      .revideo-hero__rail {
        padding: 20px;
      }
    }
  </style>
</Layout>
