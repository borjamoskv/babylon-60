    <script is:inline>
        // --- 01. FERMI FUNNEL WIDGET ---
        const funnelStages = [
            { title: "Población Mundial", num: "8.200.000.000", desc: "Población global estimada en el planeta Tierra (2026).", math: "Base: 8.2e9 (Nivel base)" },
            { title: "Educación Superior", num: "820.000.000", desc: "Graduados universitarios o con educación técnica superior equivalente (10%).", math: "8.2e9 * 0.10" },
            { title: "Perfil STEM", num: "164.000.000", desc: "Profesionales de Ciencia, Tecnología, Ingeniería y Matemáticas (20%).", math: "820e6 * 0.20" },
            { title: "Exposición Teórica", num: "3.280.000", desc: "Físicos, teóricos de la computación, químicos físicos e ingenieros avanzados (2.0%).", math: "164e6 * 0.02" },
            { title: "Comprensión Intersección", num: "164.000", desc: "Sujetos que dominan la equivalencia física y matemática entre termodinámica y Shannon (5.0%).", math: "3.28e6 * 0.05 (0.002% total)" }
        ];

        const stagesEl = document.querySelectorAll('.funnel-stage');
        const dashTitle = document.getElementById('dash-title');
        const dashNumber = document.getElementById('dash-number');
        const dashDetails = document.getElementById('dash-details');
        const dashMath = document.getElementById('dash-math');

        stagesEl.forEach(stage => {
            stage.addEventListener('mouseenter', () => {
                const index = parseInt(stage.getAttribute('data-stage'), 10);
                activateStage(index);
            });
        });

        function activateStage(index) {
            stagesEl.forEach((el, i) => {
                el.classList.remove('active', 'active-crimson');
                if (i === index) {
                    if (index === 4) {
                        el.classList.add('active-crimson');
                    } else {
                        el.classList.add('active');
                    }
                }
            });
            const info = funnelStages[index];
            dashTitle.textContent = info.title;
            dashNumber.textContent = info.num;
            dashDetails.textContent = info.desc;
            dashMath.textContent = info.math;

            if (index === 4) {
                dashNumber.classList.add('crimson-text');
            } else {
                dashNumber.classList.remove('crimson-text');
            }
        }

        // --- 02. SHANNON-GIBBS ENTROPY SANDBOX ---
        const p0Slider = document.getElementById('p0-slider');
        const p0Val = document.getElementById('p0-val');
        const p1Val = document.getElementById('p1-val');
        const shannonNum = document.getElementById('shannon-num');
        const gibbsNum = document.getElementById('gibbs-num');
        const sandboxCanvas = document.getElementById('sandbox-canvas');

        // Initialize canvas particles
        const particleCount = 40;
        const particles = [];
        for (let i = 0; i < particleCount; i++) {
            const p = document.createElement('div');
            p.className = 'sandbox-particle';
            p.style.left = `${Math.random() * 90 + 5}%`;
            p.style.top = `${Math.random() * 70 + 15}%`;
            sandboxCanvas.appendChild(p);
            particles.push(p);
        }

        const kB = 1.380649e-23; // Boltzmann constant J/K

        function updateSandbox() {
            const p0 = parseFloat(p0Slider.value);
            const p1 = 1.0 - p0;

            p0Val.textContent = p0.toFixed(2);
            p1Val.textContent = p1.toFixed(2);

            let H = 0;
            if (p0 > 0 && p0 < 1) {
                H = -(p0 * Math.log2(p0) + p1 * Math.log2(p1));
            } else {
                H = 0;
            }

            const S = kB * H * Math.log(2);

            shannonNum.textContent = `${H.toFixed(4)} bits`;
            
            if (S === 0) {
                gibbsNum.textContent = "0 J/K";
            } else {
                gibbsNum.textContent = `${(S * 1e24).toFixed(3)} × 10⁻²⁴ J/K`;
            }

            // Update particles states dynamically
            particles.forEach((p, idx) => {
                const isState1 = (idx / particleCount) > p0;
                if (isState1) {
                    p.classList.add('state-1');
                } else {
                    p.classList.remove('state-1');
                }
                
                // Add noise/motion based on entropy
                const jitter = H * 12; // higher entropy = more vibration
                const dx = (Math.random() - 0.5) * jitter;
                const dy = (Math.random() - 0.5) * jitter;
                p.style.transform = `translate(${dx}px, ${dy}px)`;
                p.style.opacity = H * 0.6 + 0.25;
            });
        }

        p0Slider.addEventListener('input', updateSandbox);
        updateSandbox();

        // --- 03. LANDAUER LIMIT CHAMBER ---
        const tempSlider = document.getElementById('temp-slider');
        const tempVal = document.getElementById('temp-val');
        const eraseBtn = document.getElementById('erase-btn');
        const qLimitText = document.getElementById('q-limit-text');
        const chamberVisual = document.getElementById('chamber-visual');
        const partition = document.getElementById('partition');
        const demon = document.getElementById('demon');
        const heatFlash = document.getElementById('heat-flash');

        const chamberParticlesCount = 15;
        const chamberParticles = [];

        // Spawn particles in chamber
        for (let i = 0; i < chamberParticlesCount; i++) {
            const p = document.createElement('div');
            p.className = 'chamber-particle-c';
            // Start distributed randomly left and right
            p.style.left = `${Math.random() * 85 + 5}%`;
            p.style.top = `${Math.random() * 65 + 15}%`;
            chamberVisual.appendChild(p);
            chamberParticles.push(p);
        }

        let temp = 298;
        let chamberInterval;

        function animateChamberParticles() {
            chamberParticles.forEach(p => {
                const speedFactor = (temp / 300) * 8 + 1;
                const currentLeft = parseFloat(p.style.left);
                const currentTop = parseFloat(p.style.top);

                let nextLeft = currentLeft + (Math.random() - 0.5) * speedFactor;
                let nextTop = currentTop + (Math.random() - 0.5) * speedFactor;

                // Bounce bounds
                if (nextLeft < 3) nextLeft = 3;
                if (nextLeft > 93) nextLeft = 93;
                if (nextTop < 12) nextTop = 12;
                if (nextTop > 75) nextTop = 75;

                // Check partition boundary if partition is closed (left of partition is <50%, right is >50%)
                const isClosed = partition.classList.contains('closed');
                if (isClosed) {
                    if (currentLeft < 48 && nextLeft >= 48) nextLeft = 47;
                    if (currentLeft > 51 && nextLeft <= 51) nextLeft = 52;
                }

                p.style.left = `${nextLeft}%`;
                p.style.top = `${nextTop}%`;
            });
        }

        function updateChamber() {
            temp = parseInt(tempSlider.value, 10);
            tempVal.textContent = `${temp} K`;
            
            // Calculate Q limit
            const Q = kB * temp * Math.log(2);
            if (Q === 0) {
                qLimitText.textContent = "0 J";
            } else {
                qLimitText.textContent = `${(Q * 1e21).toFixed(2)} × 10⁻²¹ J`;
            }
        }

        // Action: Erase 1 Bit
        eraseBtn.addEventListener('click', () => {
            // Animate demon glowing
            demon.classList.add('glow-crimson');
            
            // Animate demon closing the partition
            setTimeout(() => {
                partition.classList.add('closed');
                
                // Force particles to the left side (reducing entropy/states)
                chamberParticles.forEach((p, idx) => {
                    // Force the particle to move to left chamber
                    p.style.left = `${Math.random() * 40 + 5}%`;
                });

                // Dissipate heat (flash red background)
                setTimeout(() => {
                    heatFlash.style.opacity = (temp / 400) * 0.4 + 0.1;
                    setTimeout(() => {
                        heatFlash.style.opacity = 0;
                    }, 400);
                }, 300);

            }, 400);

            // Reopen partition and release particles after a few seconds
            setTimeout(() => {
                partition.classList.remove('closed');
                demon.classList.remove('glow-crimson');
            }, 3000);
        });

        tempSlider.addEventListener('input', updateChamber);
        updateChamber();

        // Start animation loop
        setInterval(animateChamberParticles, 100);
    </script>
</body>
