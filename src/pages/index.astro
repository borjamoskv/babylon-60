      border: 1px solid var(--line-strong);
      background: rgba(197, 255, 111, 0.12);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 0.8rem;
    }

    .void-panel summary strong {
      color: var(--text);
      font-size: 1.1rem;
      letter-spacing: -0.03em;
      text-transform: uppercase;
    }

    .void-panel summary small {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: right;
