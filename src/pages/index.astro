---

<Layout title={pageTitle} description={pageDescription}>
  <header class="site-header">
    <div class="site-header__inner w">
      <a class="brand" href={isDocsVariant ? docsHref('') : '#top'}>
        <span class="brand__mark">CP</span>
        <span>
          <strong>CORTEX</strong>
          <small>{isDocsVariant ? 'documentation' : 'website'}</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        {navLinks.map((link) => (
          <a
            class="site-nav__link"
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
      {
        isDocsVariant ? (
          <a class="btn btn--p" href={marketingHref()}>
            Product home
          </a>
        ) : (
          <a class="btn btn--p" href={docsHref('/quickstart')}>
            Read docs
          </a>
        )
      }
    </div>
  </header>

  <main id="top">
    {
      isDocsVariant ? (
        <>
          <section class="hero hero--docs w">
            <div class="hero__copy">
              <div class="eyebrow rv">Documentation Home</div>
              <h1 class="hero__title rv">Build verifiable agent memory without reverse-engineering the repo.</h1>
              <p class="hero__sub rv">
                This surface is served from <code>cortexpersist.com/docs</code>. Start with quickstart,
                then move through architecture, API, security, and compliance without changing domains.
              </p>
              <div class="hero__actions rv">
                <a class="btn btn--p" href={docsHref('/quickstart')}>Open quickstart</a>
                <a class="btn btn--g" href={docsHref('/architecture')}>Read architecture</a>
              </div>
              <p class="hero__note rv">
                Canonical setup: <strong>product</strong> on <code>cortexpersist.com</code> and
                <strong> documentation</strong> under <code>/docs</code>.
              </p>
            </div>
            <aside class="hero__rail rv">
              {docsCards.map((card) => (
                <a class="rail-card" href={card.href}>
                  <span class="rail-card__kicker">Entry point</span>
                  <h2>{card.title}</h2>
                  <p>{card.text}</p>
                </a>
              ))}
            </aside>
          </section>

