    .swarm100-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 16px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .swarm100-legend span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .swarm100-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      box-shadow: 0 0 14px currentColor;
    }

    .swarm100-dot--scout {
      color: #c5ff6f;
      background: currentColor;
    }

    .swarm100-dot--mutate {
      color: #4bf3ff;
      background: currentColor;
    }

    .swarm100-dot--verify {
      color: #ffd26c;
      background: currentColor;
    }

    .swarm100-dot--promote {
      color: #ff4f7f;
      background: currentColor;
    }

    .swarm100-squadrons__grid {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .swarm100-squad {
      display: grid;
      gap: 8px;
      padding: 16px 18px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
    }

    .swarm100-squad__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
    }

    .swarm100-squad__head strong,
    .swarm100-squad__head span {
