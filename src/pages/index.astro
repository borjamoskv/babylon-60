      position: relative;
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: 22px;
      background:
        radial-gradient(circle at top left, rgba(75, 243, 255, 0.1), transparent 18rem),
        radial-gradient(circle at top right, rgba(255, 79, 127, 0.1), transparent 18rem),
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0)),
        var(--panel);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42),
        0 0 46px rgba(95, 242, 255, 0.08);
      overflow: hidden;
    }

    .swarm100-board::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.02) 42%, rgba(255, 255, 255, 0.12) 50%, transparent 58%),
