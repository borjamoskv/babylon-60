      filter: blur(24px);
      pointer-events: none;
      animation: videoAura 8s ease-in-out infinite alternate;
    }

    .video-shell__head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      padding: 10px 10px 16px;
    }

    .video-shell__signal {
      display: grid;
      gap: 10px;
      min-width: 180px;
    }

    .video-shell__live {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .video-shell__live i {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: #ff4f7f;
      box-shadow: 0 0 16px rgba(255, 79, 127, 0.45);
      animation: signalPulse 1.4s ease-in-out infinite;
    }

    .video-shell__meter {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 6px;
      height: 34px;
      align-items: end;
    }

    .video-shell__meter span {
      display: block;
      height: calc(100% * var(--meter-scale));
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(95, 242, 255, 0.95), rgba(255, 79, 127, 0.42));
      box-shadow: 0 0 18px rgba(95, 242, 255, 0.18);
      transform-origin: center bottom;
      animation: meterBounce 1.3s ease-in-out infinite;
      animation-delay: var(--meter-delay);
    }

    .video-shell__kicker {
      color: var(--accent);
      font-family: var(--mono);
      font-size: 0.74rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    .video-shell__head p {
      display: none;
    }

    .video-shell__action {
      flex: 0 0 auto;
    }

    .demo-video {
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 22px;
      background: #000;
      cursor: zoom-in;
    }

    .site-footer {
      padding: 16px 0 28px;
    }

    .site-footer__copy {
      color: var(--muted);
    }

    .site-footer__links {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      color: var(--muted);
    }

    .site-footer__links a:hover {
      color: var(--text);
    }

    @keyframes heroHalo {
      0% {
        opacity: 0;
        transform: translate3d(calc(var(--kx) * 12px), calc(var(--ky) * 12px), 0) scale(0.88);
      }
      18% {
        opacity: 0.92;
        transform: translate3d(calc(var(--kx) * 24px), calc(var(--ky) * 22px), 0) scale(1.05);
      }
      42% {
        opacity: 0.68;
        transform: translate3d(calc(var(--kx) * 18px), calc(var(--ky) * 18px), 0) scale(0.98);
      }
      100% {
        opacity: 0.82;
        transform: translate3d(calc(var(--kx) * 28px), calc(var(--ky) * 24px), 0) scale(1.02);
      }
    }

    @keyframes heroPortal {
      0% {
        transform: translate3d(0, -14px, 0) scale(0.82);
        opacity: 0;
      }
      20% {
        transform: translate3d(0, 8px, 0) scale(1.06);
        opacity: 0.9;
      }
      46% {
        transform: translate3d(0, 0, 0) scale(0.96);
        opacity: 0.72;
      }
      100% {
        transform: translate3d(0, 18px, 0) scale(1.02);
        opacity: 0.86;
      }
    }

    @keyframes signalBand {
      0%,
      8% {
        transform: translateX(0);
      }
      34%,
      42% {
        transform: translateX(-18%);
      }
      74%,
      82%,
      100% {
        transform: translateX(-50%);
      }
    }

    @keyframes signalPulse {
      0%,
      100% {
        transform: scale(0.88);
        opacity: 0.7;
      }
      50% {
        transform: scale(1.15);
        opacity: 1;
      }
    }

    @keyframes retroSweep {
      0% {
        transform: translateX(-32%);
      }
      100% {
        transform: translateX(132%);
      }
    }

    @keyframes swarmScan {
      0% {
        transform: translate3d(-14%, -8%, 0);
        opacity: 0.35;
      }
      50% {
        opacity: 0.8;
      }
      100% {
        transform: translate3d(14%, 10%, 0);
        opacity: 0.35;
      }
    }

    @keyframes swarmCellPulse {
      0%,
      100% {
        transform: scale(0.94);
        opacity: 0.72;
      }
      50% {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes meterBounce {
      0%,
      100% {
        transform: scaleY(0.72);
        opacity: 0.78;
      }
      50% {
        transform: scaleY(1.08);
        opacity: 1;
      }
    }

    @keyframes videoAura {
      0% {
        opacity: 0.35;
        transform: translate3d(-2%, 0, 0) scale(0.96);
      }
      100% {
        opacity: 0.9;
        transform: translate3d(3%, -4%, 0) scale(1.08);
      }
    }

    @keyframes voidChamberReveal {
      0% {
        opacity: 0;
        transform: translateY(10px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

