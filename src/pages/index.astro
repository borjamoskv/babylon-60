const swarmSquadrons = swarmSquadPhases.map(([phase, mission], index) => ({
  id: `SQ-${String(index + 1).padStart(2, '0')}`,
  phase,
  mission,
}));

const swarmCells = Array.from({ length: 100 }, (_, index) => {
  const squadIndex = Math.floor(index / 10);
  const [phase] = swarmSquadPhases[squadIndex];
  return {
    id: index + 1,
    squad: squadIndex + 1,
    phase,
  };
});

