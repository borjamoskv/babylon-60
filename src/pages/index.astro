    .panel-proof__header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
    }

    .panel-proof ol {
      list-style: none;
      display: grid;
      gap: 14px;
      counter-reset: proof-steps;
    }

    .panel-proof li {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 10px 14px;
      align-items: start;
    }

    .panel-proof li::before {
      counter-increment: proof-steps;
      content: '0' counter(proof-steps);
      display: grid;
      place-items: center;
      width: 34px;
      height: 34px;
      margin-top: 2px;
      border-radius: 50%;
      background: rgba(197, 255, 111, 0.12);
      border: 1px solid var(--line-strong);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 0.72rem;
