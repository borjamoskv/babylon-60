---
import SiteLayout from '../layouts/SiteLayout.astro';
import CortexAuditLedger from '../components/CortexAuditLedger.tsx';
import TelemetryWidget from '../components/TelemetryWidget.tsx';

const navLinks = [
	{ href: '#quickstart', label: 'Quickstart' },
	{ href: '#features', label: 'Features' },
	{ href: '#sdks', label: 'SDKs' },
	{ href: '#pricing', label: 'Pricing' },
	{ href: 'https://agents.archi', label: 'Audit Registry' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/taste', label: 'Taste' },
];

const heroProofs = [
	{
		value: 'Event Ingestion',
		label: 'Track any state change or AI decision in milliseconds.',
	},
	{
		value: 'Provenance API',
		label: 'Cryptographic hash-chains prove your event history is intact.',
	},
	{
		value: 'State Replay',
		label: 'Reconstruct exactly what happened at any point in time.',
	},
];

const signalCards = [
	{
		index: '01',
		label: 'Ingest',
		title: 'Drop in and track',
		body: 'Send events from any system. We handle the ledger, indexing, and storage.',
	},
	{
		index: '02',
		label: 'Prove',
		title: 'Tamper-evident record',
		body: 'Every event is cryptographically sealed. Detect silent mutation instantly.',
	},
	{
		index: '03',
		label: 'Replay',
		title: 'Reconstruct state',
		body: 'Query the API to rebuild system state and prove what happened.',
	},
];

const capabilityCards = [
	{
		label: 'Capture',
		title: 'Capture the moments that matter',
		body: 'Record facts, decisions, and state transitions in a form that survives contact with real incident review.',
		items: ['Decision events', 'Reviewable context', 'Workflow ownership'],
	},
	{
		label: 'Seal',
		title: 'Seal the record',
		body: 'Protect the decision trail from silent edits and quiet drift so later review starts from a defensible source.',
		items: ['Hash-linked lineage', 'Integrity checks', 'Tamper evidence'],
	},
	{
		label: 'Verify',
		title: 'Verify later',
		body: 'When a workflow misfires, teams can validate the record instead of guessing from traces, screenshots, and memory.',
		items: ['Reproducible checks', 'Clear record status', 'Faster investigations'],
	},
	{
		label: 'Export',
		title: 'Export proof',
		body: 'Hand security, risk, or leadership something they can inspect quickly without turning the review into theater.',
		items: ['Audit packs', 'Human-readable artifacts', 'Internal review support'],
	},
];

const fitCards = [
	{
		label: 'Production',
		title: 'Teams already shipping agents',
		body: 'Best fit when the agent already touches a real workflow and the cost of failure is operational, not theoretical.',
		items: ['Code and deploy actions', 'Support or approval flows'],
	},
	{
		label: 'Risk',
		title: 'Sensitive or scrutinized surfaces',
		body: 'Useful when workflows involve pricing, finance, PII, approvals, or anything a human may have to defend later.',
		items: ['Internal trust reviews', 'Customer or audit scrutiny'],
	},
	{
		label: 'Adoption',
		title: 'Stacks that cannot migrate cleanly',
		body: 'CORTEX works best when replacing the full memory stack would be expensive, slow, or politically painful.',
		items: ['Drop in on top', 'Start with one flow'],
	},
];

const pricingCards = [
	{
		name: 'Developer',
		price: 'Free',
		body: 'Everything you need to track and verify events in dev environments.',
		items: ['10,000 events/mo', 'Community support', 'Standard retention', 'REST API & SDKs'],
		cta: 'Get API Key',
		href: '/api-key',
	},
	{
		name: 'Pro',
		price: 'From $49/mo',
		tag: 'Recommended',
		body: 'For production systems requiring scale and reliability.',
		items: ['1M events/mo', '99.9% SLA', 'Extended retention', 'Priority support'],
		cta: 'Start Pro Trial',
		href: '/upgrade',
		featured: true,
	},
	{
		name: 'Enterprise',
		price: 'Custom',
		body: 'For self-hosted or BYOC deployments with advanced compliance needs.',
		items: ['VPC Peering / BYOC', 'Advanced RBAC', 'Dedicated support', 'Custom integrations'],
		cta: 'Contact Sales',
		href: '/sales',
	},
];

const githubUrl = 'https://github.com/borjamoskv/Cortex-Persist';
const docsUrl = 'https://github.com/borjamoskv/Cortex-Persist/tree/main/docs';
---

<SiteLayout
	title="CORTEX Persist | Verifiable Event Ledger for Software Systems"
	description="Track, verify, and replay every event in your system with 2 lines of code."
	canonical="https://cortexpersist.com/"
>
	<main class="landing-shell">
		<header class="masthead">
			<a class="brand" href="/" aria-label="CORTEX Persist home">
				<span class="brand-mark">CP</span>
				<span class="brand-copy">
					<strong>CORTEX Persist</strong>
					<span>Verifiable event ledger</span>
				</span>
			</a>

			<nav class="site-nav" aria-label="Primary">
				{
					navLinks.map((link) => (
						<a class="nav-link" href={link.href}>
							{link.label}
						</a>
					))
				}
			</nav>

			<div class="masthead-actions">
				<a class="button-tertiary" href={githubUrl} target="_blank" rel="noreferrer">
					Docs
				</a>
				<a class="button-primary" href="/api-key">
					Get API Key
				</a>
			</div>
		</header>

		<section class="hero-section surface" id="quickstart">
			<div class="hero-copy">
				<p class="eyebrow">Developer SaaS / Zero-friction Integration</p>
				<h1>A verifiable event ledger for modern software systems.</h1>
				<p class="hero-text">
					Ingest events. Prove integrity. Replay system state. Track, verify, and replay every event in your system with 2 lines of code.
				</p>
				<p class="microcopy">
					Plans start at $0. Start tracking your first events in less than 60 seconds.
				</p>

				<div class="action-row">
					<a class="button-primary" href="/api-key">Start logging events</a>
					<a class="button-secondary" href={githubUrl} target="_blank" rel="noreferrer">
						View Documentation
					</a>
				</div>

				<div class="chip-row" aria-label="Core product properties">
					<span class="chip">Drop-in API</span>
					<span class="chip">Cryptographic Ledger</span>
					<span class="chip">No Stack Migration</span>
					<span class="chip">Self-hosted or Cloud</span>
				</div>

				<div class="hero-proofbar" aria-label="What the product enables">
					{
						heroProofs.map((proof) => (
							<article class="hero-proof surface-sunken">
								<strong>{proof.value}</strong>
								<span>{proof.label}</span>
							</article>
						))
					}
				</div>
			</div>

			<aside class="hero-console surface-sunken" aria-label="1-min Quickstart">
				<div class="surface-head">
					<span class="surface-label">1-min Quickstart</span>
					<span class="surface-state">cURL</span>
				</div>

				<pre class="console-block" style="overflow-x: auto;"><code>curl -X POST https://api.cortexpersist.com/v1/event \
  -H "Authorization: Bearer $CORTEX_API_KEY" \
  -d '&#123;
    "type": "agent.decision",
    "actor": "pricing-agent-001",
    "state": &#123; "action": "refund", "amount": 150.00 &#125;
  &#125;'</code></pre>

				<div class="proof-stack" style="margin-top: 1rem;">
					<div class="proof-item">
						<div>
							<strong>Instant hash-chaining</strong>
							<span>Event returns a verifiable cryptographic hash instantly.</span>
						</div>
						<span class="proof-tag live">23ms</span>
					</div>
					<div class="proof-item">
						<div>
							<strong>Immutable storage</strong>
							<span>Stored in the ledger, impossible to silently mutate.</span>
						</div>
						<span class="proof-tag audit">Active</span>
					</div>
				</div>
			</aside>
		</section>

		<section class="signal-grid" id="features">
			{
				signalCards.map((card) => (
					<article class="signal-card surface">
						<div class="card-meta">
							<span class="card-index">{card.index}</span>
							<span class="surface-label">{card.label}</span>
						</div>
						<h2>{card.title}</h2>
						<p class="surface-copy">{card.body}</p>
					</article>
				))
			}
		</section>

		<CortexAuditLedger client:load />

		<section class="section-frame surface" id="sdks">
			<div class="section-heading">
				<p class="section-kicker">Developer SDKs</p>
				<h2>Integrate CORTEX in 30 seconds.</h2>
				<p>
					Production-ready npm packages to inject verifiable event logging directly into your current stack.
				</p>
			</div>

			<div class="fit-layout">
				<!-- Core SDK -->
				<article class="fit-card surface-sunken" style="min-height: auto;">
					<p class="surface-label">Core SDK</p>
					<h3>cortex-persist</h3>
					<p>The core API client for Node.js and Edge environments.</p>
					<pre class="console-block"><code>npm install cortex-persist</code></pre>
					<p class="microcopy" style="font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; margin-top: 1rem; color: var(--accent-soft); line-height: 1.5;">
						import &#123; CortexClient &#125; from 'cortex-persist';
						<br/><br/>
						const cortex = new CortexClient(&#123; apiKey: process.env.CORTEX_API_KEY &#125;);
						<br/>
						await cortex.logEvent(&#123; type: 'user.login', userId: 'usr_123' &#125;);
					</p>
				</article>

				<!-- LangChain Plugin -->
				<article class="fit-card surface-sunken" style="min-height: auto;">
					<p class="surface-label">Plugin</p>
					<h3>cortex-persist-langchain</h3>
					<p>Official integration to plug CORTEX event tracking directly into your LangChain agents.</p>
					<pre class="console-block"><code>npm install cortex-persist-langchain</code></pre>
					<p class="microcopy" style="font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; margin-top: 1rem; color: var(--accent-soft); line-height: 1.5;">
						import &#123; CortexCallbackHandler &#125; from 'cortex-persist-langchain';
						<br/><br/>
						const handler = new CortexCallbackHandler(&#123; apiKey: process.env.CORTEX_API_KEY &#125;);
					</p>
				</article>
			</div>
		</section>

		<section class="section-frame surface" id="pricing">
			<div class="section-heading">
				<p class="section-kicker">Pricing</p>
				<h2>Clear, transparent pricing.</h2>
				<p>Start free. Scale as your system grows.</p>
			</div>

			<div class="pricing-grid">
				{
					pricingCards.map((card) => (
						<article class:list={['pricing-card', 'surface-sunken', card.featured && 'pricing-card-featured']}>
							<div class="pricing-head">
								<div class="pricing-head-copy">
									<h3>{card.name}</h3>
									<p class="plan-price">{card.price}</p>
								</div>
								{card.tag && <span class="plan-tag">{card.tag}</span>}
							</div>
							<p>{card.body}</p>
							<ul class="surface-list">
								{card.items.map((item) => <li>{item}</li>)}
							</ul>
							<a
								class:list={[card.featured ? 'button-primary' : 'button-secondary', 'pricing-cta']}
								href={card.href}
								target={card.href.startsWith('http') ? '_blank' : undefined}
								rel={card.href.startsWith('http') ? 'noreferrer' : undefined}
							>
								{card.cta}
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="cta-banner surface">
			<div>
				<p class="section-kicker">Get Started</p>
				<h2>Start logging events today.</h2>
				<p>
					Drop in the API key and get instant provenance for your most critical workflows.
				</p>
			</div>

			<div class="cta-actions">
				<div class="footer-actions" style="margin-top: 0;">
					<a class="button-primary" href="/api-key">Get API Key</a>
					<a class="button-secondary" href={docsUrl}>Read the Docs</a>
				</div>
			</div>
		</section>

		<footer class="site-footer">
			<p class="footer-note">CORTEX Persist / The swarm verifies. The hardware remembers.</p>
			<div class="footer-links">
				<a href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
				<a href={docsUrl} target="_blank" rel="noreferrer">Docs</a>
				<a href="https://agents.archi" target="_blank" rel="noreferrer">Audit Registry</a>
			</div>
		</footer>

		<TelemetryWidget client:load />
	</main>
</SiteLayout>
