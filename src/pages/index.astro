                        <a href="#use-cases" data-fractal-link="use-cases"><span>U-10</span><strong>Aftermath</strong></a>
                        <a href="#product" data-fractal-link="product"><span>P-02</span><strong>Need</strong></a>
                        <a href="#app-iteration" data-fractal-link="app-iteration"><span>I-05</span><strong>Friction</strong></a>
