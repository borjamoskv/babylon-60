  <script>
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      document.querySelectorAll('[data-kinetic-shell]').forEach((shell) => {
        const reset = () => {
          shell.style.setProperty('--kx', '0');
          shell.style.setProperty('--ky', '0');
        };

        reset();

        shell.addEventListener('pointermove', (event) => {
          const rect = shell.getBoundingClientRect();
          const px = (event.clientX - rect.left) / rect.width - 0.5;
          const py = (event.clientY - rect.top) / rect.height - 0.5;

          shell.style.setProperty('--kx', px.toFixed(3));
          shell.style.setProperty('--ky', py.toFixed(3));
        });

        shell.addEventListener('pointerleave', reset);
      });
    }

    const voidPanels = Array.from(document.querySelectorAll('.void-panel'));
    const fractalStatusNodes = Array.from(document.querySelectorAll('[data-fractal-status]'));
    const fractalScopeNodes = Array.from(document.querySelectorAll('[data-fractal-scope]'));
    const fractalLinks = Array.from(document.querySelectorAll('[data-fractal-link]'));

    const closeSiblingPanels = (activePanel) => {
      voidPanels.forEach((panel) => {
        if (panel !== activePanel) {
          panel.open = false;
        }
      });
    };

    const syncFractalState = (targetId) => {
      const fallbackPanel = voidPanels.find((panel) => panel.open) ?? document.getElementById('routes');
      const activeId =
        targetId && document.getElementById(targetId)?.classList.contains('void-panel')
          ? targetId
          : fallbackPanel instanceof HTMLDetailsElement
            ? fallbackPanel.id
            : 'routes';
      const label = activeId.replace(/-/g, ' ').toUpperCase();

      fractalStatusNodes.forEach((node) => {
        node.textContent = `ACTIVE WINDOW // ${label}`;
      });

      fractalScopeNodes.forEach((node) => {
        node.textContent = `SYNCED CHAMBER // ${label}`;
      });

      fractalLinks.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.fractalLink === activeId);
      });
    };

    const openVoidPanelFromHash = () => {
      const hash = window.location.hash.slice(1);

      if (!hash) {
        syncFractalState();
        return;
      }

      const panel = document.getElementById(hash);

      if (!(panel instanceof HTMLDetailsElement) || !panel.classList.contains('void-panel')) {
        syncFractalState();
        return;
      }

      closeSiblingPanels(panel);
      panel.open = true;
      syncFractalState(hash);
    };

    voidPanels.forEach((panel) => {
      panel.addEventListener('toggle', () => {
        if (panel.open) {
          closeSiblingPanels(panel);
          syncFractalState(panel.id);
        } else {
          syncFractalState();
        }
      });
    });

    window.addEventListener('hashchange', openVoidPanelFromHash);
    openVoidPanelFromHash();
  </script>

