                        <span></span>
                      </div>
                      <strong>borja://web/inside/web/inside/web</strong>
                    </div>
                    <div class="fractal-browser__viewport fractal-browser__viewport--mini">
                      <div class="fractal-browser__hero fractal-browser__hero--mini">
