                    <a href="#swarm-100" data-fractal-link="swarm-100"><span>S-06 / LEGION</span><strong>Swarm 100</strong></a>
                    <a href="/spectral-audio"><span>D-00 / SIGNAL</span><strong>DJ Automata</strong></a>
                    <a href="#mac-control" data-fractal-link="mac-control"><span>M-08 / KINETIC</span><strong>Mac Control</strong></a>
                  </div>
