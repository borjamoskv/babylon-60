      <section id="compare" class="compare-section">
        <div class="section-heading"><span class="section-kicker">Positioning</span><h2>CORTEX vs. the rest.</h2><p>CORTEX can coexist with hosted memory tools, vector stores, and agent frameworks. The difference is architectural: CORTEX treats memory as auditable state, not just recall infrastructure.</p></div>
        <div class="compare-callout"><strong>Architecture comparison.</strong> CORTEX focuses on verifiable memory and evidence continuity. Vendor pricing and product scope can change, so teams should confirm current terms during due diligence.</div>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead><tr><th>Capability</th><th>Mem0</th><th>Zep</th><th>Letta</th><th>CORTEX</th></tr></thead>
            <tbody>{compareRows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
          </table>
        </div>
      </section>

      <section class="org-section" id="trust">
        <div class="section-heading">
          <span class="section-kicker">Domain split</span>
          <h2>.com sells the product. .org carries the trust record.</h2>
          <p>cortexpersist.org is reserved for governance, research, security posture, and evidence material so public trust content does not get buried inside pricing or checkout flows.</p>
        </div>
        <div class="domain-grid" aria-label="CORTEX domain map">
          <article>
            <span>.com</span>
            <h3>Commercial canonical</h3>
            <p>Public product surface, pricing, checkout entry, and implementation support.</p>
          </article>
          <article>
            <span>.dev</span>
            <h3>Developer surface</h3>
            <p>Docs, API references, SDK examples, integration notes, and staging links.</p>
          </article>
          <article class="domain-card-primary">
            <span>.org</span>
            <h3>Trust and community</h3>
            <p>Governance, research, security posture, responsible disclosure, and evidence material.</p>
            <a class="domain-link" href="/org/">Open trust hub</a>
          </article>
        </div>
      </section>

      <section id="pricing">
        <div class="section-heading"><span class="section-kicker">Pricing</span><h2>Start locally. Add managed help when needed.</h2><p>The open-source core is free. Paid tiers are for teams that want hosted sync, implementation support, or managed compliance evidence.</p></div>
        <div class="pricing-grid">
          {plans.map(([name, desc, price, suffix, items, cta, action], index) => <article class:list={['plan', index === 1 && 'highlighted', action === 'enterprise' && 'enterprise']}>
            {index === 1 && <div class="plan-badge">Early access</div>}
            <div class="plan-head"><h3>{name}</h3><p>{desc}</p></div>
            <div class="price">{price} <span>{suffix}</span></div>
            <ul>{items.map((item) => <li>{item}</li>)}</ul>
            {action === 'copy' && <button class="btn btn-secondary copy-install" type="button" data-copy="pip install cortex-persist">{cta}</button>}
            {action === 'pro' && <button class="btn btn-primary open-checkout" type="button" data-plan="pro">{cta}</button>}
            {action === 'team' && <button class="btn btn-secondary open-checkout" type="button" data-plan="team">{cta}</button>}
            {action === 'enterprise' && <a class="btn btn-secondary" href="mailto:borja@cortexpersist.com?subject=CORTEX%20Enterprise%20deployment">{cta}</a>}
          </article>)}
        </div>
      </section>

      <section class="final-cta" id="start"><span class="section-kicker">Thirty seconds to first proof</span><h2>Do not let agent memory become unverifiable production state.</h2><p>Install locally, store one decision, and verify the ledger before you trust the next agent handoff.</p><div class="hero-actions"><a class="btn btn-primary" href="#pricing">Install CORTEX</a><a class="btn btn-secondary" href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noopener noreferrer">View source repository</a></div></section>
    </main>

    <footer class="footer"><div><a class="brand notranslate" href="#hero" aria-label="CORTEX home" translate="no"><span class="brand-mark">C</span><span translate="no">CORTEX</span></a><p>Trust infrastructure for autonomous AI. Apache 2.0 core.</p></div><nav aria-label="Footer navigation"><a href="/org/">Trust</a><a href="/site/">Docs</a><a href="/site/api/">API</a><a href="/site/security/">Security</a><a href="/site/quickstart/">Quickstart</a><a href="/site/blog/">Blog</a><a href="/org/">Trust center</a></nav></footer>

    <div class="modal" id="checkout-modal" aria-hidden="true"><div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="checkout-title"><button class="modal-close" type="button" id="checkout-close" aria-label="Close checkout">x</button><span class="section-kicker">Secure checkout</span><h2 id="checkout-title">Request access</h2><p id="checkout-copy">Card details are handled by payment-provider checkout. CORTEX does not collect raw card data on this page.</p><form id="checkout-form"><input type="hidden" name="plan" id="checkout-plan" value="pro" /><label for="checkout-email">Work email</label><input id="checkout-email" name="email" type="email" inputmode="email" autocomplete="email" placeholder="you@company.com" required /><button class="btn btn-primary" id="checkout-submit" type="submit">Continue</button></form><p class="modal-footnote">If hosted checkout is not active yet, the button opens a pre-filled founder request instead.</p></div></div>

    <script is:inline>
      (() => {
        const nav = document.getElementById('nav');
        const modal = document.getElementById('checkout-modal');
        const close = document.getElementById('checkout-close');
        const form = document.getElementById('checkout-form');
        const planInput = document.getElementById('checkout-plan');
        const title = document.getElementById('checkout-title');
        const copy = document.getElementById('checkout-copy');
        const submit = document.getElementById('checkout-submit');
        const email = document.getElementById('checkout-email');
        const apiBaseMeta = document.querySelector('meta[name="cortex-api-base"]');
        const planCopy = {
          pro: { title: 'Request Pro early access', copy: 'Pro adds encrypted sync, five tenant workspaces, and priority implementation support. the payment provider handles payment details if hosted checkout is enabled.' },
          team: { title: 'Request a Team pilot', copy: 'Team adds unlimited tenant workspaces, consensus workflows, and compliance report templates. the payment provider handles payment details if hosted checkout is enabled.' }
        };
        const openModal = (plan) => { const selected = planCopy[plan] || planCopy.pro; planInput.value = plan; title.textContent = selected.title; copy.textContent = selected.copy; modal.classList.add('active'); modal.setAttribute('aria-hidden', 'false'); setTimeout(() => email.focus(), 50); };
        const closeModal = () => { modal.classList.remove('active'); modal.setAttribute('aria-hidden', 'true'); submit.disabled = false; submit.textContent = 'Continue'; };
        const resolvePublicOrigin = () => globalThis.location.protocol === 'file:' ? 'https://cortexpersist.com' : globalThis.location.origin;
        const resolveApiBase = () => globalThis.CORTEX_API_BASE_URL || apiBaseMeta?.content || resolvePublicOrigin();
        const checkoutEndpoint = () => new URL('/v1/stripe/checkout', resolveApiBase()).toString();
        const copyInstall = async (button) => { const value = button.dataset.copy || 'pip install cortex-persist'; try { await navigator.clipboard.writeText(value); } catch (_) { const textarea = document.createElement('textarea'); textarea.value = value; textarea.setAttribute('readonly', ''); textarea.style.position = 'absolute'; textarea.style.left = '-9999px'; document.body.appendChild(textarea); textarea.select(); document.execCommand('copy'); textarea.remove(); } button.textContent = 'Copied: ' + value; setTimeout(() => { button.textContent = value; }, 1800); };
        document.querySelectorAll('.open-checkout').forEach((button) => button.addEventListener('click', () => openModal(button.dataset.plan)));
        document.querySelectorAll('.copy-install').forEach((button) => button.addEventListener('click', () => copyInstall(button)));
        close.addEventListener('click', closeModal);
        modal.addEventListener('click', (event) => { if (event.target === modal) closeModal(); });
        document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && modal.classList.contains('active')) closeModal(); });
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (!email.checkValidity()) { email.reportValidity(); return; }
          submit.disabled = true;
          submit.textContent = 'Opening secure checkout...';
          const plan = planInput.value;
          const publicOrigin = resolvePublicOrigin();
          const payload = { plan, customer_email: email.value, success_url: publicOrigin + '/success/', cancel_url: publicOrigin + '/cancel/', ui_mode: 'hosted' };
          try {
            const response = await fetch(checkoutEndpoint(), { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (!response.ok) throw new Error('checkout unavailable');
            const data = await response.json();
            if (data.url) { globalThis.location.href = data.url; return; }
            throw new Error('checkout URL missing');
          } catch (_) {
            const subject = encodeURIComponent('CORTEX ' + plan.toUpperCase() + ' access request');
            const body = encodeURIComponent('Plan: ' + plan + '\nEmail: ' + email.value + '\n\nI want access to CORTEX ' + plan + '.');
            globalThis.location.href = 'mailto:borja@cortexpersist.com?subject=' + subject + '&body=' + body;
            closeModal();
          }
        });
        const onScroll = () => nav.classList.toggle('scrolled', globalThis.scrollY > 16);
        onScroll();
        globalThis.addEventListener('scroll', onScroll, { passive: true });

        const useCases = {
          crypto: {
            kicker: 'Fiscal evidence pack',
            title: 'Blockchain and NFT forensics for tax review.',
            copy: 'Reconstructs wallets, exchanges, swaps, NFT sales, royalties, fees, and custody gaps into a traceable technical dossier for a tax advisor.',
            tags: ['wallet graph', 'tx hash', 'cost basis', 'PDF + CSV'],
            score: 96,
            checks: ['Multiple sources must be reconciled.', 'Decisions must be explained months later.', 'A third party will review the evidence.'],
            input: 'Wallets + exchange CSVs + NFT marketplaces',
            process: 'Classify, hash, flag gaps, seal evidence',
            output: 'Advisor-ready PDF, CSV, manifest'
          },
          agent: {
            kicker: 'Agent memory passport',
            title: 'An agent that remembers without fabricating its past.',
            copy: 'CORTEX separates useful memory from admitted facts: preferences, decisions, tasks, handoffs, and project context with tenant boundaries.',
            tags: ['preferences', 'handoff', 'tenant scope', 'ledger'],
            score: 91,
            checks: ['The agent operates for weeks or months.', 'Some decisions cannot be lost.', 'Context must transfer across tools.'],
            input: 'Chats, project decisions, tasks, agent events',
            process: 'Guard, scope, persist, retrieve, verify',
            output: 'Portable memory passport for the agent'
          },
          research: {
            kicker: 'Deep research crystallization',
            title: 'Research that doesn\'t die in a transcript.',
            copy: 'Converts audits, benchmarks, repo analysis, and competitive research into knowledge crystals with source, date, and traceability.',
            tags: ['source trail', 'findings', 'crystals', 'exports'],
            score: 88,
            checks: ['Sources and conclusions must remain distinct.', 'The report will be reused later.', 'Crucial to separate evidence from hypothesis.'],
            input: 'Sources, repos, notes, audit prompts',
            process: 'Acquire, analyze, classify, crystallize',
            output: 'Reusable evidence-backed research pack'
          },
          incident: {
            kicker: 'Incident reconstruction',
            title: 'Reconstruct what the system knew when it failed.',
            copy: 'For bugs, security incidents, or disputed automated decisions, CORTEX helps reconstruct memory, timelines, validations, and persisted state.',
            tags: ['timeline', 'guards', 'audit log', 'postmortem'],
            score: 93,
            checks: ['An automated decision is disputed.', 'You need a verifiable timeline.', 'The response must survive an audit.'],
            input: 'Events, memory writes, guard failures, ledger entries',
            process: 'Replay, verify chain, identify divergence',
            output: 'Postmortem timeline with proof anchors'
          }
        };

        const usecaseRoot = document.querySelector('[data-usecase-console]');
        if (usecaseRoot) {
          const usecaseEls = {
            tabs: usecaseRoot.querySelectorAll('.usecase-tab'),
            main: usecaseRoot.querySelector('.usecase-main'),
            proof: usecaseRoot.querySelector('.usecase-proof'),
            flow: usecaseRoot.querySelector('.usecase-flow'),
            kicker: document.getElementById('usecase-kicker'),
            title: document.getElementById('usecase-title'),
            copy: document.getElementById('usecase-copy'),
            tags: document.getElementById('usecase-tags'),
            score: document.getElementById('usecase-score'),
            meter: document.getElementById('usecase-meter'),
            checks: document.getElementById('usecase-checks'),
            input: document.getElementById('usecase-input'),
            process: document.getElementById('usecase-process'),
            output: document.getElementById('usecase-output')
          };

          const renderUseCase = (key) => {
            const item = useCases[key] || useCases.crypto;
            usecaseEls.tabs.forEach((tab) => {
              const active = tab.dataset.usecase === key;
              tab.classList.toggle('active', active);
              tab.setAttribute('aria-selected', String(active));
            });
            [usecaseEls.main, usecaseEls.proof, usecaseEls.flow].forEach((el) => {
              el.classList.remove('is-swapping');
              void el.offsetWidth;
              el.classList.add('is-swapping');
            });
            usecaseEls.kicker.textContent = item.kicker;
            usecaseEls.title.textContent = item.title;
            usecaseEls.copy.textContent = item.copy;
            usecaseEls.tags.innerHTML = item.tags.map((tag) => `<em>${tag}</em>`).join('');
            usecaseEls.score.textContent = item.score;
            usecaseEls.meter.style.width = `${item.score}%`;
            usecaseEls.checks.innerHTML = item.checks.map((check) => `<li>${check}</li>`).join('');
            usecaseEls.input.textContent = item.input;
            usecaseEls.process.textContent = item.process;
            usecaseEls.output.textContent = item.output;
          };

          usecaseEls.tabs.forEach((tab) => {
            tab.addEventListener('click', () => renderUseCase(tab.dataset.usecase));
          });
        }
      })();
    </script>
  </body>
</html>
