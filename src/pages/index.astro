    .swarm100-cell--verify {
      color: #ffd992;
      background: rgba(255, 210, 108, 0.12);
      box-shadow: 0 0 24px rgba(255, 210, 108, 0.14);
    }

    .swarm100-cell--promote {
      color: #ffafc5;
      background: rgba(255, 79, 127, 0.12);
      box-shadow: 0 0 24px rgba(255, 79, 127, 0.14);
