        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42),
        0 0 46px rgba(95, 242, 255, 0.08);
      position: relative;
      overflow: hidden;
    }

    .hero__metrics div {
      padding: 18px;
      border-radius: 22px;
