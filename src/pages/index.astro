    .docs-grid,
    .quickstart-grid,
    .route-grid {
      display: grid;
      gap: 18px;
    }

    .proof-strip {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      padding: 0 24px 24px;
    }

    .proof-card,
    .feature-card {
      padding: 24px;
      border-radius: 24px;
    }

    .route-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .route-card,
    .trust-card {
      display: grid;
      gap: 14px;
      padding: 26px;
      border-radius: 28px;
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0)),
        var(--panel);
      box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42),
        0 0 46px rgba(95, 242, 255, 0.08);
      position: relative;
      overflow: hidden;
      transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
    }

    .panel-proof::before,
    .rail-card::before,
    .feature-card::before,
    .comparison-card::before,
    .terminal-shell::before,
    .signal-card::before,
    .proof-card::before,
    .video-shell::before,
    .route-card::before,
    .trust-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.02) 42%, rgba(255, 255, 255, 0.12) 50%, transparent 58%),
        repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 3px);
      mix-blend-mode: screen;
      opacity: 0.5;
      pointer-events: none;
      animation: retroSweep 12s linear infinite;
