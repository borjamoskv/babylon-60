    .void-panel[open] {
      border-color: var(--line-strong);
      box-shadow:
        0 0 0 1px rgba(197, 255, 111, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 80px rgba(0, 0, 0, 0.42),
        0 0 54px rgba(95, 242, 255, 0.12);
