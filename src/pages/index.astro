const docsOrigin = import.meta.env.PUBLIC_DOCS_ORIGIN || '/docs';
const marketingOrigin = import.meta.env.PUBLIC_MARKETING_ORIGIN || '';

const docsHref = (path = '') => `${docsOrigin}${path}`;
const marketingHref = (path = '/') => `${marketingOrigin}${path}`;

const pageTitle = isDocsVariant
