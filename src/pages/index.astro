    <!-- Fast Checkout Modal -->
    <div class="checkout-overlay" id="checkout-overlay">
        <div class="checkout-modal">
            <div class="checkout-header">
                <div class="checkout-title">Complete your Subscription</div>
                <button class="checkout-close" id="checkout-close">&times;</button>
            </div>
            <div class="checkout-plan">
                <div class="checkout-plan-name" id="checkout-plan-name">Pro Plan</div>
                <div class="checkout-plan-price" id="checkout-plan-price">$49</div>
            </div>
            <div class="checkout-form">
                <input type="email" class="checkout-input" placeholder="Email Address" required>
                <input type="text" class="checkout-input" placeholder="Card Number" required>
                <div style="display:flex; gap:16px;">
                    <input type="text" class="checkout-input" placeholder="MM/YY" style="flex:1" required>
                    <input type="text" class="checkout-input" placeholder="CVC" style="flex:1" required>
                </div>
            </div>
            <button class="btn btn-primary checkout-btn" id="checkout-submit">Pay Securely →</button>
            <div class="checkout-footer">
                <span style="display:inline-block; width:12px; height:12px; border-radius:50%; background:green; margin-right:4px;"></span>
                Encrypted & Secured by CORTEX Privacy Shield
            </div>
        </div>
    </div>

    <!-- Payment Integration -->
    <script is:inline src="https://js.stripe.com/v3/"></script>
    <script is:inline>
        let stripeCheckoutInstance = null;
        const checkoutOverlay = document.getElementById('checkout-overlay');
        const checkoutClose = document.getElementById('checkout-close');
        const checkoutName = document.getElementById('checkout-plan-name');
        const checkoutPrice = document.getElementById('checkout-plan-price');
        const checkoutSubmit = document.getElementById('checkout-submit');

        document.querySelectorAll('[data-plan]').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const plan = btn.dataset.plan;
                const amount = plan === 'pro' ? '49' : '0';
                const name = plan === 'pro' ? 'Pro Plan' : 'Custom';
                
                checkoutName.innerText = name;
                checkoutPrice.innerText = '$' + amount;
                checkoutOverlay.classList.add('active');
            });
        });

        checkoutClose.addEventListener('click', () => {
            checkoutOverlay.classList.remove('active');
            setTimeout(() => {
                if (stripeCheckoutInstance) {
                    stripeCheckoutInstance.destroy();
                    stripeCheckoutInstance = null;
                }
                document.querySelector('.checkout-form').style.display = 'block';
                checkoutSubmit.style.display = 'block';
                checkoutSubmit.innerText = "Pay Securely →";
                checkoutSubmit.style.opacity = "1";
                checkoutSubmit.style.pointerEvents = "auto";
                document.querySelector('.checkout-footer').style.display = 'block';
                const embedded = document.getElementById('stripe-checkout-container');
                if (embedded) embedded.remove();
            }, 300);
        });

        checkoutOverlay.addEventListener('click', (e) => {
            if (e.target === checkoutOverlay) {
                checkoutOverlay.classList.remove('active');
            }
        });

        checkoutSubmit.addEventListener('click', async () => {
            const emailInput = document.querySelector('.checkout-input[type="email"]');
            const plan = checkoutName.innerText.toLowerCase().includes('pro') ? 'pro' : 'enterprise';
            
            if (!emailInput.value || !emailInput.checkValidity()) {
                alert("Please enter a valid email address.");
                return;
            }

            checkoutSubmit.innerHTML = "Processing... <span class='spinner'></span>";
            checkoutSubmit.style.opacity = "0.7";
            checkoutSubmit.style.pointerEvents = "none";
            
            try {
                const response = await fetch('/v1/stripe/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        plan: plan,
                        customer_email: emailInput.value,
                        success_url: globalThis.location.origin + "/docs/prototypes/success.html",
                        cancel_url: globalThis.location.origin + "/docs/prototypes/cancel.html"
                    })
                });
                
                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.detail || 'Stripe initialization failed.');
                }
                
                const data = await response.json();
                if (data.client_secret) {
                    const stripe = Stripe('pk_test_TYooMQauvdEDq54NiTphI7jx');
                    
                    document.querySelector('.checkout-form').style.display = 'none';
                    checkoutSubmit.style.display = 'none';
                    document.querySelector('.checkout-footer').style.display = 'none';
                    
                    const checkoutContainer = document.createElement('div');
                    checkoutContainer.id = 'stripe-checkout-container';
                    document.querySelector('.checkout-modal').appendChild(checkoutContainer);
                    
                    stripeCheckoutInstance = await stripe.initEmbeddedCheckout({
                        clientSecret: data.client_secret,
                        appearance: {
                            theme: 'night',
                            variables: {
                                colorPrimary: '#CCFF00',
                                colorBackground: '#0F0F0F',
                                colorText: '#E0E0E0',
                                colorDanger: '#FF5252',
                                fontFamily: 'Inter, system-ui, sans-serif',
                                borderRadius: '12px'
                            }
                        }
                    });
                    
                    stripeCheckoutInstance.mount('#stripe-checkout-container');
                } else if (data.url) {
                    globalThis.location.href = data.url;
                } else {
                    throw new Error('No checkout session received.');
                }
            } catch (error) {
                console.error("Stripe Checkout Error:", error);
                alert("Payment gateway connection failed. Error: " + error.message);
                checkoutSubmit.innerText = "Pay Securely →";
                checkoutSubmit.style.opacity = "1";
                checkoutSubmit.style.pointerEvents = "auto";
            }
        });

        // Nav scroll effect
        window.addEventListener('scroll', () => {
            document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 50);
        });
    </script>

    <!-- Terminal Typewriter Animation -->
    <script is:inline>
    (function() {
        const lines = [
            { type: 'prompt', text: '$ ', delay: 0 },
            { type: 'cmd', text: 'pip install cortex-persist', delay: 40 },
            { type: 'newline', delay: 600 },
            { type: 'output', text: '✓ Installed cortex-persist 0.3.0b7', delay: 10 },
            { type: 'newline', delay: 800 },
            { type: 'prompt', text: '$ ', delay: 0 },
            { type: 'cmd', text: 'cortex store --type decision "Chose OAuth2 PKCE for auth"', delay: 35 },
            { type: 'newline', delay: 500 },
            { type: 'success', text: '✅ Stored fact #42 — SHA-256 hash-chained to ledger', delay: 10 },
            { type: 'newline', delay: 200 },
            { type: 'hash', text: '   tx: a3f8c2...d91b → prev: 7e2b01...4fc3', delay: 10 },
            { type: 'newline', delay: 800 },
            { type: 'prompt', text: '$ ', delay: 0 },
            { type: 'cmd', text: 'cortex verify 42', delay: 35 },
            { type: 'newline', delay: 400 },
            { type: 'success', text: '✅ VERIFIED — Hash chain intact, Merkle sealed', delay: 10 },
            { type: 'newline', delay: 800 },
            { type: 'prompt', text: '$ ', delay: 0 },
            { type: 'cmd', text: 'cortex compliance-report', delay: 30 },
            { type: 'newline', delay: 400 },
            { type: 'success', text: '📋 Compliance Score: 5/5 — All Article 12 requirements met', delay: 10 },
        ];

        const output = document.getElementById('terminal-output');
        let lineIndex = 0;
        let charIndex = 0;
        let currentSpan = null;

        function typeNext() {
            if (lineIndex >= lines.length) {
                // Add blinking cursor at end
                const cursor = document.createElement('span');
                cursor.className = 'typing-cursor';
                output.appendChild(cursor);
                return;
            }

            const line = lines[lineIndex];

            if (line.type === 'newline') {
                output.appendChild(document.createElement('br'));
                lineIndex++;
                charIndex = 0;
                currentSpan = null;
                setTimeout(typeNext, line.delay);
                return;
            }

            if (!currentSpan) {
                currentSpan = document.createElement('span');
                currentSpan.className = line.type;
                output.appendChild(currentSpan);
            }

            if (charIndex < line.text.length) {
                currentSpan.textContent += line.text[charIndex];
                charIndex++;
                setTimeout(typeNext, line.delay);
            } else {
                lineIndex++;
                charIndex = 0;
                currentSpan = null;
                setTimeout(typeNext, 50);
            }
        }

        // Start typewriter when element is in viewport
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    setTimeout(typeNext, 500);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.3 });

        observer.observe(document.getElementById('terminal-demo'));
    })();
    </script>


    <!-- Scroll Reveal Logic -->
    <script is:inline>
        const revealElements = document.querySelectorAll('.reveal');
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.1 });
        revealElements.forEach(el => revealObserver.observe(el));
    </script>

</body>
</html>
