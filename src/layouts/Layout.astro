---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Tamper-evident memory and decision lineage for AI agents.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#08110d" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --bg: #050c09;
        --bg-soft: #0d1713;
        --panel: rgba(10, 20, 16, 0.9);
        --panel-strong: #12211a;
        --line: rgba(225, 255, 171, 0.2);
        --line-strong: rgba(197, 255, 111, 0.42);
        --text: #f7fff0;
        --muted: #c1cdc0;
        --accent: #c5ff6f;
        --accent-strong: #84f6c5;
        --accent-ink: #0a160f;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
        --sans: 'Space Grotesk', sans-serif;
        --mono: 'IBM Plex Mono', monospace;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }

      body {
        background:
          radial-gradient(circle at top left, rgba(132, 246, 197, 0.08), transparent 28rem),
          radial-gradient(circle at top right, rgba(197, 255, 111, 0.08), transparent 22rem),
          linear-gradient(180deg, #09120e 0%, var(--bg) 55%, #040906 100%);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.6;
        overflow-x: hidden;
        min-height: 100vh;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
        background-size: 72px 72px;
        mask-image: radial-gradient(circle at center, black 25%, transparent 80%);
        pointer-events: none;
        opacity: 0.2;
      }

      body::after {
        content: '';
        position: fixed;
        inset: -18%;
        background:
          radial-gradient(circle at 16% 18%, rgba(75, 243, 255, 0.1), transparent 24rem),
          radial-gradient(circle at 82% 14%, rgba(197, 255, 111, 0.08), transparent 22rem),
          radial-gradient(circle at 52% 78%, rgba(255, 91, 134, 0.08), transparent 24rem);
        filter: blur(72px);
        opacity: 0.48;
        pointer-events: none;
        z-index: -1;
        animation: auroraDrift 24s ease-in-out infinite alternate;
      }

      body, button, input, textarea {
        font: inherit;
      }

      pre, code, kbd {
        font-family: var(--mono);
      }

      img, video {
        display: block;
        max-width: 100%;
      }

      .w { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

      a { color: inherit; text-decoration: none; }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
        cursor: pointer;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn--p {
        background: linear-gradient(135deg, var(--accent) 0%, #efffbf 100%);
        color: var(--accent-ink);
        box-shadow: 0 18px 44px rgba(197, 255, 111, 0.2);
      }

      .btn--g {
        background: rgba(6, 12, 10, 0.82);
        border-color: var(--line);
        color: var(--text);
      }

      .btn--g:hover {
        border-color: var(--line-strong);
        background: rgba(14, 26, 20, 0.94);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--accent);
      }

      .eyebrow::before {
        content: '';
        width: 28px;
        height: 1px;
        background: currentColor;
        opacity: 0.7;
      }

      .rv {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 800ms ease, transform 800ms ease;
      }

      .rv.vis { opacity: 1; transform: translateY(0); }

      video:fullscreen,
      video:-webkit-full-screen {
        width: 100vw;
        height: 100vh;
        object-fit: contain;
        background: #000;
      }

      @keyframes auroraDrift {
        0% {
          transform: translate3d(-2%, -1%, 0) scale(1);
        }

        50% {
          transform: translate3d(2%, 1%, 0) scale(1.06);
        }

        100% {
          transform: translate3d(-1%, 3%, 0) scale(1.02);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        body::after { animation: none; }
        .rv {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    
    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('vis'); io.unobserve(e.target); }
        });
      }, { threshold: 0.06 });
      document.querySelectorAll('.rv').forEach(el => io.observe(el));

      const requestVideoFullscreen = async (element) => {
        if (!element) {
          return;
        }

        if (element.requestFullscreen) {
          await element.requestFullscreen();
          return;
        }

        if (element.webkitRequestFullscreen) {
          element.webkitRequestFullscreen();
        }
      };

      const exitVideoFullscreen = async () => {
        if (document.fullscreenElement && document.exitFullscreen) {
          await document.exitFullscreen();
          return;
        }

        if (document.webkitFullscreenElement && document.webkitExitFullscreen) {
          document.webkitExitFullscreen();
        }
      };

      document.querySelectorAll('[data-video-stage]').forEach((stage) => {
        const video = stage.querySelector('video');
        const button = stage.querySelector('[data-video-fullscreen]');

        if (!video) {
          return;
        }

        const syncState = () => {
          const isFullscreen =
            document.fullscreenElement === video || document.webkitFullscreenElement === video;

          stage.classList.toggle('is-fullscreen', isFullscreen);

          if (button) {
            button.textContent = isFullscreen ? 'Exit fullscreen' : 'Fullscreen';
          }
        };

        video.addEventListener('dblclick', () => {
          void requestVideoFullscreen(video);
        });

        button?.addEventListener('click', async () => {
          const isFullscreen =
            document.fullscreenElement === video || document.webkitFullscreenElement === video;

          if (isFullscreen) {
            await exitVideoFullscreen();
          } else {
            await requestVideoFullscreen(video);
          }
        });

        document.addEventListener('fullscreenchange', syncState);
        document.addEventListener('webkitfullscreenchange', syncState);
        syncState();
      });
    </script>
  </body>
</html>
