---
const presets = [
  {
    id: 'glass-cathedral',
    label: 'Glass Cathedral',
    caption: 'High-end shimmer with hollow resonant pockets and airy reflections.',
  },
  {
    id: 'subharmonic-rain',
    label: 'Subharmonic Rain',
    caption: 'Low-end droplets and descending pressure tails for darker textures.',
  },
  {
    id: 'neon-choir',
    label: 'Neon Choir',
    caption: 'Stacked harmonic bands that turn painted strokes into synthetic voices.',
  },
  {
    id: 'granular-drift',
    label: 'Granular Drift',
    caption: 'Cloud-like particles with broad diffusion and unstable spectral motion.',
  },
];

const defaultPreset = presets[0];
---

<section class="spectral-lab w" data-spectral-lab data-presets={JSON.stringify(presets)}>
  <div class="spectral-lab__head rv">
    <div>
      <div class="eyebrow">Spectral Lab</div>
      <h2>Generate audio by painting and diffusing a spectrogram.</h2>
      <p>
        Draw directly on the time-frequency grid, run a procedural diffusion pass, then
        resynthesize stereo audio and download a WAV file without leaving the browser.
      </p>
    </div>
    <div class="spectral-lab__badges">
      <span>DJ Automata</span>
      <span>Client-side</span>
      <span>Web Audio</span>
      <span>WAV export</span>
    </div>
  </div>

  <div class="spectral-lab__grid">
    <article class="spectral-lab__workspace rv">
      <div class="spectral-lab__workspace-head">
        <div>
          <span class="spectral-lab__kicker">Visual spectrogram field</span>
          <h3>Paint energy across time and frequency.</h3>
        </div>
        <p>Drag to paint. Hold <kbd>Alt</kbd> or right-click to erase.</p>
      </div>

      <div class="spectral-lab__canvas-shell">
        <canvas
          class="spectral-lab__canvas"
          data-spectrum-canvas
          width="900"
          height="560"
          aria-label="Editable spectrogram"
        ></canvas>
        <div class="spectral-lab__axis spectral-lab__axis--vertical" aria-hidden="true">
          <span>High</span>
          <span>Low</span>
        </div>
        <div class="spectral-lab__axis spectral-lab__axis--horizontal" aria-hidden="true">
          <span>Attack</span>
          <span>Release</span>
        </div>
      </div>

      <div class="spectral-lab__legend">
        <span>Frequency</span>
        <div aria-hidden="true"></div>
        <span>Time</span>
      </div>
    </article>

    <aside class="spectral-lab__sidebar">
      <article class="spectral-lab__panel rv">
        <div class="spectral-lab__panel-head">
          <span class="spectral-lab__kicker">Seed + Diffuse</span>
          <h3>Shape the field before rendering.</h3>
        </div>

        <label class="spectral-lab__field">
          <span>Preset</span>
          <select data-preset-select>
            {presets.map((preset) => (
              <option value={preset.id} selected={preset.id === defaultPreset.id}>
                {preset.label}
              </option>
            ))}
          </select>
        </label>

        <p class="spectral-lab__caption" data-preset-caption>{defaultPreset.caption}</p>

        <div class="spectral-lab__slider-grid">
          <label class="spectral-lab__field">
            <span>Brush radius</span>
            <div class="spectral-lab__slider-row">
              <input data-brush-size type="range" min="1" max="8" step="1" value="3" />
              <strong data-brush-size-readout>3</strong>
            </div>
          </label>

          <label class="spectral-lab__field">
            <span>Diffusion amount</span>
            <div class="spectral-lab__slider-row">
              <input data-diffusion-amount type="range" min="0.1" max="0.9" step="0.01" value="0.34" />
              <strong data-diffusion-readout>0.34</strong>
            </div>
          </label>

          <label class="spectral-lab__field">
            <span>Diffusion passes</span>
            <div class="spectral-lab__slider-row">
              <input data-diffusion-passes type="range" min="1" max="8" step="1" value="3" />
              <strong data-passes-readout>3</strong>
            </div>
          </label>

          <label class="spectral-lab__field">
            <span>Clip length</span>
            <div class="spectral-lab__slider-row">
              <input data-duration-seconds type="range" min="2" max="8" step="0.5" value="4" />
              <strong data-duration-readout>4.0s</strong>
            </div>
          </label>
        </div>

        <div class="spectral-lab__button-grid">
          <button type="button" class="btn btn--p" data-seed-button>Seed preset</button>
          <button type="button" class="btn btn--g" data-diffuse-button>Diffuse field</button>
          <button type="button" class="btn btn--g" data-clear-button>Clear canvas</button>
        </div>
      </article>

      <article class="spectral-lab__panel rv">
        <div class="spectral-lab__panel-head">
          <span class="spectral-lab__kicker">Render + Export</span>
          <h3>Listen to the current spectrogram.</h3>
        </div>

        <canvas
          class="spectral-lab__waveform"
          data-waveform-canvas
          width="560"
          height="180"
          aria-label="Audio waveform preview"
        ></canvas>

        <div class="spectral-lab__button-grid spectral-lab__button-grid--dense">
          <button type="button" class="btn btn--p" data-render-button>Render audio</button>
          <button type="button" class="btn btn--g" data-play-button disabled>Play</button>
          <button type="button" class="btn btn--g" data-download-button disabled>Download WAV</button>
        </div>

        <p class="spectral-lab__status" data-status>
          Paint or seed the grid, then render a stereo preview.
        </p>

        <div class="spectral-lab__stats">
          <div>
            <span>Energy</span>
            <strong data-energy-readout>0.00</strong>
          </div>
          <div>
            <span>Active bins</span>
            <strong data-bins-readout>0</strong>
          </div>
          <div>
            <span>Peak</span>
            <strong data-peak-readout>Pending</strong>
          </div>
        </div>
      </article>

      <article class="spectral-lab__panel spectral-lab__panel--live rv">
        <div class="spectral-lab__panel-head">
          <div>
            <span class="spectral-lab__kicker">DJ Automata</span>
            <h3>Infinite ambient avant-garde broadcast.</h3>
          </div>
          <p class="spectral-lab__caption">
            One click arms a live set that keeps reseeding, diffusing, and crossfading itself in-browser.
          </p>
        </div>

        <div class="spectral-lab__live-row">
          <span class="spectral-lab__live-pill" data-live-pill>Off air</span>
          <strong class="spectral-lab__live-readout" data-live-readout>
            Idle. Arm DJ Automata to keep the room in motion.
          </strong>
        </div>

        <div class="spectral-lab__slider-grid">
          <label class="spectral-lab__field">
            <span>Mutation temperature</span>
            <div class="spectral-lab__slider-row">
              <input data-live-temperature type="range" min="0.15" max="1" step="0.01" value="0.58" />
              <strong data-live-temperature-readout>0.58</strong>
            </div>
          </label>

          <label class="spectral-lab__field">
            <span>Preset gravity</span>
            <div class="spectral-lab__slider-row">
              <input data-live-gravity type="range" min="0" max="1" step="0.01" value="0.42" />
              <strong data-live-gravity-readout>0.42</strong>
            </div>
          </label>
        </div>

        <div class="spectral-lab__button-grid spectral-lab__button-grid--live">
          <button type="button" class="btn btn--p" data-live-start-button>Start live set</button>
          <button type="button" class="btn btn--g" data-live-stop-button disabled>Stop broadcast</button>
        </div>

        <div class="spectral-lab__stats spectral-lab__stats--live">
          <div>
            <span>Scenes</span>
            <strong data-live-scenes-readout>0</strong>
          </div>
          <div>
            <span>Current preset</span>
            <strong data-live-preset-readout>{defaultPreset.label}</strong>
          </div>
          <div>
            <span>Mode</span>
            <strong data-live-mode-readout>Drifting</strong>
          </div>
        </div>
      </article>

      <article class="spectral-lab__panel rv" id="how-it-works">
        <div class="spectral-lab__panel-head">
          <span class="spectral-lab__kicker">How it works</span>
          <h3>Procedural diffusion, then additive resynthesis.</h3>
        </div>

        <ol class="spectral-lab__steps">
          <li>
            <strong>1. Seed or paint</strong>
            <span>Each cell holds spectral energy for one frequency band at one time slice.</span>
          </li>
          <li>
            <strong>2. Diffuse</strong>
            <span>Blur, drift, and small jitter spread the image forward like a visual diffusion field.</span>
          </li>
          <li>
            <strong>3. Resynthesize</strong>
            <span>The browser converts the field into stereo sine partials and packages a WAV for export.</span>
          </li>
        </ol>

        <p class="spectral-lab__footnote">
          This is intentionally local and deterministic: no uploads, no server render, no hidden model call.
        </p>
      </article>
    </aside>
  </div>
</section>

<style>
  .spectral-lab {
    padding: 32px 0 120px;
  }

  .spectral-lab__head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 24px;
    margin-bottom: 28px;
  }

  .spectral-lab__head h2 {
    margin-top: 16px;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    letter-spacing: -0.05em;
  }

  .spectral-lab__head p {
    max-width: 760px;
    margin-top: 14px;
    color: var(--muted);
    font-size: 1.04rem;
    display: none;
  }

  .spectral-lab__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .spectral-lab__badges span,
  .spectral-lab__kicker {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #f3ffd5;
    background: rgba(255, 255, 255, 0.03);
  }

  .spectral-lab__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(340px, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .spectral-lab__workspace,
  .spectral-lab__panel {
    border: 1px solid rgba(225, 255, 171, 0.16);
    border-radius: 30px;
    background:
      linear-gradient(180deg, rgba(132, 246, 197, 0.05), rgba(255, 255, 255, 0)),
      rgba(8, 15, 12, 0.94);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
    position: relative;
    overflow: hidden;
  }

  .spectral-lab__workspace::before,
  .spectral-lab__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.02) 42%, rgba(255, 255, 255, 0.12) 50%, transparent 58%),
      repeating-linear-gradient(180deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 3px);
    mix-blend-mode: screen;
    opacity: 0.3;
    pointer-events: none;
    animation: spectralPanelSweep 12s linear infinite;
  }

  .spectral-lab__workspace {
    padding: 24px;
  }

  .spectral-lab__sidebar {
    display: grid;
    gap: 20px;
  }

  .spectral-lab__panel {
    padding: 22px;
  }

  .spectral-lab__panel--live {
    background:
      radial-gradient(circle at top left, rgba(75, 243, 255, 0.1), transparent 18rem),
      radial-gradient(circle at top right, rgba(255, 91, 134, 0.12), transparent 18rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
      rgba(8, 15, 12, 0.96);
  }

  .spectral-lab__workspace-head,
  .spectral-lab__panel-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: start;
  }

  .spectral-lab__workspace-head h3,
  .spectral-lab__panel-head h3 {
    margin-top: 14px;
    font-size: 1.4rem;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    background: linear-gradient(180deg, #ffffff 0%, #d5ff8b 34%, #5ff2ff 68%, #ff89b0 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow:
      0 0 28px rgba(95, 242, 255, 0.12),
      0 0 24px rgba(255, 137, 176, 0.12);
  }

  .spectral-lab__workspace-head p,
  .spectral-lab__caption,
  .spectral-lab__status,
  .spectral-lab__footnote {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .spectral-lab__workspace-head p,
  .spectral-lab__caption,
  .spectral-lab__footnote,
  .spectral-lab__steps span {
    display: none;
  }

  .spectral-lab__canvas-shell {
    position: relative;
    margin-top: 22px;
    padding: 20px;
    border-radius: 28px;
    background:
      radial-gradient(circle at top, rgba(197, 255, 111, 0.06), transparent 44%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.005));
    border: 1px solid rgba(225, 255, 171, 0.14);
  }

  .spectral-lab__canvas-shell::before {
    content: '';
    position: absolute;
    inset: 10% 12%;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(255, 255, 255, 0.86) 0%, rgba(95, 242, 255, 0.24) 16%, rgba(255, 137, 176, 0.16) 28%, rgba(9, 17, 13, 0) 62%),
      repeating-radial-gradient(circle, rgba(255, 255, 255, 0.08) 0 2px, rgba(255, 255, 255, 0) 2px 9px);
    mix-blend-mode: screen;
    opacity: 0.18;
    pointer-events: none;
    animation: spectralPortal 14s ease-in-out infinite alternate;
  }

  .spectral-lab__canvas,
  .spectral-lab__waveform {
    width: 100%;
    display: block;
    border-radius: 20px;
    background:
      radial-gradient(circle at top left, rgba(132, 246, 197, 0.04), transparent 38%),
      #030806;
    border: 1px solid rgba(225, 255, 171, 0.12);
  }

  .spectral-lab__canvas {
    aspect-ratio: 16 / 10;
    cursor: crosshair;
    touch-action: none;
  }

  .spectral-lab__waveform {
    margin-top: 18px;
    aspect-ratio: 16 / 5;
  }

  .spectral-lab__axis {
    position: absolute;
    display: flex;
    color: rgba(247, 255, 240, 0.72);
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .spectral-lab__axis--vertical {
    top: 24px;
    bottom: 24px;
    left: 8px;
    flex-direction: column;
    justify-content: space-between;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .spectral-lab__axis--horizontal {
    right: 24px;
    bottom: 6px;
    left: 24px;
    justify-content: space-between;
  }

  .spectral-lab__legend {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 16px;
    color: rgba(247, 255, 240, 0.76);
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .spectral-lab__legend div {
    flex: 1;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(90deg, #4bf3ff 0%, #a5ff80 32%, #ffd26c 62%, #ff4f7f 100%);
  }

  .spectral-lab__field {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .spectral-lab__field span {
    color: var(--text);
    font-size: 0.94rem;
  }

  .spectral-lab__field select,
  .spectral-lab__field input[type='range'] {
    width: 100%;
  }

  .spectral-lab__field select {
    min-height: 48px;
    padding: 0 16px;
    color: var(--text);
    background: rgba(5, 12, 10, 0.88);
    border: 1px solid rgba(225, 255, 171, 0.16);
    border-radius: 16px;
    outline: none;
  }

  .spectral-lab__field input[type='range'] {
    accent-color: var(--accent);
  }

  .spectral-lab__slider-grid {
    display: grid;
    gap: 10px;
  }

  .spectral-lab__slider-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
  }

  .spectral-lab__slider-row strong {
    min-width: 48px;
    text-align: right;
    color: #efffbf;
    font-family: var(--mono);
    font-size: 0.9rem;
  }

  .spectral-lab__button-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 20px;
  }

  .spectral-lab__button-grid--dense {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .spectral-lab__button-grid--live {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .spectral-lab__button-grid .btn {
    width: 100%;
    min-height: 46px;
  }

  .spectral-lab__live-row {
    display: grid;
    gap: 12px;
    margin-top: 18px;
    padding: 16px 18px;
    border-radius: 22px;
    border: 1px solid rgba(225, 255, 171, 0.16);
    background: rgba(7, 14, 11, 0.88);
  }

  .spectral-lab__live-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    border: 1px solid rgba(225, 255, 171, 0.16);
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.76rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: rgba(5, 12, 10, 0.82);
  }

  .spectral-lab__live-pill.is-live {
    border-color: rgba(255, 91, 134, 0.46);
    background: rgba(255, 91, 134, 0.14);
    color: #ffd6e2;
    box-shadow: 0 0 28px rgba(255, 91, 134, 0.22);
    animation: spectralLivePulse 1.8s ease-in-out infinite;
  }

  .spectral-lab__live-readout {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: -0.02em;
  }

  .spectral-lab__status {
    margin-top: 14px;
    min-height: 1.5em;
  }

  .spectral-lab__stats--live {
    margin-top: 18px;
  }

  .spectral-lab__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .spectral-lab__stats div {
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(225, 255, 171, 0.14);
    background: rgba(7, 14, 11, 0.86);
  }

  .spectral-lab__stats span {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .spectral-lab__stats strong {
    display: block;
    margin-top: 8px;
    color: var(--text);
    font-size: 1.05rem;
    letter-spacing: -0.03em;
  }

  .spectral-lab__steps {
    list-style: none;
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .spectral-lab__steps li {
    display: grid;
    gap: 6px;
    padding: 14px 16px;
    border-radius: 18px;
    border: 1px solid rgba(225, 255, 171, 0.14);
    background: rgba(7, 14, 11, 0.86);
  }

  .spectral-lab__steps strong {
    color: var(--text);
  }

  .spectral-lab__steps span {
    color: var(--muted);
    font-size: 0.93rem;
  }

  .spectral-lab__footnote {
    margin-top: 16px;
  }

  @keyframes spectralLivePulse {
    0%,
    100% {
      transform: scale(1);
      box-shadow: 0 0 24px rgba(255, 91, 134, 0.18);
    }

    50% {
      transform: scale(1.03);
      box-shadow: 0 0 36px rgba(255, 91, 134, 0.3);
    }
  }

  @keyframes spectralPanelSweep {
    0% {
      transform: translateX(-32%);
    }

    100% {
      transform: translateX(132%);
    }
  }

  @keyframes spectralPortal {
    0% {
      transform: scale(0.94) translateY(-8px);
      opacity: 0.18;
    }

    100% {
      transform: scale(1.04) translateY(10px);
      opacity: 0.34;
    }
  }

  kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.8em;
    min-height: 1.8em;
    padding: 0 0.4em;
    border-radius: 0.5em;
    border: 1px solid rgba(225, 255, 171, 0.16);
    background: rgba(5, 12, 10, 0.84);
    color: var(--text);
  }

  @media (max-width: 1100px) {
    .spectral-lab__grid,
    .spectral-lab__button-grid,
    .spectral-lab__stats {
      grid-template-columns: 1fr;
    }

    .spectral-lab__head,
    .spectral-lab__workspace-head,
    .spectral-lab__panel-head {
      flex-direction: column;
      align-items: start;
    }
  }

  @media (max-width: 720px) {
    .spectral-lab {
      padding-bottom: 80px;
    }

    .spectral-lab__workspace,
    .spectral-lab__panel {
      border-radius: 24px;
      padding: 18px;
    }

    .spectral-lab__canvas-shell {
      padding: 14px;
      border-radius: 22px;
    }
  }
</style>

<script>
  import {
    GRID_HEIGHT,
    GRID_WIDTH,
    createEmptyGrid,
    diffuseGrid,
    encodeWav,
    paintGrid,
    renderGridToStereo,
    seedPreset,
  } from '../lib/spectrogramSynth.js';

  const root = document.querySelector('[data-spectral-lab]');

  if (root) {
    const presets = JSON.parse(root.dataset.presets || '[]');
    const palette = Array.from({ length: 256 }, (_, index) => {
      const ratio = index / 255;
      const hue = 210 - ratio * 190;
      const saturation = 68 + ratio * 18;
      const lightness = 8 + ratio * 58;
      return `hsl(${hue} ${saturation}% ${lightness}%)`;
    });
    const canvas = root.querySelector('[data-spectrum-canvas]');
    const canvasContext = canvas?.getContext('2d');
    const waveformCanvas = root.querySelector('[data-waveform-canvas]');
    const waveformContext = waveformCanvas?.getContext('2d');
    const presetSelect = root.querySelector('[data-preset-select]');
    const presetCaption = root.querySelector('[data-preset-caption]');
    const brushInput = root.querySelector('[data-brush-size]');
    const brushReadout = root.querySelector('[data-brush-size-readout]');
    const diffusionInput = root.querySelector('[data-diffusion-amount]');
    const diffusionReadout = root.querySelector('[data-diffusion-readout]');
    const passesInput = root.querySelector('[data-diffusion-passes]');
    const passesReadout = root.querySelector('[data-passes-readout]');
    const durationInput = root.querySelector('[data-duration-seconds]');
    const durationReadout = root.querySelector('[data-duration-readout]');
    const seedButton = root.querySelector('[data-seed-button]');
    const diffuseButton = root.querySelector('[data-diffuse-button]');
    const clearButton = root.querySelector('[data-clear-button]');
    const renderButton = root.querySelector('[data-render-button]');
    const playButton = root.querySelector('[data-play-button]');
    const downloadButton = root.querySelector('[data-download-button]');
    const liveTemperatureInput = root.querySelector('[data-live-temperature]');
    const liveTemperatureReadout = root.querySelector('[data-live-temperature-readout]');
    const liveGravityInput = root.querySelector('[data-live-gravity]');
    const liveGravityReadout = root.querySelector('[data-live-gravity-readout]');
    const liveStartButton = root.querySelector('[data-live-start-button]');
    const liveStopButton = root.querySelector('[data-live-stop-button]');
    const livePill = root.querySelector('[data-live-pill]');
    const liveReadout = root.querySelector('[data-live-readout]');
    const liveScenesReadout = root.querySelector('[data-live-scenes-readout]');
    const livePresetReadout = root.querySelector('[data-live-preset-readout]');
    const liveModeReadout = root.querySelector('[data-live-mode-readout]');
    const status = root.querySelector('[data-status]');
    const energyReadout = root.querySelector('[data-energy-readout]');
    const binsReadout = root.querySelector('[data-bins-readout]');
    const peakReadout = root.querySelector('[data-peak-readout]');
    const defaultPresetId = presetSelect?.value || presets[0]?.id || 'glass-cathedral';

    const state = {
      grid: seedPreset(defaultPresetId),
      audioContext: null,
      audioBuffer: null,
      blobUrl: '',
      sourceNode: null,
      renderResult: null,
      isPointerDown: false,
      seedCounter: 1,
      liveModeEnabled: false,
      liveVoices: [],
      liveMasterGain: null,
      liveTimerId: 0,
      liveHudId: 0,
      liveScheduledUntil: 0,
      liveSegmentIndex: 0,
      liveStartedAt: 0,
      livePresetCursor: Math.max(
        0,
        presets.findIndex((preset) => preset.id === defaultPresetId),
      ),
      liveCurrentPreset: defaultPresetId,
      livePhaseLabel: 'Drifting',
      isLiveQueueing: false,
    };

    function clamp(value, min = 0, max = 1) {
      return Math.min(max, Math.max(min, value));
    }

    function createPrng(seed) {
      let current = seed >>> 0 || 1;

      return () => {
        current += 0x6d2b79f5;
        let next = current;
        next = Math.imul(next ^ (next >>> 15), next | 1);
        next ^= next + Math.imul(next ^ (next >>> 7), next | 61);
        return ((next ^ (next >>> 14)) >>> 0) / 4294967296;
      };
    }

    function blendGrids(base, overlay, amount) {
      const mix = clamp(amount);
      const next = new Float32Array(base.length);

      for (let index = 0; index < base.length; index += 1) {
        next[index] = clamp(base[index] * (1 - mix) + overlay[index] * mix);
      }

      return next;
    }

    function setStatus(message) {
      if (status) {
        status.textContent = message;
      }
    }

    function getPresetMeta(id) {
      return presets.find((preset) => preset.id === id);
    }

    function getPresetLabel(id) {
      return getPresetMeta(id)?.label || id || 'Unknown';
    }

    function syncReadouts() {
      if (brushReadout && brushInput) {
        brushReadout.textContent = brushInput.value;
      }

      if (diffusionReadout && diffusionInput) {
        diffusionReadout.textContent = Number(diffusionInput.value).toFixed(2);
      }

      if (passesReadout && passesInput) {
        passesReadout.textContent = passesInput.value;
      }

      if (durationReadout && durationInput) {
        durationReadout.textContent = `${Number(durationInput.value).toFixed(1)}s`;
      }

      if (presetCaption && presetSelect) {
        presetCaption.textContent = getPresetMeta(presetSelect.value)?.caption || '';
      }

      if (liveTemperatureReadout && liveTemperatureInput) {
        liveTemperatureReadout.textContent = Number(liveTemperatureInput.value).toFixed(2);
      }

      if (liveGravityReadout && liveGravityInput) {
        liveGravityReadout.textContent = Number(liveGravityInput.value).toFixed(2);
      }
    }

    function syncTransportButtons() {
      if (playButton) {
        if (state.liveModeEnabled) {
          playButton.disabled = true;
          playButton.textContent = 'Live on air';
        } else {
          playButton.disabled = !state.audioBuffer;
          playButton.textContent = state.sourceNode ? 'Stop' : 'Play';
        }
      }

      if (downloadButton) {
        downloadButton.disabled = !state.blobUrl;
      }

      if (liveStartButton) {
        liveStartButton.disabled = state.liveModeEnabled;
      }

      if (liveStopButton) {
        liveStopButton.disabled = !state.liveModeEnabled;
      }
    }

    function formatElapsed(seconds) {
      const total = Math.max(0, Math.floor(seconds));
      const minutes = Math.floor(total / 60);
      const remainder = total % 60;
      return `${String(minutes).padStart(2, '0')}:${String(remainder).padStart(2, '0')}`;
    }

    function updateLiveUi() {
      if (livePill) {
        livePill.textContent = state.liveModeEnabled ? 'On air' : 'Off air';
        livePill.classList.toggle('is-live', state.liveModeEnabled);
      }

      if (liveScenesReadout) {
        liveScenesReadout.textContent = String(state.liveSegmentIndex);
      }

      if (livePresetReadout) {
        livePresetReadout.textContent = getPresetLabel(state.liveCurrentPreset);
      }

      if (liveModeReadout) {
        liveModeReadout.textContent = state.livePhaseLabel;
      }

      if (liveReadout) {
        if (state.liveModeEnabled) {
          const elapsed = (performance.now() - state.liveStartedAt) / 1000;
          liveReadout.textContent = `${formatElapsed(elapsed)} on air · scene ${state.liveSegmentIndex} · ${getPresetLabel(state.liveCurrentPreset)}`;
        } else {
          liveReadout.textContent = 'Idle. Arm DJ Automata to keep the room in motion.';
        }
      }
    }

    function updateEnergyStats() {
      let energy = 0;
      let activeBins = 0;

      for (const value of state.grid) {
        energy += value;
        if (value > 0.16) {
          activeBins += 1;
        }
      }

      if (energyReadout) {
        energyReadout.textContent = (energy / state.grid.length).toFixed(2);
      }

      if (binsReadout) {
        binsReadout.textContent = String(activeBins);
      }
    }

    function drawCanvasGrid() {
      if (!canvasContext || !canvas) {
        return;
      }

      const cellWidth = canvas.width / GRID_WIDTH;
      const cellHeight = canvas.height / GRID_HEIGHT;

      canvasContext.clearRect(0, 0, canvas.width, canvas.height);
      canvasContext.fillStyle = '#040907';
      canvasContext.fillRect(0, 0, canvas.width, canvas.height);

      for (let y = 0; y < GRID_HEIGHT; y += 1) {
        for (let x = 0; x < GRID_WIDTH; x += 1) {
          const intensity = state.grid[y * GRID_WIDTH + x];
          const paletteIndex = Math.max(0, Math.min(255, Math.round(intensity * 255)));
          canvasContext.fillStyle = palette[paletteIndex];
          canvasContext.fillRect(x * cellWidth, y * cellHeight, cellWidth + 0.75, cellHeight + 0.75);
        }
      }

      canvasContext.strokeStyle = 'rgba(255, 255, 255, 0.06)';
      canvasContext.lineWidth = 1;

      for (let row = 0; row <= GRID_HEIGHT; row += 6) {
        const y = row * cellHeight;
        canvasContext.beginPath();
        canvasContext.moveTo(0, y);
        canvasContext.lineTo(canvas.width, y);
        canvasContext.stroke();
      }

      for (let column = 0; column <= GRID_WIDTH; column += 6) {
        const x = column * cellWidth;
        canvasContext.beginPath();
        canvasContext.moveTo(x, 0);
        canvasContext.lineTo(x, canvas.height);
        canvasContext.stroke();
      }
    }

    function drawWaveform(samples) {
      if (!waveformContext || !waveformCanvas) {
        return;
      }

      waveformContext.clearRect(0, 0, waveformCanvas.width, waveformCanvas.height);
      waveformContext.fillStyle = '#040907';
      waveformContext.fillRect(0, 0, waveformCanvas.width, waveformCanvas.height);

      const gradient = waveformContext.createLinearGradient(0, 0, waveformCanvas.width, 0);
      gradient.addColorStop(0, '#4bf3ff');
      gradient.addColorStop(0.45, '#b2ff7d');
      gradient.addColorStop(1, '#ff5b86');

      waveformContext.strokeStyle = 'rgba(255, 255, 255, 0.08)';
      waveformContext.lineWidth = 1;
      waveformContext.beginPath();
      waveformContext.moveTo(0, waveformCanvas.height / 2);
      waveformContext.lineTo(waveformCanvas.width, waveformCanvas.height / 2);
      waveformContext.stroke();

      if (!samples) {
        waveformContext.fillStyle = 'rgba(255, 255, 255, 0.6)';
        waveformContext.font = '16px IBM Plex Mono';
        waveformContext.fillText('Render audio to preview the waveform.', 24, waveformCanvas.height / 2 + 6);
        return;
      }

      waveformContext.strokeStyle = gradient;
      waveformContext.lineWidth = 2.2;
      waveformContext.beginPath();

      const midline = waveformCanvas.height / 2;
      const bucketSize = Math.max(1, Math.floor(samples.length / waveformCanvas.width));

      for (let x = 0; x < waveformCanvas.width; x += 1) {
        let peak = 0;

        for (let sample = 0; sample < bucketSize; sample += 1) {
          const value = samples[Math.min(samples.length - 1, x * bucketSize + sample)];
          peak = Math.max(peak, Math.abs(value));
        }

        const y = midline - peak * (waveformCanvas.height * 0.38);

        if (x === 0) {
          waveformContext.moveTo(x, y);
        } else {
          waveformContext.lineTo(x, y);
        }
      }

      for (let x = waveformCanvas.width - 1; x >= 0; x -= 1) {
        let peak = 0;

        for (let sample = 0; sample < bucketSize; sample += 1) {
          const value = samples[Math.min(samples.length - 1, x * bucketSize + sample)];
          peak = Math.max(peak, Math.abs(value));
        }

        const y = midline + peak * (waveformCanvas.height * 0.38);
        waveformContext.lineTo(x, y);
      }

      waveformContext.closePath();
      waveformContext.fillStyle = 'rgba(132, 246, 197, 0.16)';
      waveformContext.fill();
      waveformContext.stroke();
    }

    function refreshUi() {
      syncReadouts();
      updateEnergyStats();
      drawCanvasGrid();
      drawWaveform(state.renderResult?.left || null);
      updateLiveUi();
      syncTransportButtons();
    }

    function invalidateRender() {
      state.renderResult = null;
      state.audioBuffer = null;

      if (state.blobUrl) {
        URL.revokeObjectURL(state.blobUrl);
        state.blobUrl = '';
      }

      if (peakReadout) {
        peakReadout.textContent = 'Pending';
      }
    }

    function stopPlayback() {
      if (state.sourceNode) {
        state.sourceNode.onended = null;
        state.sourceNode.stop();
        state.sourceNode.disconnect();
        state.sourceNode = null;
      }
    }

    async function ensureAudioContext() {
      if (!state.audioContext) {
        const Constructor = window.AudioContext || window.webkitAudioContext;

        if (!Constructor) {
          throw new Error('Web Audio is not available in this browser.');
        }

        state.audioContext = new Constructor();
      }

      if (state.audioContext.state === 'suspended') {
        await state.audioContext.resume();
      }

      return state.audioContext;
    }

    function createAudioBuffer(audioContext, result) {
      const audioBuffer = audioContext.createBuffer(2, result.left.length, result.sampleRate);
      audioBuffer.copyToChannel(result.left, 0);
      audioBuffer.copyToChannel(result.right, 1);
      return audioBuffer;
    }

    function updateRenderedAssets(result, audioBuffer, fileStem = null) {
      state.audioBuffer = audioBuffer;
      state.renderResult = result;

      if (state.blobUrl) {
        URL.revokeObjectURL(state.blobUrl);
      }

      state.blobUrl = URL.createObjectURL(
        new Blob([encodeWav([result.left, result.right], result.sampleRate)], { type: 'audio/wav' }),
      );

      if (peakReadout) {
        peakReadout.textContent = result.peak.toFixed(2);
      }

      if (!fileStem && presetSelect) {
        return;
      }

      if (downloadButton && fileStem) {
        downloadButton.dataset.filename = fileStem;
      }
    }

    function eventToGridPoint(event) {
      const rect = canvas.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * GRID_WIDTH;
      const y = ((event.clientY - rect.top) / rect.height) * GRID_HEIGHT;
      return {
        x: Math.max(0, Math.min(GRID_WIDTH - 1, x)),
        y: Math.max(0, Math.min(GRID_HEIGHT - 1, y)),
      };
    }

    function applyBrush(event) {
      const { x, y } = eventToGridPoint(event);
      const isErase = event.altKey || event.button === 2 || event.buttons === 2;

      state.grid = paintGrid(state.grid, {
        x,
        y,
        radius: Number(brushInput?.value || 3),
        mode: isErase ? 'erase' : 'paint',
      });
      invalidateRender();
      refreshUi();
    }

    async function renderAudio() {
      setStatus('Rendering the current void-state into stereo audio...');
      renderButton?.setAttribute('disabled', 'true');
      stopPlayback();
      await new Promise((resolve) => window.requestAnimationFrame(resolve));

      try {
        const audioContext = await ensureAudioContext();
        const result = renderGridToStereo(state.grid, {
          durationSeconds: Number(durationInput?.value || 4),
        });
        const audioBuffer = createAudioBuffer(audioContext, result);
        updateRenderedAssets(result, audioBuffer);
        refreshUi();
        setStatus(`Ready: ${result.durationSeconds.toFixed(1)}s of spectral output at ${result.sampleRate} Hz.`);
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Audio rendering failed.';
        setStatus(message);
      } finally {
        renderButton?.removeAttribute('disabled');
      }
    }

    function evolveAutomataGrid() {
      const temperature = Number(liveTemperatureInput?.value || 0.58);
      const gravity = Number(liveGravityInput?.value || 0.42);
      const seed = state.seedCounter + state.liveSegmentIndex + 1;
      const random = createPrng(seed * 2654435761);
      let next = new Float32Array(state.grid);
      const shouldAnchorPreset = state.liveSegmentIndex === 0 || random() < 0.22 + gravity * 0.42;

      if (shouldAnchorPreset && presets.length > 0) {
        const jump = 1 + Math.floor(random() * presets.length);
        state.livePresetCursor = (state.livePresetCursor + jump) % presets.length;
        state.liveCurrentPreset = presets[state.livePresetCursor]?.id || defaultPresetId;
        const anchorGrid = seedPreset(state.liveCurrentPreset, {
          seed,
          brightness: 0.78 + random() * 0.36,
        });
        next = blendGrids(next, anchorGrid, 0.22 + gravity * 0.44);
        state.livePhaseLabel = random() > 0.5 ? 'Void anchor' : 'Preset collapse';
      } else {
        state.livePhaseLabel = random() > 0.5 ? 'Drift field' : 'Aether smear';
      }

      const accents = 3 + Math.floor(random() * (2 + temperature * 5));

      for (let index = 0; index < accents; index += 1) {
        const erase = random() < 0.18;
        const focusHigh = random() < 0.62;
        next = paintGrid(next, {
          x: random() * GRID_WIDTH,
          y: focusHigh ? random() * GRID_HEIGHT * 0.45 : GRID_HEIGHT * (0.42 + random() * 0.52),
          radius: 1 + random() * (1.8 + temperature * 4),
          intensity: 0.18 + random() * (0.32 + temperature * 0.38),
          mode: erase ? 'erase' : 'paint',
        });
      }

      next = diffuseGrid(next, {
        amount: 0.18 + temperature * 0.52,
        drift: 0.28 + temperature * 0.5,
        jitter: 0.012 + temperature * 0.032,
        decay: 0.005 + (1 - temperature) * 0.022,
        passes: 1 + Math.floor(random() * (2 + temperature * 4)),
        seed,
      });

      state.seedCounter = seed;
      state.liveCurrentPreset = state.liveCurrentPreset || presetSelect?.value || defaultPresetId;

      if (presetSelect && getPresetMeta(state.liveCurrentPreset)) {
        presetSelect.value = state.liveCurrentPreset;
      }

      return next;
    }

    function stopLiveBroadcast({ quiet = false } = {}) {
      if (state.liveTimerId) {
        window.clearTimeout(state.liveTimerId);
        state.liveTimerId = 0;
      }

      if (state.liveHudId) {
        window.clearInterval(state.liveHudId);
        state.liveHudId = 0;
      }

      for (const voice of state.liveVoices) {
        voice.source.onended = null;
        try {
          voice.source.stop();
        } catch {}
        voice.source.disconnect();
        voice.gain.disconnect();
      }

      state.liveVoices = [];
      state.liveModeEnabled = false;
      state.liveScheduledUntil = 0;
      state.isLiveQueueing = false;
      state.livePhaseLabel = 'Drifting';

      if (!quiet) {
        setStatus('DJ Automata returned from the void. The last scene is still available to preview.');
      }

      refreshUi();
    }

    async function scheduleAutomataSegment(startAt) {
      const audioContext = await ensureAudioContext();

      if (!state.liveMasterGain) {
        state.liveMasterGain = audioContext.createGain();
        state.liveMasterGain.gain.value = 0.88;
        state.liveMasterGain.connect(audioContext.destination);
      }

      state.grid = evolveAutomataGrid();

      const result = renderGridToStereo(state.grid, {
        durationSeconds: Number(durationInput?.value || 4),
      });
      const audioBuffer = createAudioBuffer(audioContext, result);
      updateRenderedAssets(result, audioBuffer, 'dj-automata-live');

      const source = audioContext.createBufferSource();
      const gain = audioContext.createGain();
      source.buffer = audioBuffer;
      source.connect(gain);
      gain.connect(state.liveMasterGain);

      const overlap = Math.min(1.2, Math.max(0.32, result.durationSeconds * 0.18));
      const startTime = Math.max(audioContext.currentTime + 0.05, startAt);
      const endTime = startTime + result.durationSeconds;
      const fadeInEnd = Math.min(endTime - 0.08, startTime + overlap);
      const fadeOutStart = Math.max(fadeInEnd, endTime - overlap);

      gain.gain.setValueAtTime(0.0001, startTime);
      gain.gain.exponentialRampToValueAtTime(1, fadeInEnd);
      gain.gain.setValueAtTime(1, fadeOutStart);
      gain.gain.linearRampToValueAtTime(0.0001, endTime);

      source.start(startTime);
      source.stop(endTime + 0.05);

      const voice = { source, gain, stopAt: endTime + 0.05 };
      state.liveVoices.push(voice);
      source.onended = () => {
        state.liveVoices = state.liveVoices.filter((candidate) => candidate !== voice);
        source.disconnect();
        gain.disconnect();
      };

      state.liveSegmentIndex += 1;
      state.liveScheduledUntil = endTime - overlap * 0.68;
      refreshUi();

      return state.liveScheduledUntil;
    }

    async function queueAutomataSegments() {
      if (!state.liveModeEnabled || state.isLiveQueueing) {
        return;
      }

      state.isLiveQueueing = true;

      try {
        const audioContext = await ensureAudioContext();
        const horizon = audioContext.currentTime + 7;
        let cursor = state.liveScheduledUntil || audioContext.currentTime + 0.08;

        while (cursor < horizon && state.liveModeEnabled) {
          cursor = await scheduleAutomataSegment(cursor);
        }

        if (state.liveModeEnabled) {
          if (state.liveTimerId) {
            window.clearTimeout(state.liveTimerId);
          }

          const delayMs = Math.max(
            420,
            Math.min(1800, Math.round((cursor - audioContext.currentTime - 2.4) * 1000)),
          );

          state.liveTimerId = window.setTimeout(() => {
            void queueAutomataSegments();
          }, delayMs);
        }
      } catch (error) {
        const message =
          error instanceof Error ? error.message : 'DJ Automata failed to queue the next scene.';
        stopLiveBroadcast({ quiet: true });
        setStatus(message);
      } finally {
        state.isLiveQueueing = false;
      }
    }

    async function startLiveBroadcast() {
      if (state.liveModeEnabled) {
        return;
      }

      stopPlayback();
      await ensureAudioContext();

      state.liveModeEnabled = true;
      state.liveStartedAt = performance.now();
      state.liveSegmentIndex = 0;
      state.liveScheduledUntil = 0;
      state.liveCurrentPreset = presetSelect?.value || defaultPresetId;
      state.livePresetCursor = Math.max(
        0,
        presets.findIndex((preset) => preset.id === state.liveCurrentPreset),
      );
      state.livePhaseLabel = 'Void gate open';

      if (state.liveHudId) {
        window.clearInterval(state.liveHudId);
      }

      state.liveHudId = window.setInterval(updateLiveUi, 1000);
      setStatus('DJ Automata is on air. The room is now drifting through the void.');
      refreshUi();
      await queueAutomataSegments();
    }

    async function togglePlayback() {
      if (state.liveModeEnabled) {
        setStatus('DJ Automata is already on air. Stop the broadcast to preview the last isolated scene.');
        return;
      }

      if (state.sourceNode) {
        stopPlayback();
        refreshUi();
        return;
      }

      if (!state.audioBuffer) {
        setStatus('Render audio before playback.');
        return;
      }

      try {
        const audioContext = await ensureAudioContext();
        const source = audioContext.createBufferSource();
        source.buffer = state.audioBuffer;
        source.connect(audioContext.destination);
        source.onended = () => {
          if (state.sourceNode === source) {
            state.sourceNode = null;
            refreshUi();
          }
        };
        source.start();
        state.sourceNode = source;
        refreshUi();
      } catch (error) {
        const message = error instanceof Error ? error.message : 'Playback is unavailable.';
        setStatus(message);
      }
    }

    function downloadWav() {
      if (!state.blobUrl) {
        setStatus('Render audio before downloading a WAV.');
        return;
      }

      const anchor = document.createElement('a');
      anchor.href = state.blobUrl;
      const filename = downloadButton?.dataset.filename || `${presetSelect?.value || 'spectral-field'}`;
      anchor.download = `${filename}.wav`;
      anchor.click();
    }

    function reseedGrid() {
      state.seedCounter += 1;
      state.grid = seedPreset(presetSelect?.value || 'glass-cathedral', { seed: state.seedCounter });
      stopPlayback();
      invalidateRender();
      state.liveCurrentPreset = presetSelect?.value || defaultPresetId;
      setStatus('Preset field regenerated. Paint, diffuse, or throw DJ Automata back into the void from here.');
      refreshUi();
    }

    function clearGrid() {
      state.grid = createEmptyGrid();
      stopPlayback();
      invalidateRender();
      state.livePhaseLabel = 'Absolute void';
      setStatus('Canvas collapsed to void-state.');
      refreshUi();
    }

    function diffuseCurrentGrid() {
      state.seedCounter += 1;
      state.grid = diffuseGrid(state.grid, {
        amount: Number(diffusionInput?.value || 0.34),
        passes: Number(passesInput?.value || 3),
        seed: state.seedCounter,
      });
      stopPlayback();
      invalidateRender();
      state.livePhaseLabel = 'Field diffusion';
      setStatus('Field diffused. Render it or let DJ Automata keep pushing it deeper.');
      refreshUi();
    }

    canvas?.addEventListener('contextmenu', (event) => event.preventDefault());
    canvas?.addEventListener('pointerdown', (event) => {
      state.isPointerDown = true;
      canvas.setPointerCapture(event.pointerId);
      applyBrush(event);
    });
    canvas?.addEventListener('pointermove', (event) => {
      if (state.isPointerDown) {
        applyBrush(event);
      }
    });
    canvas?.addEventListener('pointerup', () => {
      state.isPointerDown = false;
    });
    canvas?.addEventListener('pointerleave', () => {
      state.isPointerDown = false;
    });

    presetSelect?.addEventListener('change', () => {
      state.liveCurrentPreset = presetSelect.value;
      state.livePresetCursor = Math.max(
        0,
        presets.findIndex((preset) => preset.id === presetSelect.value),
      );
      syncReadouts();
      updateLiveUi();
    });
    brushInput?.addEventListener('input', syncReadouts);
    diffusionInput?.addEventListener('input', syncReadouts);
    passesInput?.addEventListener('input', syncReadouts);
    durationInput?.addEventListener('input', syncReadouts);
    liveTemperatureInput?.addEventListener('input', syncReadouts);
    liveGravityInput?.addEventListener('input', syncReadouts);
    seedButton?.addEventListener('click', reseedGrid);
    diffuseButton?.addEventListener('click', diffuseCurrentGrid);
    clearButton?.addEventListener('click', clearGrid);
    renderButton?.addEventListener('click', renderAudio);
    playButton?.addEventListener('click', togglePlayback);
    downloadButton?.addEventListener('click', downloadWav);
    liveStartButton?.addEventListener('click', () => {
      void startLiveBroadcast();
    });
    liveStopButton?.addEventListener('click', () => {
      stopLiveBroadcast();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible' && state.liveModeEnabled) {
        void queueAutomataSegments();
      }
    });

    window.addEventListener('beforeunload', () => {
      stopLiveBroadcast({ quiet: true });
      stopPlayback();
      if (state.blobUrl) {
        URL.revokeObjectURL(state.blobUrl);
      }
    });

    refreshUi();
    setStatus('Seed a preset or paint directly into the spectrogram.');
  }
</script>
