---
interface Signal {
	index: string;
	label: string;
	title: string;
	body: string;
}

interface Props {
	signals: Signal[];
}

const { signals } = Astro.props;
---

<section class="signal-grid">
	{
		signals.map((card) => (
			<article class="signal-card surface">
				<div class="card-meta">
					<span class="card-index">{card.index}</span>
					<span class="surface-label">{card.label}</span>
				</div>
				<h2>{card.title}</h2>
				<p class="surface-copy">{card.body}</p>
			</article>
		))
	}
</section>
