---
interface FAQItem {
	question: string;
	answer: string;
}

interface Props {
	faqItems: FAQItem[];
}

const { faqItems } = Astro.props;
---

<section class="section-frame surface" id="faq">
	<div class="section-heading">
		<p class="section-kicker">FAQ</p>
		<h2>Short answers for technical buyers.</h2>
		<p>
			Keep the scope tight: integrity, traceability, and evidence readiness.
		</p>
	</div>

	<div class="faq-grid">
		{
			faqItems.map((item) => (
				<article class="faq-card surface-sunken">
					<h3>{item.question}</h3>
					<p>{item.answer}</p>
				</article>
			))
		}
	</div>
</section>
