include LICENSE
include README.md
include pyproject.toml
include config/tips.json
graft cortex
prune .github
prune build
prune cortex-sdk
prune dist
prune docs
prune docs_backup
prune experimental
prune node_modules
prune sdks
prune src
prune tests
prune worktrees
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude *.db
global-exclude *.db-wal
global-exclude *.db-shm
global-exclude *.sqlite
prune cortex/math_verification/cortex_math_lean/.lake
