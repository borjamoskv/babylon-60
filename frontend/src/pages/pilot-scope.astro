---
import IntakeFormScript from '../components/IntakeFormScript.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SUPPORT_EMAIL } from '../lib/intake';

const subject = 'CORTEX Pilot Scope';
const intakeLines = [
	{ label: 'Workflow', field: 'workflow' },
	{ label: 'Current stack', field: 'stack' },
	{ label: 'Sensitive data', field: 'sensitive' },
	{ label: 'Hosting model', field: 'hosting' },
	{ label: 'Target environment', field: 'environment' },
	{ label: 'Owner', field: 'owner' },
	{ label: 'Team size', field: 'teamsize' },
	{ label: 'Timeline pressure', field: 'timeline' },
	{ label: 'Success criteria', field: 'success' },
	{ label: 'Name', field: 'name' },
	{ label: 'Contact', field: 'contact' },
];

const processSteps = [
	{
		index: '01',
		title: 'You send',
		body: 'Workflow, stack, constraints, and what success looks like. This form drafts the email.',
		tag: 'Now',
		tagClass: 'live',
	},
	{
		index: '02',
		title: 'We scope',
		body: 'Async review of fit, risk level, and integration surface. No call needed.',
		tag: '24h',
		tagClass: 'audit',
	},
	{
		index: '03',
		title: 'You receive',
		body: 'Scoped pilot recommendation, pricing, timeline, and one clear next step.',
		tag: 'Reply',
		tagClass: 'live',
	},
];

const deliverables = [
	{
		title: 'Scoped recommendation',
		body: 'Which workflow to instrument first, why it is the best starting point, and what the integration surface looks like.',
		tag: 'Scope',
		tagClass: 'live',
	},
	{
		title: 'Pilot estimate',
		body: 'Fixed-price pilot proposal with timeline, deliverables, and constraints. No hidden fees, no scope creep.',
		tag: 'EUR',
		tagClass: 'audit',
	},
	{
		title: 'Risk assessment',
		body: 'Sensitive data, hosting model, and compliance surface mapped before kickoff, not after.',
		tag: 'Risk',
		tagClass: 'audit',
	},
	{
		title: 'Next step',
		body: 'Approve and kick off, or we ask for one missing detail. One email, one decision.',
		tag: 'Async',
		tagClass: 'live',
	},
];

const trustSignals = [
	{ value: 'Zero obligation', label: 'The scope is free. You only pay if you start the pilot.' },
	{ value: 'Open source core', label: 'Inspect the codebase before you commit. BSL 1.1 → Apache 2.0.' },
	{ value: 'No call required', label: 'The entire flow is async by email. You choose when to reply.' },
];

const faqItems = [
	{
		question: 'What if my workflow is hard to describe?',
		answer: 'Start with the one that would be most painful to explain to leadership if the agent misfired. We will ask for details if needed.',
	},
	{
		question: 'Is this a sales call in disguise?',
		answer: 'No. The scope is async by email. We reply with a recommendation, not a calendar link.',
	},
	{
		question: 'What if CORTEX is not a good fit?',
		answer: 'We will tell you. The scope costs us time, not you money. If the fit is weak, we say so in the reply.',
	},
	{
		question: 'Can I start with the open source version first?',
		answer: 'Yes. Install, evaluate, and scope the pilot later if you need support, integration, or an audit-pack for leadership.',
	},
];
---

<SiteLayout
	title="Get Pilot Scope | CORTEX Persist"
	description="Send your workflow, stack, and constraints to scope a CORTEX pilot asynchronously. Free scope, async reply, no call required."
	canonical="https://cortexpersist.com/pilot-scope"
>
	<main class="landing-shell intake-shell" id="top">
		<a class="intake-backlink" href="/">← Back to CORTEX Persist</a>

		<!-- HERO -->
		<section class="section-frame surface intake-hero">
			<div class="section-heading">
				<p class="section-kicker">Pilot Scope — Free, Async, No Obligation</p>
				<h1>Send one workflow. Get a scoped pilot recommendation.</h1>
				<p>
					Describe the workflow, stack, risk level, and hosting constraints. We reply
					within one business day with a concrete pilot proposal — pricing, timeline,
					and one clear next step. No call. No commitment.
				</p>
			</div>

			<div class="chip-row" aria-label="Pilot scope promises">
				<span class="chip">One workflow</span>
				<span class="chip">One environment</span>
				<span class="chip">Free scope</span>
				<span class="chip">Reply within 24h</span>
			</div>
		</section>

		<!-- PROCESS TIMELINE -->
		<section class="intake-process">
			{
				processSteps.map((step) => (
					<article class="process-step surface-sunken">
						<span class="step-index">{step.index}</span>
						<div>
							<strong>{step.title}</strong>
							<span>{step.body}</span>
						</div>
						<span class:list={['proof-tag', step.tagClass]}>{step.tag}</span>
					</article>
				))
			}
		</section>

		<!-- MAIN GRID: Form + Aside -->
		<section class="intake-grid">
			<section class="surface intake-panel">
				<div class="surface-head">
					<span class="surface-label">Scope inputs</span>
					<span class="surface-state">Pilot</span>
				</div>

				<form class="intake-form" data-intake-form data-subject={subject} data-email={SUPPORT_EMAIL} novalidate>
					<label class="field">
						<span>Workflow</span>
						<textarea
							name="workflow"
							rows="4"
							placeholder="Which workflow should the pilot instrument first? E.g. 'Refund approval flow — agent reads ticket, checks policy, approves or escalates.'"
							required
							aria-required="true"
						></textarea>
						<small class="field-hint">Start with the workflow where a misfire would be hardest to explain.</small>
					</label>

					<label class="field">
						<span>Current stack</span>
						<textarea
							name="stack"
							rows="4"
							placeholder="E.g. 'OpenAI GPT-4o + LangGraph + Postgres + Datadog. Memory: in-house vector store on Pinecone.'"
							required
							aria-required="true"
						></textarea>
						<small class="field-hint">Agent orchestration, memory layer, observability, APIs, repos, or relevant systems.</small>
					</label>

					<div class="field-grid">
						<label class="field">
							<span>Sensitive data</span>
							<select name="sensitive">
								<option>Yes — PII, financial, or regulated</option>
								<option>Yes — internal/proprietary</option>
								<option>No</option>
								<option selected>Not sure yet</option>
							</select>
						</label>

						<label class="field">
							<span>Hosting model</span>
							<select name="hosting">
								<option selected>Not sure yet</option>
								<option>Cloud (managed)</option>
								<option>Self-hosted (on-prem or private cloud)</option>
								<option>BYOC (bring your own cloud)</option>
								<option>Hybrid</option>
							</select>
						</label>
					</div>

					<div class="field-grid">
						<label class="field">
							<span>Target environment</span>
							<select name="environment">
								<option>Development</option>
								<option>Staging</option>
								<option>Production-like</option>
								<option selected>Not sure yet</option>
							</select>
						</label>

						<label class="field">
							<span>Owner</span>
							<select name="owner">
								<option>Engineering</option>
								<option>Platform / Infra</option>
								<option>Security / Compliance</option>
								<option>Leadership / CTO</option>
								<option selected>Not sure yet</option>
							</select>
						</label>
					</div>

					<div class="field-grid">
						<label class="field">
							<span>Team size (agents in production)</span>
							<select name="teamsize">
								<option>1–3 agents</option>
								<option>4–10 agents</option>
								<option>10+ agents</option>
								<option selected>Not sure yet</option>
							</select>
						</label>

						<label class="field">
							<span>Timeline pressure</span>
							<select name="timeline">
								<option>Urgent — need to show progress this quarter</option>
								<option>Planning — evaluating for next quarter</option>
								<option>Exploratory — no hard deadline</option>
								<option selected>Not sure yet</option>
							</select>
						</label>
					</div>

					<label class="field">
						<span>Success criteria</span>
						<textarea
							name="success"
							rows="4"
							placeholder="E.g. 'We need to prove to our CISO that every agent decision in the refund flow has an immutable, auditable record before Q3 board review.'"
							required
							aria-required="true"
						></textarea>
						<small class="field-hint">What would make the pilot clearly worth doing? Who needs to be convinced?</small>
					</label>

					<div class="field-grid">
						<label class="field">
							<span>Name</span>
							<input name="name" type="text" placeholder="Your name" />
						</label>
						<label class="field">
							<span>Email or company</span>
							<input name="contact" type="text" placeholder="you@company.com" />
						</label>
					</div>

					<div class="intake-actions">
						<button class="button-primary" type="submit">Open Email Draft</button>
						<button class="button-secondary" type="button" data-copy-intake>Copy Scope Brief</button>
					</div>

					<p class="microcopy">
						Required: workflow, current stack, and success criteria. Everything else helps us scope faster.
					</p>
					<p class="microcopy">
						This page drafts an email on your device. Nothing is submitted server-side from the browser.
					</p>
					<p class="microcopy">
						Prefer to write your own email? Send it to
						<a class="inline-link" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
					</p>
					<p class="intake-status" data-intake-status role="status" aria-live="polite" aria-atomic="true"></p>
				</form>
				<noscript>
					<p class="microcopy">
						JavaScript is off. Email your workflow, current stack, and success criteria
						directly to
						<a class="inline-link" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
					</p>
				</noscript>
			</section>

			<aside class="intake-aside">
				<!-- DELIVERABLES -->
				<section class="surface-sunken intake-panel">
					<div class="surface-head">
						<span class="surface-label">What we send back</span>
						<span class="surface-state">24h</span>
					</div>

					<div class="proof-stack">
						{
							deliverables.map((item) => (
								<div class="proof-item">
									<div>
										<strong>{item.title}</strong>
										<span>{item.body}</span>
									</div>
									<span class:list={['proof-tag', item.tagClass]}>{item.tag}</span>
								</div>
							))
						}
					</div>
				</section>

				<!-- TRUST SIGNALS -->
				<section class="surface-sunken intake-panel intake-trust">
					<div class="surface-head">
						<span class="surface-label">Trust</span>
						<span class="surface-state">Zero Risk</span>
					</div>
					{
						trustSignals.map((signal) => (
							<div class="trust-signal">
								<strong>{signal.value}</strong>
								<span>{signal.label}</span>
							</div>
						))
					}
				</section>

				<!-- LIVE PREVIEW -->
				<section class="surface-sunken intake-panel">
					<div class="surface-head">
						<span class="surface-label">Email preview</span>
					</div>
					<div class="intake-preview">
						<p class="preview-label">Subject</p>
						<p class="preview-subject" data-intake-subject>{subject}</p>
						<p class="preview-label">Body</p>
						<pre class="preview-body" data-intake-preview></pre>
					</div>
				</section>
			</aside>
		</section>

		<!-- FAQ -->
		<section class="section-frame surface intake-faq-section">
			<div class="section-heading">
				<p class="section-kicker">Before you send</p>
				<h2 style="font-size: clamp(1.4rem, 3.2vw, 2.4rem);">Common questions about the scope process.</h2>
			</div>

			<div class="intake-faq-grid">
				{
					faqItems.map((item) => (
						<article class="faq-card surface-sunken">
							<h3>{item.question}</h3>
							<p>{item.answer}</p>
						</article>
					))
				}
			</div>
		</section>

		<!-- BOTTOM CTA -->
		<section class="cta-banner surface">
			<div>
				<p class="section-kicker">Ready</p>
				<h2 style="font-size: clamp(1.4rem, 3.6vw, 2.6rem);">One email. One workflow. One clear answer.</h2>
				<p>
					Fill the form above or send your scope directly. We reply within one business day
					with a concrete recommendation.
				</p>
			</div>

			<div class="cta-actions">
				<div class="cta-prompts" aria-label="Scope fields">
					<span class="chip">Workflow</span>
					<span class="chip">Stack</span>
					<span class="chip">Constraints</span>
					<span class="chip">Success criteria</span>
				</div>
				<div class="footer-actions">
					<a class="button-primary" href="#top">↑ Fill the Scope Form</a>
					<a class="button-secondary" href="/">← Back to Product</a>
				</div>
				<a class="cta-email" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>
			</div>
		</section>

		<footer class="site-footer">
			<p class="footer-note">CORTEX Persist / The swarm verifies. The hardware remembers.</p>
			<div class="footer-links">
				<a href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noreferrer">GitHub</a>
				<a href="/certificaciones">Certificaciones</a>
				<a href="https://agents.archi" target="_blank" rel="noreferrer">Audit Registry</a>
				<a href="/async-demo">Async Demo</a>
			</div>
		</footer>
	</main>

	<IntakeFormScript requestTitle="CORTEX pilot scope request" lines={intakeLines} />
</SiteLayout>
