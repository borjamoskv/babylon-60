---
import NoirLayout from '../layouts/NoirLayout.astro';
import AwwwardsHero from '../components/landing/AwwwardsHero';
import MTKBoundaryVisual from '../components/landing/MTKBoundaryVisual';
---

<NoirLayout title="CORTEX Persist | Know exactly what your AI agents did.">
  <AwwwardsHero client:load />

  <section class="architecture-section">
    <div class="container">
      <div class="grid-2">
        <div class="arch-text">
          <h2 class="text-kintsugi">THE MTK BOUNDARY</h2>
          <p class="text-secondary">
            We have eradicated distributed systems cosplay. The Minimal Trusted Kernel (MTK) physically hooks into SQLite via authorizers. 
            No valid ephemeral cryptographic token in the current context thread = <strong class="text-primary">SQLITE_DENY</strong>.
          </p>
          <ul class="arch-list mono text-muted">
            <li>Zero Anergy</li>
            <li>Base-60 Substrate</li>
            <li>Causal Verification</li>
          </ul>
        </div>
        <div class="arch-visual glass-panel">
          <MTKBoundaryVisual client:visible />
        </div>
      </div>
    </div>
  </section>
</NoirLayout>

<style>
  .architecture-section {
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border-dim);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  @media (max-width: 768px) {
    .grid-2 {
      grid-template-columns: 1fr;
    }
  }

  h2 {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  p {
    font-size: 1.1rem;
    margin-bottom: var(--space-4);
  }

  .arch-list {
    list-style: none;
    padding-left: 0;
  }

  .arch-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--border-dim);
  }

  .arch-list li::before {
    content: '> ';
    color: var(--accent-cobalt);
  }

  .arch-visual {
    height: 400px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(10,10,10,0.8), rgba(43,59,229,0.1));
  }
</style>
