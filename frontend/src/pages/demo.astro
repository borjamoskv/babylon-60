---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
	title="CORTEX Persist | Causal Persistence Demo"
	description="CORTEX-PERSIST DEMO v0. Causal persistence, hash-chain auditing, and recursive origin recovery."
	canonical="https://cortexpersist.com/demo"
	bodyClass="demo-body"
>
	<div id="demo-stage">
		<header class="demo-topbar surface">
			<div class="demo-brand">
				<a class="brand" href="/" aria-label="Return to landing">
					<span class="brand-mark">CP</span>
					<span class="brand-copy">
						<strong>CORTEX Persist</strong>
						<span>Causal Persistence Ledger / Demo v0</span>
					</span>
				</a>
			</div>

			<div class="demo-heading">
				<p class="eyebrow">DEMO ORCHESTRATOR</p>
				<h1>Sovereign Memory & Provenance</h1>
			</div>

			<div class="demo-actions">
				<div class="status-badge" id="conn-status" data-mode="standby" role="status">
					STANDBY
				</div>
				<button class="button-primary compact" id="btn-toggle-mode">
					SWITCH TO LIVE
				</button>
			</div>
		</header>

		<main class="demo-grid">
			<!-- CORTEX Auditor Status Card -->
			<section class="demo-panel">
				<article class="surface auditor-card">
					<div class="surface-head">
						<span class="surface-label">CRYPTOGRAPHIC INTEGRITY MONITOR</span>
						<span class="surface-state" id="integrity-badge">SECURE</span>
					</div>
					
					<div class="auditor-box">
						<div class="terminal-border-top">┌───────────────────────────┐</div>
						<div class="terminal-line">│ <span class="terminal-title">CORTEX AUDITOR</span>            │</div>
						<div class="terminal-border-mid">├───────────────────────────┤</div>
						<div class="terminal-line">│ Events      : <span class="terminal-val" id="val-events">0</span>           │</div>
						<div class="terminal-line">│ Integrity   : <span class="terminal-val" id="val-integrity">WAITING</span>     │</div>
						<div class="terminal-line">│ Restarts    : <span class="terminal-val" id="val-restarts">0</span>           │</div>
						<div class="terminal-line">│ Corruption  : <span class="terminal-val" id="val-corruption">0</span>           │</div>
						<div class="terminal-line">│ Root Causes : <span class="terminal-val" id="val-root">100%</span>        │</div>
						<div class="terminal-border-bottom">└───────────────────────────┘</div>
					</div>

					<p class="card-desc">
						This panel runs continuous SHA-256 validation over the event ledger. Tampering with any historical block propagates a chain breach.
					</p>
				</article>

				<!-- Controls -->
				<article class="surface operations-card">
					<div class="surface-head">
						<span class="surface-label">OPERATIONS CENTER</span>
						<span class="surface-state">READY</span>
					</div>
					
					<div class="ops-buttons">
						<button class="button-primary" id="btn-init">
							1. INGEST 10,000 EVENTS
						</button>
						<button class="button-secondary btn-risk" id="btn-tamper">
							2. TAMPER EVENT 9834
						</button>
						<button class="button-secondary" id="btn-audit">
							3. RUN CRYPTOGRAPHIC AUDIT
						</button>
						<button class="button-tertiary" id="btn-repair">
							4. REPAIR HASH CHAIN
						</button>
					</div>
				</article>
			</section>

			<!-- Causal Chain Visualizer -->
			<section class="demo-panel">
				<article class="surface visualizer-card">
					<div class="surface-head">
						<span class="surface-label">CAUSAL TRACE VISUALIZER</span>
						<span class="surface-state">ACTIVE</span>
					</div>
					
					<div class="visualizer-content">
						<div class="query-prompt">
							<p>Query Causal Origin of Event 9834:</p>
							<button class="button-primary compact" id="btn-query-causal">
								Run WITH RECURSIVE Causal Query
							</button>
						</div>

						<div class="causal-chain-display" id="causal-chain-display">
							<div class="empty-state">No causal query executed yet. Click above to trace history.</div>
						</div>
					</div>
				</article>
			</section>

			<!-- Terminal / Log Log -->
			<section class="demo-panel full-width">
				<article class="surface console-card">
					<div class="surface-head">
						<span class="surface-label">LEDGER TELEMETRY TERMINAL</span>
						<span class="surface-state">RAW</span>
					</div>
					<div class="console-body" id="console-body">
						<div class="console-row">[SYSTEM] Offline demonstration mode active. Click 'SWITCH TO LIVE' to interface with the local C5-REAL server on port 8000.</div>
					</div>
				</article>
			</section>
		</main>
	</div>

	<script>
		const API_BASE = "http://127.0.0.1:8000/v1/demo"; // Matches registered prefix
		let liveMode = false;

		// Simulated state for offline fallback
		let simEvents = 0;
		let simIntegrity = "PASS";
		let simRestarts = 12;
		let simCorruption = 0;
		let simTampered = false;

		// UI elements
		const btnToggleMode = document.getElementById("btn-toggle-mode");
		const connStatus = document.getElementById("conn-status");
		const btnInit = document.getElementById("btn-init");
		const btnTamper = document.getElementById("btn-tamper");
		const btnAudit = document.getElementById("btn-audit");
		const btnRepair = document.getElementById("btn-repair");
		const btnQueryCausal = document.getElementById("btn-query-causal");

		const valEvents = document.getElementById("val-events");
		const valIntegrity = document.getElementById("val-integrity");
		const valRestarts = document.getElementById("val-restarts");
		const valCorruption = document.getElementById("val-corruption");
		const valRoot = document.getElementById("val-root");
		const integrityBadge = document.getElementById("integrity-badge");
		
		const causalChainDisplay = document.getElementById("causal-chain-display");
		const consoleBody = document.getElementById("console-body");

		function logConsole(tag, msg, isError = false) {
			const row = document.createElement("div");
			row.className = `console-row ${isError ? 'error' : ''}`;
			row.textContent = `[${tag}] ${msg}`;
			consoleBody.appendChild(row);
			consoleBody.scrollTop = consoleBody.scrollHeight;
		}

		// Update Auditor UI
		function updateAuditorUI(events, integrity, restarts, corruption) {
			valEvents.textContent = events.toLocaleString();
			valIntegrity.textContent = integrity;
			valRestarts.textContent = restarts;
			valCorruption.textContent = corruption;
			
			if (corruption > 0 || integrity === "compromised" || integrity === "FAIL") {
				valIntegrity.style.color = "var(--danger)";
				integrityBadge.textContent = "COMPROMISED";
				integrityBadge.style.background = "rgba(255, 102, 122, 0.14)";
				integrityBadge.style.color = "#ff9ba8";
			} else if (events > 0) {
				valIntegrity.style.color = "var(--success)";
				integrityBadge.textContent = "SECURE";
				integrityBadge.style.background = "rgba(138, 240, 196, 0.14)";
				integrityBadge.style.color = "var(--success)";
			} else {
				valIntegrity.style.color = "var(--text-muted)";
				integrityBadge.textContent = "WAITING";
				integrityBadge.style.background = "rgba(255, 255, 255, 0.05)";
				integrityBadge.style.color = "var(--text-muted)";
			}
		}

		// Toggle mode between live API and local synthetic simulation
		async function toggleMode() {
			liveMode = !liveMode;
			if (liveMode) {
				btnToggleMode.textContent = "SWITCH TO DEMO";
				connStatus.textContent = "LIVE (PORT 8000)";
				connStatus.dataset.mode = "live";
				logConsole("SYSTEM", "Attaching to local CORTEX FastAPI backend...");
				await syncLiveState();
			} else {
				btnToggleMode.textContent = "SWITCH TO LIVE";
				connStatus.textContent = "STANDBY";
				connStatus.dataset.mode = "standby";
				logConsole("SYSTEM", "Disconnected from backend. Switched to offline demo mode.");
				updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
			}
		}

		async function syncLiveState() {
			if (!liveMode) return;
			try {
				const res = await fetch(`${API_BASE}/state`);
				if (!res.ok) throw new Error("HTTP state fetch failed");
				const state = await res.json();
				
				simEvents = state.events_loaded;
				simRestarts = state.restarts;
				
				// Audit to determine integrity and corruption
				const auditRes = await fetch(`${API_BASE}/audit`);
				const auditReport = await auditRes.json();
				
				simCorruption = auditReport.broken_hashes;
				simIntegrity = auditReport.integrity === "valid" ? "PASS" : "FAIL";

				updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
				logConsole("API", `State synchronized: ${simEvents} events loaded, restarts: ${simRestarts}.`);
			} catch (err) {
				logConsole("API", `Failed to sync backend state: ${err.message}. Reverting to demo mode.`, true);
				toggleMode();
			}
		}

		// Ingest / Init
		async function handleInit() {
			logConsole("LEDGER", "Initializing ingestion pipeline of 10,000 events...");
			if (liveMode) {
				try {
					const res = await fetch(`${API_BASE}/init`, { method: "POST" });
					const data = await res.json();
					logConsole("API", `Ingestion complete. ${data.events_generated} events registered in SQLite.`);
					await syncLiveState();
				} catch (err) {
					logConsole("API", `Error during ingestion: ${err.message}`, true);
				}
			} else {
				simEvents = 10000;
				simIntegrity = "PASS";
				simCorruption = 0;
				simTampered = false;
				updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
				logConsole("SIM", "Ingestion simulation complete: 10,000 cryptographic events generated in memory.");
			}
		}

		// Tamper
		async function handleTamper() {
			logConsole("SECURITY", "Injecting malicious payload modification into event 9834...", true);
			if (liveMode) {
				try {
					const res = await fetch(`${API_BASE}/tamper/9834`, { method: "POST" });
					const data = await res.json();
					logConsole("API", `Attack completed: event 9834 payload altered direct-in-DB.`, true);
					await syncLiveState();
				} catch (err) {
					logConsole("API", `Error during tampering: ${err.message}`, true);
				}
			} else {
				if (simEvents < 10000) {
					logConsole("SIM", "Cannot tamper event 9834. Ingest events first.", true);
					return;
				}
				simTampered = true;
				simCorruption = 167; // subsequent blocks corrupted
				simIntegrity = "FAIL";
				updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
				logConsole("SIM", "Malicious modification detected: Event 9834 payload corrupted. All downstream SHA256 hashes invalidated.", true);
			}
		}

		// Audit
		async function handleAudit() {
			logConsole("AUDITOR", "Executing cryptographic sequence verification...");
			if (liveMode) {
				try {
					const res = await fetch(`${API_BASE}/audit`);
					const data = await res.json();
					logConsole("API", `Audit report: events=${data.events}, integrity=${data.integrity}, broken_hashes=${data.broken_hashes}, tampering=${data.tampering}`);
					simCorruption = data.broken_hashes;
					simIntegrity = data.integrity === "valid" ? "PASS" : "FAIL";
					updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
				} catch (err) {
					logConsole("API", `Audit request failed: ${err.message}`, true);
				}
			} else {
				if (simEvents === 0) {
					logConsole("SIM", "Audit failed: ledger is empty.", true);
					return;
				}
				if (simTampered) {
					logConsole("SIM", "AUDIT VERIFICATION FAILED: 167 broken hashes, tampering detected in event 9834.", true);
				} else {
					logConsole("SIM", "AUDIT VERIFICATION PASSED: 10,000 blocks correct, zero broken hashes.");
				}
			}
		}

		// Repair
		async function handleRepair() {
			logConsole("LEDGER", "Recomputating cryptographic hashes to repair chain...");
			if (liveMode) {
				try {
					const res = await fetch(`${API_BASE}/repair`, { method: "POST" });
					const data = await res.json();
					logConsole("API", `Repair completed: ${data.message}`);
					await syncLiveState();
				} catch (err) {
					logConsole("API", `Repair request failed: ${err.message}`, true);
				}
			} else {
				if (!simTampered) {
					logConsole("SIM", "Ledger is already secure, repair skipped.");
					return;
				}
				simTampered = false;
				simCorruption = 0;
				simIntegrity = "PASS";
				updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
				logConsole("SIM", "Hash chain re-anchored. All 10,000 event blocks are now cryptographically secure.");
			}
		}

		// Causal Query
		async function handleCausalQuery() {
			logConsole("ENGINE", "Executing recursive CTE causal query for event 9834...");
			if (liveMode) {
				try {
					const res = await fetch(`${API_BASE}/causal/9834`);
					if (!res.ok) throw new Error("Causal query failed");
					const data = await res.json();
					renderCausalChain(data.event, data.caused_by, data.root_cause, data.causal_path_length, data.hash_chain_verified);
					logConsole("API", `Causal chain retrieved. Path depth: ${data.causal_path_length} events.`);
				} catch (err) {
					logConsole("API", `Error fetching causal chain: ${err.message}`, true);
				}
			} else {
				if (simEvents < 10000) {
					logConsole("SIM", "Ledger empty. Ingest events first.", true);
					return;
				}
				// Mock the causal response
				const causedBy = [9833, 9788, 9701];
				renderCausalChain(9834, causedBy, "user_request_42", 184, !simTampered);
				logConsole("SIM", "Recursive trace resolved: 184 causal propagation steps. Verified back to root user request.");
			}
		}

		function renderCausalChain(target, causedBy, rootCause, length, hashVerified) {
			causalChainDisplay.innerHTML = "";

			const card = document.createElement("div");
			card.className = "causal-box";
			card.innerHTML = `
				<div class="causal-header">
					<strong>Trace Event #${target}</strong>
					<span class="proof-badge ${hashVerified ? 'valid' : 'invalid'}">${hashVerified ? 'HASH SECURE' : 'HASH BREACHED'}</span>
				</div>
				<div class="causal-step current">
					<span class="step-num">9834</span>
					<div class="step-info">
						<strong>Tool Execution</strong>
						<span>payload: {"tool": "web_search", "query": "query_9834"}</span>
					</div>
				</div>
				
				<div class="causal-arrow">▼ caused by</div>

				<div class="causal-step">
					<span class="step-num">9833</span>
					<div class="step-info">
						<strong>Tool Execution</strong>
						<span>payload: {"tool": "web_search", "query": "query_9833"}</span>
					</div>
				</div>

				<div class="causal-arrow">▼ caused by</div>

				<div class="causal-step-skip">... [${length - 5} intermediate events omitted] ...</div>

				<div class="causal-arrow">▼ caused by</div>

				<div class="causal-step">
					<span class="step-num">9788</span>
					<div class="step-info">
						<strong>Tool Execution</strong>
						<span>payload: {"tool": "web_search", "query": "query_9788"}</span>
					</div>
				</div>

				<div class="causal-arrow">▼ caused by</div>

				<div class="causal-step">
					<span class="step-num">9701</span>
					<div class="step-info">
						<strong>Tool Execution</strong>
						<span>payload: {"tool": "web_search", "query": "query_9701"}</span>
					</div>
				</div>

				<div class="causal-arrow">▼ caused by</div>

				<div class="causal-step root">
					<span class="step-num">42</span>
					<div class="step-info">
						<strong>Root Cause: user_request</strong>
						<span>payload: {"message": "user_message_001"}</span>
					</div>
				</div>

				<div class="causal-summary">
					<span>Total Causal Depth: <strong>${length} events</strong></span>
					<span>Verifiable Source: <strong>${rootCause}</strong></span>
				</div>
			`;
			causalChainDisplay.appendChild(card);
		}

		// Listeners
		btnToggleMode.addEventListener("click", toggleMode);
		btnInit.addEventListener("click", handleInit);
		btnTamper.addEventListener("click", handleTamper);
		btnAudit.addEventListener("click", handleAudit);
		btnRepair.addEventListener("click", handleRepair);
		btnQueryCausal.addEventListener("click", handleCausalQuery);

		// Initial load
		updateAuditorUI(simEvents, simIntegrity, simRestarts, simCorruption);
	</script>
</SiteLayout>

<style is:global>
	.demo-body {
		background: #0A0A0A;
		color: #E2E8F0;
		font-family: 'Manrope', sans-serif;
	}

	#demo-stage {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 1rem;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.demo-topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		background: rgba(26, 26, 26, 0.4);
		backdrop-filter: blur(12px);
	}

	.demo-brand {
		display: flex;
		align-items: center;
	}

	.demo-heading h1 {
		font-family: 'Orbitron', sans-serif;
		font-size: 1.25rem;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.demo-actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.demo-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 900px) {
		.demo-grid {
			grid-template-columns: 1fr 1fr;
		}
		.full-width {
			grid-column: span 2;
		}
	}

	.demo-panel {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.surface {
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		background: rgba(20, 20, 20, 0.6);
		backdrop-filter: blur(8px);
		padding: 1.5rem;
	}

	.surface-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 0.75rem;
	}

	.surface-label {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.75rem;
		color: var(--accent-bright, #2B3BE5);
		letter-spacing: 0.1em;
	}

	.surface-state {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.75rem;
		background: rgba(255, 255, 255, 0.05);
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
	}

	/* Terminal-like Auditor Card */
	.auditor-box {
		background: #000;
		border-radius: 8px;
		padding: 1.25rem;
		font-family: 'IBM Plex Mono', monospace;
		margin-bottom: 1rem;
		box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.8);
		font-size: 0.9rem;
		line-height: 1.5;
	}

	.terminal-border-top,
	.terminal-border-mid,
	.terminal-border-bottom {
		color: #334155;
	}

	.terminal-title {
		color: #CCFF00;
		font-weight: bold;
	}

	.terminal-val {
		color: #E2E8F0;
		font-weight: bold;
	}

	.card-desc {
		color: #94A3B8;
		font-size: 0.85rem;
		line-height: 1.6;
		margin: 0;
	}

	/* Buttons & operations */
	.ops-buttons {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
	}

	.button-primary, .button-secondary, .button-tertiary {
		padding: 0.85rem 1.25rem;
		border-radius: 8px;
		font-family: 'Manrope', sans-serif;
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
		text-align: center;
		border: none;
	}

	.button-primary {
		background: #2B3BE5;
		color: white;
	}

	.button-primary:hover {
		background: #3B4BFF;
		box-shadow: 0 0 12px rgba(43, 59, 229, 0.4);
	}

	.button-secondary {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: #E2E8F0;
	}

	.button-secondary:hover {
		background: rgba(255, 255, 255, 0.1);
	}

	.btn-risk:hover {
		border-color: rgba(239, 68, 68, 0.5);
		color: #EF4444;
		box-shadow: 0 0 12px rgba(239, 68, 68, 0.2);
	}

	.button-tertiary {
		background: transparent;
		color: #94A3B8;
		border: 1px dashed rgba(255, 255, 255, 0.15);
	}

	.button-tertiary:hover {
		color: white;
		border-color: rgba(255, 255, 255, 0.3);
	}

	/* Visualizer */
	.visualizer-content {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.query-prompt {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: rgba(255, 255, 255, 0.03);
		padding: 0.75rem 1rem;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.query-prompt p {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 500;
	}

	.causal-chain-display {
		background: #070707;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.05);
		min-height: 28rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: 1.5rem;
	}

	.empty-state {
		color: #64748B;
		font-size: 0.9rem;
		text-align: center;
		font-style: italic;
	}

	.causal-box {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.causal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		padding-bottom: 0.5rem;
	}

	.proof-badge {
		font-family: 'IBM Plex Mono', monospace;
		font-size: 0.75rem;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		font-weight: bold;
	}

