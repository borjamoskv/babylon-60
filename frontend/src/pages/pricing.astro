---
import SiteLayout from '../layouts/NoirLayout.astro';

// C5-REAL Edge Personalization
const country = Astro.request.headers.get('cf-ipcountry') || 'Unknown';
---

<NoirLayout
	title="CORTEX Persist | Planes y Precios"
	description="Control plane de IA escalable desde el nivel de desarrollador hasta entornos empresariales regulados."
	canonical="https://cortexpersist.com/pricing"
	lang="es"
>
	<main class="landing-shell" id="top">
		<!-- HEADER / MASTHEAD -->
		<header class="masthead">
			<a class="brand" href="/" aria-label="CORTEX Persist home">
				<span class="brand-mark">CP</span>
				<span class="brand-copy">
					<strong>CORTEX Persist</strong>
					<span>Verifiable event ledger</span>
				</span>
			</a>

			<nav class="site-nav" aria-label="Primary">
				<a class="nav-link" href="/">Plataforma</a>
				<a class="nav-link" href="/fiscal">Fiscal Audit</a>
				<a class="nav-link nav-link-active" href="/pricing">Precios</a>
				<a class="nav-link" href="/vsa">VSA</a>
				<a class="nav-link" href="/blog">Blog</a>
			</nav>

			<div class="masthead-actions">
				<span class="microcopy" style="color: var(--accent-soft); font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; margin-right: 1rem; text-transform: uppercase; letter-spacing: 0.05em; display: none; @media (min-width: 768px) { display: inline-block; }">
					EDGE: {country}
				</span>
				<a class="button-tertiary" href="/pilot-scope">Piloto Async</a>
				<a class="button-primary" href="/api-key">Get API Key</a>
			</div>
		</header>

		<!-- HERO SECTION -->
		<section class="section-frame surface hero">
			<div class="section-heading">
				<p class="section-kicker" style="color: var(--accent, #2B3BE5);">C5-REAL PRICING SUBSTRATE</p>
				<h1 style="font-size: clamp(2.4rem, 5vw, 4rem); max-width: 1000px; line-height: 1.1; margin-bottom: 1.5rem;">
					Control plane de IA Soberana. Auditoría Inmutable.
				</h1>
				<p style="font-size: 1.2rem; max-width: 800px; color: var(--text-muted, #a0a0a0); line-height: 1.6;">
					Desde desarrollo local open-source hasta infraestructuras soberanas en la nube para entornos altamente regulados.
				</p>
			</div>

			<!-- EPISTEMIC JUSTIFICATION BLOCK -->
			<div class="surface-sunken" style="margin-top: 3rem; padding: 2rem; border-left: 4px solid var(--accent, #2B3BE5); font-family: 'IBM Plex Mono', monospace; border-radius: 0 4px 4px 0; max-width: 800px;">
				<span style="color: var(--accent, #2B3BE5); font-weight: bold; display: block; margin-bottom: 1rem; font-size: 0.85rem;">[EPISTEMIC STATE: C5-REAL CONFIDENCE]</span>
				<pre style="margin: 0; color: #e0e0e0; font-size: 0.9rem; line-height: 1.4; overflow-x: auto;">
claim: "Cortex Persist Multi-Tier Pricing Model"
proof:
  base_cryptography: "Deterministic SLA Tracking & Usage Cryptographic Attestation"
  attribution_token: "CORTEX-TAINT"
  pricing_framework: "Exergy-Optimized Resource Allocation Model"
  status: "ACTIVE"
  confidence_rating: "C5-REAL"</pre>
			</div>
		</section>

		<!-- PRICING TIERS -->
		<section class="section-frame surface-sunken" style="margin-top: 4rem;">
			<div class="section-heading" style="margin-bottom: 3rem;">
				<p class="section-kicker">Planes y Tarifas</p>
				<h2>Elige tu edición</h2>
			</div>

			<div class="pricing-grid-4">
				<!-- Core (Local) -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Core (Local)</h3>
					<div class="pricing-card-price">$0 <span>(Apache-2.0)</span></div>
					<p class="pricing-card-desc">Ejecución desconectada local. CLI integrado con base de datos SQLite.</p>
					<ul class="pricing-card-features">
						<li><strong>CLI & SQLite</strong> locales</li>
						<li>Retención local ilimitada</li>
						<li><strong>1 seat</strong> individual</li>
						<li>5 runs de evaluación / mes</li>
						<li>Soporte comunitario</li>
					</ul>
					<a href="https://github.com/borjamoskv/Cortex-Persist" class="pricing-card-cta pricing-card-cta-secondary">Descarga OSS</a>
				</article>

				<!-- Pro (SaaS) -->
				<article class="pricing-card-custom pricing-card-featured-custom">
					<span class="pricing-card-tag">Recomendado</span>
					<h3 class="pricing-card-title">Pro (SaaS)</h3>
					<div class="pricing-card-price">$99 <span>/ mes + compute</span></div>
					<p class="pricing-card-desc">Plataforma multiusuario en la nube con orquestación y retención histórica.</p>
					<ul class="pricing-card-features">
						<li><strong>1M spans/mes</strong> incluidos</li>
						<li>$0.10 por cada 10k spans extra</li>
						<li>Retención de <strong>30 días</strong></li>
						<li>Hasta <strong>10 seats</strong> de equipo</li>
						<li>50 runs de evaluación / mes</li>
						<li>SLA de 99.9% y soporte prioritario</li>
					</ul>
					<a href="/api-key" class="pricing-card-cta pricing-card-cta-primary">Regístrate Gratis</a>
				</article>

				<!-- Enterprise (Sovereign) -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Enterprise</h3>
					<div class="pricing-card-price">$45k - 150k <span>/ año</span></div>
					<p class="pricing-card-desc">Despliegue privado en VPC u On-Premises para industrias reguladas.</p>
					<ul class="pricing-card-features">
						<li><strong>5M spans/mes</strong> incluidos</li>
						<li>Retención de <strong>90 días</strong></li>
						<li>Hasta <strong>50 seats</strong> (expandibles)</li>
						<li>500 runs de evaluación / mes</li>
						<li>SLA de 99.99% y respuesta &lt;15 min</li>
						<li>Soporte 24/7 con Pager y TAM</li>
					</ul>
					<a href="/pilot-scope" class="pricing-card-cta pricing-card-cta-secondary">Solicitar Demo</a>
				</article>

				<!-- Enterprise Strategic -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Estratégico</h3>
					<div class="pricing-card-price">Custom</div>
					<p class="pricing-card-desc">Contratos a medida y servicios profesionales de onboarding e integración.</p>
					<ul class="pricing-card-features">
						<li>Volumen de spans <strong>ilimitado</strong></li>
						<li>Retención personalizada</li>
						<li>Seats y evaluaciones <strong>ilimitados</strong></li>
						<li>Soporte TAM dedicado 24/7+</li>
						<li>Auditorías y co-diseño de roadmap</li>
						<li>SLA crítico a medida</li>
					</ul>
					<a href="/pilot-scope" class="pricing-card-cta pricing-card-cta-secondary">Contacto Ventas</a>
				</article>
			</div>
		</section>

		<!-- DETAILED MATRIX TABLE -->
		<section class="section-frame surface">
			<div class="section-heading">
				<p class="section-kicker">Matriz de características</p>
				<h2>Comparativa Técnica</h2>
			</div>

			<div class="matrix-container">
				<table class="matrix-table">
					<thead>
						<tr>
							<th>Característica</th>
							<th>Core (Local)</th>
							<th>Pro (SaaS)</th>
							<th>Enterprise (Sovereign)</th>
							<th>Estratégico / Regulador</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><strong>Precio Base</strong></td>
							<td>Gratuito (Apache-2.0)</td>
							<td>$99/mes + compute</td>
							<td>$45k – $150k/año</td>
							<td>Personalizado</td>
						</tr>
						<tr>
							<td><strong>Spans Incluidos</strong></td>
							<td>Ilimitado local (ej. 100k)</td>
							<td>1M / mes</td>
							<td>5M / mes (escalable)</td>
							<td>Ilimitado</td>
						</tr>
						<tr>
							<td><strong>Exceso de Spans</strong></td>
							<td>N/A</td>
							<td>$0.10 por 10k spans</td>
							<td>Acordado por contrato</td>
							<td>Personalizado</td>
						</tr>
						<tr>
							<td><strong>Retención de Datos</strong></td>
							<td>Capacidad local</td>
							<td>30 días</td>
							<td>90 días</td>
							<td>Personalizada (&gt;1 año)</td>
						</tr>
						<tr>
							<td><strong>Seats / Usuarios</strong></td>
							<td>1 usuario (CLI local)</td>
							<td>Hasta 10 seats</td>
							<td>Hasta 50 seats</td>
							<td>Ilimitados</td>
						</tr>
						<tr>
							<td><strong>Evaluaciones / Runs</strong></td>
							<td>~5 runs / mes</td>
							<td>~50 runs / mes</td>
							<td>~500 runs / mes</td>
							<td>Ilimitadas</td>
						</tr>
						<tr>
							<td><strong>Despliegue</strong></td>
							<td>Local (SQLite)</td>
							<td>Cloud (SaaS)</td>
							<td>VPC / On-Prem (Docker, Helm)</td>
							<td>Híbrido / Kafka / Dedicado</td>
						</tr>
						<tr>
							<td><strong>SLA de Uptime</strong></td>
							<td>N/A</td>
							<td>99.9%</td>
							<td>99.99%</td>
							<td>Garantía Máxima</td>
						</tr>
						<tr>
							<td><strong>Canal de Soporte</strong></td>
							<td>GitHub / Docs</td>
							<td>Email</td>
							<td>24/7 Pager & TAM</td>
							<td>24/7 TAM Dedicado</td>
						</tr>
						<tr>
							<td><strong>Tiempo de Respuesta</strong></td>
							<td>Soporte voluntario</td>
							<td>Standard</td>
							<td>&lt;15 minutos</td>
							<td>Inmediato (TAM)</td>
						</tr>
						<tr>
							<td><strong>Servicios Profesionales</strong></td>
							<td>No</td>
							<td>No</td>
							<td>Opcional</td>
							<td>Incluido (Migración, talleres)</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<!-- SALES ARGUMENTS -->
		<section class="section-frame surface-sunken" style="margin-top: 4rem;">
			<div class="section-heading" style="margin-bottom: 3rem;">
				<p class="section-kicker">Propuesta de Valor</p>
				<h2>Soberanía y Control Causal</h2>
			</div>

			<div class="arguments-grid">
				<div class="argument-card">
					<h4>Autarquía Local (Core)</h4>
					<p>Ejecución 100% desconectada con SQLite local. Evalúa flujos de control sin transferir telemetría ni datos sensibles fuera de tu entorno local.</p>
				</div>
				<div class="argument-card">
					<h4>Visibilidad Operativa (Pro)</h4>
					<p>Colaboración multiusuario en la nube con histórico extendido. Controla el consumo y la deriva de costes de tokens en tiempo real sin sorpresas.</p>
				</div>
				<div class="argument-card">
					<h4>Soberanía Total (Enterprise)</h4>
					<p>Despliegue privado en tu propia VPC o Kubernetes. Integración directa con tus políticas de SSO, RBAC e inmutabilidad estricta (GDPR/LOPD).</p>
				</div>
				<div class="argument-card">
					<h4>Co-diseño y Resiliencia (Estratégico)</h4>
					<p>Soporte de TAM dedicado con guardias 24/7 y SLA garantizado por contrato. Integración nativa con colas distribuidas (Kafka) y auditoría SOC 2 Tipo II.</p>
				</div>
			</div>
		</section>

		<!-- FAQS SECTION -->
		<section class="section-frame surface faq-section">
			<div class="section-heading">
				<p class="section-kicker">FAQs</p>
				<h2>Preguntas Frecuentes</h2>
			</div>

			<div class="faq-list">
				<div class="faq-item">
					<h3 class="faq-question">¿Cómo empiezo sin compromiso?</h3>
					<p class="faq-answer">Puedes descargar el plan Core de código abierto gratuitamente, sin necesidad de tarjeta de crédito. Incluye hasta ~50k spans de prueba por mes (planificación aproximada) con todas las características básicas de trazabilidad e inmutabilidad local.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Qué pasa si supero los límites de uso?</h3>
					<p class="faq-answer">El exceso se factura automáticamente según el consumo registrado en tu panel. En el plan Pro SaaS, cobramos $0.10 por cada 10,000 spans adicionales. También puedes solicitar un upgrade preventivo para ajustar tu plan antes de incurrir en costos variables.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Cómo se diferencia un “span” de una “traza”?</h3>
					<p class="faq-answer">Cada <strong>span</strong> es una operación individual y discreta (como una llamada específica a una API de LLM, una consulta de vector o un paso intermedio de un agente). Una <strong>traza</strong> es el grafo dirigido completo que agrupa la secuencia de spans involucrados en una interacción o tarea final. El span es la unidad atómica de facturación de datos en CORTEX.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Necesito firmar contrato o pagar a plazo?</h3>
					<p class="faq-answer">El plan Core es Apache-2.0 de descarga libre sin contratos. El plan Pro se factura con carácter mensual recurrente y es cancelable en cualquier momento desde tu panel de facturación. Los planes Enterprise y Estratégicos operan con facturación y contratos anuales con SLAs garantizados.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Hay soporte dedicado o SLA en Pro?</h3>
					<p class="faq-answer">El plan Pro ofrece un SLA estándar de 99.9% de disponibilidad y atención de soporte vía correo electrónico. Si requieres soporte crítico 24/7 con guardias a través de buscapersonas (Pager), gestor de cuenta asignado y un SLA de resolución menor a 15 minutos, debes optar por nuestros planes Enterprise o Estratégico.</p>
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="site-footer">
			<p class="footer-note">CORTEX Persist / The swarm verifies. The hardware remembers. <span style="opacity:0.5; margin-left:8px;">| Powered by Cloudflare Edge</span></p>
			<div class="footer-links">
				<a href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noreferrer">GitHub</a>
				<a href="https://github.com/borjamoskv/Cortex-Persist/tree/main/docs" target="_blank" rel="noreferrer">Docs</a>
				<a href="/certificaciones">Certificaciones</a>
				<a href="/pricing">Precios</a>
				<a href="https://agents.archi" target="_blank" rel="noreferrer">Audit Registry</a>
			</div>
		</footer>
	</main>
</NoirLayout>

<style>
/* Responsive grid */
.pricing-grid-4 {
	display: grid;
	gap: 1.5rem;
	grid-template-columns: 1fr;
	margin-top: 3rem;
}
@media (min-width: 768px) {
	.pricing-grid-4 {
		grid-template-columns: repeat(2, 1fr);
	}
}
@media (min-width: 1200px) {
	.pricing-grid-4 {
		grid-template-columns: repeat(4, 1fr);
	}
}

/* Card details */
.pricing-card-custom {
	display: flex;
	flex-direction: column;
	background: rgba(10, 10, 10, 0.85);
	backdrop-filter: blur(24px);
	-webkit-backdrop-filter: blur(24px);
	border: 1px solid rgba(43, 59, 229, 0.25);
	border-radius: var(--radius-lg, 0px);
	padding: 2.2rem 1.8rem;
	transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
	position: relative;
}
.pricing-card-custom:hover {
	border-color: rgba(43, 59, 229, 0.6);
	transform: translateY(-6px);
	box-shadow: 0 18px 45px rgba(43, 59, 229, 0.18), inset 0 0 15px rgba(43, 59, 229, 0.08);
}
.pricing-card-featured-custom {
	border-color: rgba(43, 59, 229, 0.5);
	box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(43, 59, 229, 0.3);
	background: linear-gradient(180deg, rgba(43, 59, 229, 0.08) 0%, rgba(5, 5, 5, 0.96) 100%);
}
.pricing-card-featured-custom:hover {
	border-color: #00e5a3;
	box-shadow: 0 22px 55px rgba(0, 229, 163, 0.2), 0 0 0 1px rgba(0, 229, 163, 0.4);
}
.pricing-card-tag {
	position: absolute;
	top: 1rem;
	right: 1.2rem;
	background: var(--accent, #2b3be5);
	color: #fff;
	font-size: 0.65rem;
	font-family: 'IBM Plex Mono', monospace;
	padding: 0.25rem 0.55rem;
	border-radius: 4px;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	font-weight: bold;
}
.pricing-card-title {
	font-family: 'Orbitron', sans-serif;
	font-size: 1.4rem;
	margin: 0 0 0.5rem 0;
	color: #fff;
	letter-spacing: 0.02em;
}
.pricing-card-price {
	font-size: 1.8rem;
	font-weight: 800;
	color: #fff;
	margin: 0.5rem 0 1.5rem 0;
	font-family: 'IBM Plex Mono', monospace;
	letter-spacing: -0.02em;
}
.pricing-card-price span {
	font-size: 0.85rem;
	color: var(--muted, #8e95af);
	font-weight: normal;
	font-family: 'Manrope', sans-serif;
	letter-spacing: 0;
}
.pricing-card-desc {
	color: var(--muted, #8e95af);
	font-size: 0.88rem;
	margin-bottom: 1.8rem;
	line-height: 1.5;
	min-height: 4rem;
}
.pricing-card-features {
	list-style: none;
	padding: 0;
	margin: 0 0 2rem 0;
	display: flex;
	flex-direction: column;
	gap: 0.8rem;
	flex-grow: 1;
}
.pricing-card-features li {
	display: flex;
	align-items: flex-start;
	gap: 0.6rem;
	font-size: 0.86rem;
	color: var(--text, #f3f4f6);
	line-height: 1.45;
}
.pricing-card-features li strong {
	color: #fff;
}
.pricing-card-features li::before {
	content: '✓';
	color: var(--accent-soft, #6e7cff);
	font-weight: bold;
	flex-shrink: 0;
	font-size: 0.9rem;
}
.pricing-card-cta {
	display: block;
	text-align: center;
	padding: 0.8rem 1.5rem;
	border-radius: var(--radius-md, 4px);
	font-weight: 600;
	font-size: 0.92rem;
	transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	width: 100%;
}
.pricing-card-cta-primary {
	background: var(--accent, #2b3be5);
	color: #fff;
}
.pricing-card-cta-primary:hover {
	background: var(--accent-soft, #6e7cff);
}
.pricing-card-cta-secondary {
	background: rgba(255, 255, 255, 0.03);
	border: 1px solid rgba(255, 255, 255, 0.08);
	color: #f3f4f6;
}
.pricing-card-cta-secondary:hover {
	background: rgba(255, 255, 255, 0.08);
	border-color: rgba(255, 255, 255, 0.15);
	color: #fff;
}

/* Matrix Table Styles */
.matrix-container {
	margin-top: 3rem;
	overflow-x: auto;
	border: 1px solid rgba(255, 255, 255, 0.05);
	border-radius: var(--radius-lg, 6px);
	background: var(--bg-1, #0f0f12);
}
.matrix-table {
	width: 100%;
	border-collapse: collapse;
	text-align: left;
	font-size: 0.88rem;
	min-width: 800px;
}
.matrix-table th, .matrix-table td {
	padding: 1.2rem;
	border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
.matrix-table th {
	background: rgba(255, 255, 255, 0.01);
	font-family: 'Orbitron', sans-serif;
	font-weight: 600;
	color: #fff;
	text-transform: uppercase;
	font-size: 0.78rem;
	letter-spacing: 0.05em;
}
.matrix-table tr {
	transition: background 0.15s ease;
}
.matrix-table tr:hover td {
	background: rgba(255, 255, 255, 0.01);
	color: #fff;
}
.matrix-table tr:last-child td {
	border-bottom: none;
}
.matrix-table td strong {
	color: #fff;
}

/* Sales Arguments grid */
.arguments-grid {
	display: grid;
	gap: 1.5rem;
	grid-template-columns: 1fr;
	margin-top: 3rem;
}
@media (min-width: 768px) {
	.arguments-grid {
		grid-template-columns: repeat(2, 1fr);
	}
}
.argument-card {
	background: var(--bg-1, #0f0f12);
	border-left: 3px solid var(--accent, #2b3be5);
	padding: 1.8rem;
	border-radius: 0 var(--radius-lg, 6px) var(--radius-lg, 6px) 0;
	transition: border-color 0.2s ease, background 0.2s ease;
}
.argument-card:hover {
	border-left-color: var(--accent-soft, #6e7cff);
	background: rgba(43, 59, 229, 0.02);
}
.argument-card h4 {
	font-size: 1.1rem;
	margin: 0 0 0.6rem 0;
	color: #fff;
}
.argument-card p {
	color: var(--muted, #8e95af);
	font-size: 0.88rem;
	line-height: 1.55;
	margin: 0;
}

/* FAQ Styles */
.faq-list {
	display: grid;
	gap: 1.2rem;
	margin-top: 3rem;
}
.faq-item {
	background: var(--bg-1, #0f0f12);
	border: 1px solid rgba(255, 255, 255, 0.04);
	border-radius: var(--radius-lg, 6px);
	padding: 1.8rem;
	transition: border-color 0.2s ease;
}
.faq-item:hover {
	border-color: rgba(43, 59, 229, 0.15);
}
.faq-question {
	font-size: 1.05rem;
	font-weight: 600;
	color: #fff;
	margin: 0 0 0.8rem 0;
}
