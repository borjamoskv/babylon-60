---
import SiteLayout from '../layouts/SiteLayout.astro';

// C5-REAL Edge Personalization
const country = Astro.request.headers.get('cf-ipcountry') || 'Unknown';
---

<SiteLayout
	title="CORTEX Persist | Planes y Precios (Core, Pro, Enterprise)"
	description="Control plane de IA escalable desde el nivel de desarrollador hasta entornos empresariales regulados."
	canonical="https://cortexpersist.com/pricing"
	lang="es"
>
	<main class="landing-shell" id="top">
		<!-- HEADER / MASTHEAD -->
		<header class="masthead">
			<a class="brand" href="/" aria-label="CORTEX Persist home">
				<span class="brand-mark">CP</span>
				<span class="brand-copy">
					<strong>CORTEX Persist</strong>
					<span>Verifiable event ledger</span>
				</span>
			</a>

			<nav class="site-nav" aria-label="Primary">
				<a class="nav-link" href="/">Plataforma</a>
				<a class="nav-link" href="/fiscal">Fiscal Audit</a>
				<a class="nav-link nav-link-active" href="/pricing">Precios</a>
				<a class="nav-link" href="/vsa">VSA</a>
				<a class="nav-link" href="/blog">Blog</a>
			</nav>

			<div class="masthead-actions">
				<span class="microcopy" style="color: var(--accent-soft); font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; margin-right: 1rem; text-transform: uppercase; letter-spacing: 0.05em; display: none; @media (min-width: 768px) { display: inline-block; }">
					EDGE: {country}
				</span>
				<a class="button-tertiary" href="/pilot-scope">Piloto Async</a>
				<a class="button-primary" href="/api-key">Get API Key</a>
			</div>
		</header>

		<!-- HERO SECTION -->
		<section class="section-frame surface hero">
			<div class="section-heading">
				<p class="section-kicker" style="color: var(--accent, #2B3BE5);">C5-REAL PRICING SUBSTRATE</p>
				<h1 style="font-size: clamp(2.4rem, 5vw, 4rem); max-width: 1000px; line-height: 1.1; margin-bottom: 1.5rem;">
					Control plane de IA escalable. Sin fricción.
				</h1>
				<p style="font-size: 1.25rem; max-width: 800px; color: var(--text-muted, #a0a0a0); line-height: 1.6;">
					Desde el desarrollo local en código abierto hasta infraestructuras soberanas en la nube para industrias reguladas. Paga por lo que usas, escala con confianza matemática.
				</p>
			</div>

			<!-- EPISTEMIC JUSTIFICATION BLOCK -->
			<div class="surface-sunken" style="margin-top: 3rem; padding: 2rem; border-left: 4px solid var(--accent, #2B3BE5); font-family: 'IBM Plex Mono', monospace; border-radius: 0 4px 4px 0; max-width: 800px;">
				<span style="color: var(--accent, #2B3BE5); font-weight: bold; display: block; margin-bottom: 1rem; font-size: 0.85rem;">[EPISTEMIC STATE: C5-REAL CONFIDENCE]</span>
				<pre style="margin: 0; color: #e0e0e0; font-size: 0.9rem; line-height: 1.4; overflow-x: auto;">
claim: "Cortex Persist Multi-Tier Pricing Model"
proof:
  base_cryptography: "Deterministic SLA Tracking & Usage Cryptographic Attestation"
  attribution_token: "CORTEX-TAINT"
  pricing_framework: "Exergy-Optimized Resource Allocation Model"
  status: "ACTIVE"
  confidence_rating: "C5-REAL"</pre>
			</div>
		</section>

		<!-- PRICING TIERS -->
		<section class="section-frame surface-sunken" style="margin-top: 4rem;">
			<div class="section-heading" style="margin-bottom: 3rem;">
				<p class="section-kicker">Planes y Tarifas</p>
				<h2>Elige la edición que se adapte a tu escala</h2>
			</div>

			<div class="pricing-grid-4">
				<!-- Core (Local) -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Core (Local)</h3>
					<div class="pricing-card-price">$0 <span>(Apache-2.0)</span></div>
					<p class="pricing-card-desc">Plan gratuito local. Ideal para desarrollo, pruebas y proyectos individuales. CLI integrado con base SQLite.</p>
					<ul class="pricing-card-features">
						<li>Uso <strong>ilimitado local</strong> (ej. 100k spans/mes)</li>
						<li>Retención según capacidad local</li>
						<li>Límite de <strong>1 seat</strong> (individual)</li>
						<li>Evaluaciones limitadas (5 runs/mes)</li>
						<li>Soporte comunitario y documentación</li>
					</ul>
					<a href="https://github.com/borjamoskv/Cortex-Persist" class="pricing-card-cta pricing-card-cta-secondary">Descarga OSS</a>
				</article>

				<!-- Starter SaaS -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Starter SaaS</h3>
					<div class="pricing-card-price">$15 <span>/ mes</span></div>
					<p class="pricing-card-desc">Trazas inmutables para desarrolladores pragmáticos. Integración directa con Langfuse y LangChain.</p>
					<ul class="pricing-card-features">
						<li><strong>100k spans/mes</strong> incluidos</li>
						<li>Retención de <strong>14 días</strong></li>
						<li>Hasta <strong>3 seats</strong> de equipo</li>
						<li>Sincronización con Langfuse</li>
						<li>Soporte comunitario (Discord)</li>
					</ul>
					<a href="/api-key" class="pricing-card-cta pricing-card-cta-secondary">Start Free Plan</a>
				</article>

				<!-- Pro (SaaS) -->
				<article class="pricing-card-custom pricing-card-featured-custom">
					<span class="pricing-card-tag">Recomendado</span>
					<h3 class="pricing-card-title">Pro (SaaS)</h3>
					<div class="pricing-card-price">$49 <span>/ mes + uso</span></div>
					<p class="pricing-card-desc">Equipo en crecimiento. Plataforma multiusuario en la nube con orquestación, retención histórica y métricas.</p>
					<ul class="pricing-card-features">
						<li><strong>500k spans/mes</strong> incluidos</li>
						<li>$0.10 por cada 10k spans extra</li>
						<li>Retención de <strong>30 días</strong></li>
						<li>Hasta <strong>10 seats</strong> multiusuario</li>
						<li>~50 runs de evaluación/mes</li>
						<li>SLA de 99.9% y soporte por email</li>
					</ul>
					<a href="/api-key" class="pricing-card-cta pricing-card-cta-primary">Regístrate Gratis</a>
				</article>

				<!-- Enterprise (Sovereign) -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Enterprise</h3>
					<div class="pricing-card-price">$25k - 120k <span>/ año</span></div>
					<p class="pricing-card-desc">Para empresas medianas o grandes que requieren seguridad extrema. Despliegue on-prem o VPC privado.</p>
					<ul class="pricing-card-features">
						<li><strong>2M spans/mes</strong> incluidos (escalables)</li>
						<li>Retención extendida de <strong>90 días</strong></li>
						<li>Hasta <strong>50 seats</strong> (ampliables)</li>
						<li>~500 runs de evaluación/mes</li>
						<li>SLA de 99.99% y respuesta &lt;15 min</li>
						<li>Soporte 24/7 con Pager y Account Manager</li>
					</ul>
					<a href="/pilot-scope" class="pricing-card-cta pricing-card-cta-secondary">Solicitar Demo</a>
				</article>

				<!-- Enterprise Strategic -->
				<article class="pricing-card-custom">
					<h3 class="pricing-card-title">Estratégico</h3>
					<div class="pricing-card-price">Custom</div>
					<p class="pricing-card-desc">Grandes corporaciones con requisitos críticos. Todo en Enterprise con desarrollo a medida y servicios.</p>
					<ul class="pricing-card-features">
						<li>Volumen de spans <strong>ilimitado</strong></li>
						<li>Retención personalizada (&gt;1 año)</li>
						<li>Seats y evaluaciones <strong>ilimitados</strong></li>
						<li>Soporte TAM dedicado y 24/7+</li>
						<li>Auditoría SOC 2 Tipo II y contratos a medida</li>
						<li>Integración, migración y talleres</li>
					</ul>
					<a href="/pilot-scope" class="pricing-card-cta pricing-card-cta-secondary">Contacto Ventas</a>
				</article>
			</div>
		</section>

		<!-- DETAILED MATRIX TABLE -->
		<section class="section-frame surface">
			<div class="section-heading">
				<p class="section-kicker">Matriz de características</p>
				<h2>Comparativa Técnica Detallada</h2>
			</div>

			<div class="matrix-container">
				<table class="matrix-table">
					<thead>
						<tr>
							<th>Característica</th>
							<th>Core (Local)</th>
							<th>Starter SaaS</th>
							<th>Pro (SaaS)</th>
							<th>Enterprise (Sovereign)</th>
							<th>Estratégico / Regulador</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><strong>Precio Base</strong></td>
							<td>Gratuito (Apache-2.0)</td>
							<td>$15/mes</td>
							<td>$49/mes + uso</td>
							<td>$25k – $120k/año</td>
							<td>Personalizado (A convenir)</td>
						</tr>
						<tr>
							<td><strong>Spans Incluidos</strong></td>
							<td>Ilimitado local (ej. 100k)</td>
							<td>100k / mes</td>
							<td>1M / mes</td>
							<td>2M / mes (escalable)</td>
							<td>Ilimitado</td>
						</tr>
						<tr>
							<td><strong>Exceso de Spans</strong></td>
							<td>N/A</td>
							<td>N/A (Soft Limit)</td>
							<td>$0.10 por 10k spans</td>
							<td>Acordado por contrato</td>
							<td>Personalizado</td>
						</tr>
						<tr>
							<td><strong>Retención de Datos</strong></td>
							<td>Capacidad local</td>
							<td>14 días</td>
							<td>30 días</td>
							<td>90 días</td>
							<td>Personalizada (&gt;1 año)</td>
						</tr>
						<tr>
							<td><strong>Seats / Usuarios</strong></td>
							<td>1 usuario (CLI local)</td>
							<td>Hasta 3 seats</td>
							<td>Hasta 10 seats</td>
							<td>Hasta 50 seats (expandible)</td>
							<td>Ilimitados</td>
						</tr>
						<tr>
							<td><strong>Evaluaciones / Runs</strong></td>
							<td>~5 runs / mes</td>
							<td>~10 runs / mes</td>
							<td>~50 runs / mes</td>
							<td>~500 runs / mes</td>
							<td>Ilimitadas</td>
						</tr>
						<tr>
							<td><strong>Despliegue</strong></td>
							<td>Local (SQLite integrado)</td>
							<td>Cloud (SaaS)</td>
							<td>Cloud (SaaS multiusuario)</td>
							<td>VPC / On-Prem (Docker, Helm)</td>
							<td>VPC, On-Prem, Híbrido, Kafka</td>
						</tr>
						<tr>
							<td><strong>SLA de Uptime</strong></td>
							<td>N/A (Local)</td>
							<td>99.9%</td>
							<td>99.9%</td>
							<td>99.99%</td>
							<td>Nivel máximo garantizado</td>
						</tr>
						<tr>
							<td><strong>Canal de Soporte</strong></td>
							<td>Comunidad / GitHub</td>
							<td>Discord / Comunidad</td>
							<td>Email</td>
							<td>24/7 Pager & Account Manager</td>
							<td>24/7 Dedicated TAM</td>
						</tr>
						<tr>
							<td><strong>Tiempo de Respuesta</strong></td>
							<td>Soporte voluntario</td>
							<td>Mejor esfuerzo</td>
							<td>Standard</td>
							<td>&lt;15 minutos</td>
							<td>Inmediato (TAM)</td>
						</tr>
						<tr>
							<td><strong>Servicios Profesionales</strong></td>
							<td>No</td>
							<td>No</td>
							<td>No</td>
							<td>Opcional</td>
							<td>Incluido (Migración, talleres)</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<!-- SALES ARGUMENTS -->
		<section class="section-frame surface-sunken" style="margin-top: 4rem;">
			<div class="section-heading" style="margin-bottom: 3rem;">
				<p class="section-kicker">Propuesta de Valor</p>
				<h2>¿Por qué Cortex Persist?</h2>
			</div>

			<div class="arguments-grid">
				<!-- Core -->
				<div class="argument-card">
					<h4>Core (Local): Gratis y sin riesgo</h4>
					<p>Ideal para desarrolladores y pruebas de concepto. Permite evaluar toda la potencia de nuestra infraestructura local con SQLite sin realizar ninguna inversión inicial. La independencia de ejecución en un solo binario simplifica drásticamente tus pruebas iniciales.</p>
				</div>
				<!-- Starter SaaS -->
				<div class="argument-card">
					<h4>Starter: Desarrolladores pragmáticos</h4>
					<p>Trazas inmutables en la nube sin configurar infraestructura. Especialmente diseñado para sincronizarse nativamente con <strong>Langfuse</strong> u otras plataformas de observabilidad, convirtiendo logs estándar en evidencia criptográfica con una sola variable de entorno.</p>
				</div>
				<!-- Pro -->
				<div class="argument-card">
					<h4>Pro (SaaS): Escalado para equipos</h4>
					<p>Diseñado para startups y equipos de IA en pleno crecimiento. Habilita la colaboración multiusuario y proporciona total visibilidad sobre el costo y retención de tokens, protegiendo tus presupuestos de sorpresas imprevistas facturadas por consumo.</p>
				</div>
				<!-- Enterprise -->
				<div class="argument-card">
					<h4>Enterprise: Seguridad y control total</h4>
					<p>Imprescindible para compañías medianas o grandes en entornos altamente regulados (fintech, e-health). Permite despliegues seguros dentro de tu VPC con integración LDAP/SSO, cifrado absoluto y cumplimiento de normativas de custodia como GDPR y LOPD.</p>
				</div>
				<!-- Estratégico -->
				<div class="argument-card">
					<h4>Estratégico: Alianza y co-diseño</h4>
					<p>Un traje a medida diseñado conjuntamente con grandes corporaciones. Obtén soporte prioritario de un Technical Account Manager (TAM) dedicado, auditoría continua SOC 2 Tipo II, integraciones a medida con colas distribuidas Kafka, y co-diseño de nuestro roadmap de producto.</p>
				</div>
			</div>
		</section>

		<!-- FAQS SECTION -->
		<section class="section-frame surface faq-section">
			<div class="section-heading">
				<p class="section-kicker">FAQs</p>
				<h2>Preguntas Frecuentes</h2>
				<p>Resolución de dudas sobre facturación, límites y el funcionamiento del control plane.</p>
			</div>

			<div class="faq-list">
				<div class="faq-item">
					<h3 class="faq-question">¿Cómo empiezo sin compromiso?</h3>
					<p class="faq-answer">Puedes descargar el plan Core de código abierto gratuitamente, sin necesidad de tarjeta de crédito. Incluye hasta ~50k spans de prueba por mes (planificación aproximada) con todas las características básicas de trazabilidad e inmutabilidad local.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Qué pasa si supero los límites de uso?</h3>
					<p class="faq-answer">El exceso se factura automáticamente según el consumo registrado en tu panel. En el plan Pro SaaS, cobramos $0.10 por cada 10,000 spans adicionales. También puedes solicitar un upgrade preventivo para ajustar tu plan antes de incurrir en costos variables.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Cómo se diferencia un “span” de una “traza”?</h3>
					<p class="faq-answer">Cada <strong>span</strong> es una operación individual y discreta (como una llamada específica a una API de LLM, una consulta de vector o un paso intermedio de un agente). Una <strong>traza</strong> es el grafo dirigido completo que agrupa la secuencia de spans involucrados en una interacción o tarea final. El span es la unidad atómica de facturación de datos en CORTEX.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Necesito firmar contrato o pagar a plazo?</h3>
					<p class="faq-answer">El plan Core es Apache-2.0 de descarga libre sin contratos. El plan Pro se factura con carácter mensual recurrente y es cancelable en cualquier momento desde tu panel de facturación. Los planes Enterprise y Estratégicos operan con facturación y contratos anuales con SLAs garantizados.</p>
				</div>

				<div class="faq-item">
					<h3 class="faq-question">¿Hay soporte dedicado o SLA en Pro?</h3>
					<p class="faq-answer">El plan Pro ofrece un SLA estándar de 99.9% de disponibilidad y atención de soporte vía correo electrónico. Si requieres soporte crítico 24/7 con guardias a través de buscapersonas (Pager), gestor de cuenta asignado y un SLA de resolución menor a 15 minutos, debes optar por nuestros planes Enterprise o Estratégico.</p>
				</div>
			</div>
		</section>

		<!-- FOOTER -->
		<footer class="site-footer">
			<p class="footer-note">CORTEX Persist / The swarm verifies. The hardware remembers. <span style="opacity:0.5; margin-left:8px;">| Powered by Cloudflare Edge</span></p>
			<div class="footer-links">
				<a href="https://github.com/borjamoskv/Cortex-Persist" target="_blank" rel="noreferrer">GitHub</a>
				<a href="https://github.com/borjamoskv/Cortex-Persist/tree/main/docs" target="_blank" rel="noreferrer">Docs</a>
				<a href="/certificaciones">Certificaciones</a>
				<a href="/pricing">Precios</a>
				<a href="https://agents.archi" target="_blank" rel="noreferrer">Audit Registry</a>
			</div>
		</footer>
	</main>
</SiteLayout>

<style>
/* Responsive grid */
.pricing-grid-4 {
	display: grid;
	gap: 1.5rem;
	grid-template-columns: 1fr;
	margin-top: 3rem;
}
@media (min-width: 768px) {
	.pricing-grid-4 {
		grid-template-columns: repeat(2, 1fr);
	}
}
@media (min-width: 1200px) {
	.pricing-grid-4 {
		grid-template-columns: repeat(5, 1fr);
	}
}

/* Card details */
.pricing-card-custom {
	display: flex;
	flex-direction: column;
	background: var(--bg-1, #0f0f12);
	border: 1px solid rgba(255, 255, 255, 0.05);
	border-radius: var(--radius-lg, 6px);
	padding: 2.2rem 1.8rem;
	transition: border-color 0.2s ease, transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
	position: relative;
}
.pricing-card-custom:hover {
	border-color: rgba(43, 59, 229, 0.35);
	transform: translateY(-4px);
}
.pricing-card-featured-custom {
	border-color: rgba(43, 59, 229, 0.45);
	box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(43, 59, 229, 0.2);
	background: linear-gradient(180deg, rgba(43, 59, 229, 0.04) 0%, rgba(15, 15, 18, 0.95) 100%);
}
.pricing-card-tag {
	position: absolute;
	top: 1rem;
	right: 1.2rem;
	background: var(--accent, #2b3be5);
	color: #fff;
	font-size: 0.65rem;
	font-family: 'IBM Plex Mono', monospace;
	padding: 0.25rem 0.55rem;
	border-radius: 4px;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	font-weight: bold;
}
.pricing-card-title {
	font-family: 'Orbitron', sans-serif;
	font-size: 1.4rem;
	margin: 0 0 0.5rem 0;
	color: #fff;
	letter-spacing: 0.02em;
}
.pricing-card-price {
	font-size: 1.8rem;
	font-weight: 800;
	color: #fff;
	margin: 0.5rem 0 1.5rem 0;
	font-family: 'IBM Plex Mono', monospace;
	letter-spacing: -0.02em;
}
.pricing-card-price span {
	font-size: 0.85rem;
	color: var(--muted, #8e95af);
	font-weight: normal;
	font-family: 'Manrope', sans-serif;
	letter-spacing: 0;
}
.pricing-card-desc {
	color: var(--muted, #8e95af);
	font-size: 0.88rem;
	margin-bottom: 1.8rem;
	line-height: 1.5;
	min-height: 4rem;
}
.pricing-card-features {
	list-style: none;
	padding: 0;
	margin: 0 0 2rem 0;
	display: flex;
	flex-direction: column;
	gap: 0.8rem;
	flex-grow: 1;
}
.pricing-card-features li {
	display: flex;
	align-items: flex-start;
	gap: 0.6rem;
	font-size: 0.86rem;
	color: var(--text, #f3f4f6);
	line-height: 1.45;
}
.pricing-card-features li strong {
	color: #fff;
}
.pricing-card-features li::before {
	content: '✓';
	color: var(--success, #00e5a3);
	font-weight: bold;
	flex-shrink: 0;
	font-size: 0.9rem;
}
.pricing-card-cta {
	display: block;
	text-align: center;
	padding: 0.8rem 1.5rem;
	border-radius: var(--radius-md, 4px);
	font-weight: 600;
	font-size: 0.92rem;
	transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	width: 100%;
}
.pricing-card-cta-primary {
	background: var(--accent, #2b3be5);
	color: #fff;
}
.pricing-card-cta-primary:hover {
	background: var(--accent-soft, #6e7cff);
}
.pricing-card-cta-secondary {
	background: rgba(255, 255, 255, 0.03);
	border: 1px solid rgba(255, 255, 255, 0.08);
	color: #f3f4f6;
}
.pricing-card-cta-secondary:hover {
	background: rgba(255, 255, 255, 0.08);
	border-color: rgba(255, 255, 255, 0.15);
	color: #fff;
}

/* Matrix Table Styles */
.matrix-container {
	margin-top: 3rem;
	overflow-x: auto;
	border: 1px solid rgba(255, 255, 255, 0.05);
	border-radius: var(--radius-lg, 6px);
	background: var(--bg-1, #0f0f12);
}
.matrix-table {
	width: 100%;
	border-collapse: collapse;
	text-align: left;
	font-size: 0.88rem;
	min-width: 800px;
}
.matrix-table th, .matrix-table td {
	padding: 1.2rem;
	border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
.matrix-table th {
