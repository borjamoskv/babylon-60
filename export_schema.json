{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BABYLON-60 Immutable Artifact Manifest (v3.0.0)",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "binary_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "global_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$", "description": "Global seal of the custody chain" },
    "components": {
      "type": "object",
      "properties": {
        "trace_bin": { "type": "string", "description": "Hash of trace.bin" },
        "ledger_bin": { "type": "string", "description": "Hash of ledger.bin" },
        "proof_dir": { "type": "string", "description": "Hash of proof/ directory tree" },
        "signature_file": { "type": "string", "description": "Cryptographic signature of the global hash" }
      },
      "required": ["trace_bin", "ledger_bin", "proof_dir", "signature_file"]
    },
    "theorem_of_babylon_compliance": {
      "type": "boolean",
      "description": "True if termination occurred without CRITICAL HALT"
    }
  },
  "required": ["version", "binary_sha256", "global_hash", "components", "theorem_of_babylon_compliance"]
}
