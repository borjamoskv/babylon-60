# CORTEX Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Core ────────────────────────────────────────────────────────────
CORTEX_DB_PATH=~/.cortex/cortex.db
CORTEX_RATE_LIMIT=300
CORTEX_RATE_WINDOW=60
CORTEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Native Silicon (optional) ──────────────────────────────────────
# Exact binary overrides for the Rust ledger / strike engine.
# CORTEX_NATIVE_DB_BIN=/absolute/path/to/cortex-db
# CORTEX_NATIVE_STRIKE_BIN=/absolute/path/to/cortex-strike
# Legacy aliases supported by the resolver:
# CORTEX_DB_BIN=/absolute/path/to/cortex-db
# CORTEX_STRIKE_BIN=/absolute/path/to/cortex-strike

# ─── LLM Providers (add keys for providers you use) ──────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# TOGETHER_API_KEY=...
# XAI_API_KEY=xai-...
# COHERE_API_KEY=...
# MISTRAL_API_KEY=...
# FIREWORKS_API_KEY=...
# CEREBRAS_API_KEY=...
# SAMBANOVA_API_KEY=...
# ZHIPU_API_KEY=...
# AIMLAPI_KEY=...

# ─── Langbase (opt-in) ──────────────────────────────────────────────
# LANGBASE_API_KEY=...

# ─── Stripe Billing (opt-in) ────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Embeddings ─────────────────────────────────────────────────────
# CORTEX_EMBEDDINGS=local          # 'local' (default) or 'api'
# CORTEX_EMBEDDINGS_PROVIDER=gemini  # 'gemini' or 'openai' (when api mode)

# ─── MCP Toolbox (opt-in) ────────────────────────────────────────────
# TOOLBOX_URL=http://127.0.0.1:5000
# TOOLBOX_TOOLSET=cortex-readonly
# TOOLBOX_TIMEOUT=30

# ─── Cloud Storage (opt-in) ─────────────────────────────────────────
# CORTEX_STORAGE=local              # 'local' (default), 'turso', or 'postgres'
#
# Turso (libSQL edge):
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...
#
# PostgreSQL / AlloyDB:
# POSTGRES_DSN=postgresql://user:pass@host:5432/cortex
#
# Qdrant (vector store):
# QDRANT_URL=http://localhost:6333
#
# Redis (L1 cache):
# REDIS_URL=redis://localhost:6379/0

# ─── LinkedIn OAuth (Community Management API) ───────────────────────
# Developer Portal: https://www.linkedin.com/developers/apps
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_REDIRECT_URI=https://your-app.com/auth/linkedin/callback
#
# Set after running: cortex linkedin auth
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_TOKEN_EXPIRY=0        # Unix epoch when token expires
# LINKEDIN_ACTOR_URN=urn:li:person:XXXX  # or urn:li:organization:XXXX
