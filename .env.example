# CORTEX Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Core ───────────────────────────────────────
CORTEX_DB_PATH=~/.cortex/cortex.db
CORTEX_RATE_LIMIT=300
CORTEX_RATE_WINDOW=60
CORTEX_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── LLM Providers (add keys for providers you use) ──────────────
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GEMINI_API_KEY=your_gemini_key_here
# DEEPSEEK_API_KEY=your_deepseek_key_here
# GROQ_API_KEY=your_groq_key_here
# TOGETHER_API_KEY=your_together_key_here
# XAI_API_KEY=your_xai_key_here
# COHERE_API_KEY=your_cohere_key_here
# MISTRAL_API_KEY=your_mistral_key_here
# FIREWORKS_API_KEY=your_fireworks_key_here
# CEREBRAS_API_KEY=your_cerebras_key_here
# SAMBANOVA_API_KEY=your_sambanova_key_here
# ZHIPU_API_KEY=your_zhipu_key_here
# AIMLAPI_KEY=your_aimlapi_key_here

# ─── Langbase (opt-in) ────────────────
# LANGBASE_API_KEY=your_langbase_key_here

# ─── Stripe Billing (opt-in) ────────────────
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
