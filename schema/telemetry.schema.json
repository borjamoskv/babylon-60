{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "latency_metrics": {
      "type": "object",
      "properties": {
        "nvmeof_rocev2": {
          "type": "object",
          "properties": {
            "mean": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?µs$" },
            "p99": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?µs$" },
            "load": { "type": "string", "pattern": "^[0-9]+%$" },
            "pfc": { "type": "string", "enum": ["active", "inactive"] },
            "hardware": { "type": "string" }
          },
          "required": ["mean", "p99", "load", "pfc", "hardware"],
          "additionalProperties": false
        }
      },
      "required": ["nvmeof_rocev2"],
      "additionalProperties": false
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["latency_metrics", "timestamp"],
  "additionalProperties": false
}
