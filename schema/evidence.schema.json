{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Schema (L0)",
  "type": "object",
  "required": ["evidence_id", "source_type", "payload", "timestamp", "cortex_taint_hash"],
  "properties": {
    "evidence_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_type": {
      "type": "string",
      "enum": ["AST_DIFF", "LOG_FILE", "NETWORK_TRACE", "SQLITE_QUERY", "USER_INPUT"]
    },
    "payload": {
      "type": "string",
      "description": "Raw uncompressed data."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "cortex_taint_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$",
      "description": "SHA3-256 seal of the payload."
    }
  }
}
