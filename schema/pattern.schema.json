{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pattern Schema (L1)",
  "type": "object",
  "required": ["pattern_id", "evidence_ids", "invariant_claim", "shannon_entropy_score"],
  "properties": {
    "pattern_id": {
      "type": "string",
      "format": "uuid"
    },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 1
    },
    "invariant_claim": {
      "type": "string",
      "description": "The compressed, non-decorative claim extracted from evidence."
    },
    "shannon_entropy_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Metric measuring semantic density (Landauer compression validation)."
    }
  }
}
