{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experiment Schema (L4)",
  "type": "object",
  "required": ["experiment_id", "prediction_id", "execution_context", "outcome"],
  "properties": {
    "experiment_id": { "type": "string", "format": "uuid" },
    "prediction_id": { "type": "string", "format": "uuid" },
    "execution_context": {
      "type": "string",
      "enum": ["SANDBOX_THREAD", "ISOLATED_BRANCH", "DRY_RUN", "ORPHAN_QUERY"]
    },
    "outcome": {
      "type": "object",
      "required": ["refuted", "evidence_hash"],
      "properties": {
        "refuted": { "type": "boolean", "description": "True if prediction failed." },
        "evidence_hash": { "type": "string", "description": "Hash of the test execution log." }
      }
    }
  }
}
