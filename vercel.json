{
  "ignoreCommand": "bash -c 'if [[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]]; then exit 0; else exit 1; fi'",
  "redirects": [
    {
      "source": "/saas_landing/:match*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/prototypes/saas_landing.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
