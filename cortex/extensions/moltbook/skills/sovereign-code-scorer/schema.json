{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sovereign Code Scorer Report",
  "type": "object",
  "properties": {
    "path": {
      "type": "string"
    },
    "files_analyzed": {
      "type": "integer"
    },
    "total_score": {
      "type": "number"
    },
    "verdict": {
      "type": "string"
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "syntax": { "$ref": "#/definitions/dimension" },
        "semantics": { "$ref": "#/definitions/dimension" },
        "consistency": { "$ref": "#/definitions/dimension" },
        "tests": { "$ref": "#/definitions/dimension" },
        "aesthetics": { "$ref": "#/definitions/dimension" }
      },
      "required": ["syntax", "semantics", "consistency", "tests", "aesthetics"]
    },
    "issue_count": {
      "type": "integer"
    },
    "critical_issues": {
      "type": "integer"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "category": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" }
        },
        "required": ["file", "line", "category", "severity", "message"]
      }
    },
    "files": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "path",
    "files_analyzed",
    "total_score",
    "verdict",
    "dimensions",
    "issue_count",
    "critical_issues"
  ],
  "definitions": {
    "dimension": {
      "type": "object",
      "properties": {
        "score": { "type": "number" },
        "max": { "type": "number" }
      },
      "required": ["score", "max"]
    }
  }
}
